{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SWFEN3YVmXkZ6DimASmNDC","type":"tool_result","content":"     1→const core = require(\"@actions/core\");\n     2→const { transitionLabel } = require(\"../labels\");\n     3→\n     4→module.exports = async function ship(ctx) {\n     5→  const { octokit, context, config } = ctx;\n     6→  const pr = context.payload.pull_request;\n     7→  const prefix = config.labels?.prefix || \"kiln\";\n     8→\n     9→  if (!pr) {\n    10→    core.info(\"🔥 Ship — No PR in payload, skipping.\");\n    11→    return { status: \"skipped\" };\n    12→  }\n    13→\n    14→  core.info(`🔥 Ship — Checking if PR #${pr.number} is ready to merge`);\n    15→\n    16→  // Verify conditions: approved + CI green\n    17→  const { data: reviews } = await octokit.rest.pulls.listReviews({\n    18→    ...context.repo,\n    19→    pull_number: pr.number,\n    20→  });\n    21→\n    22→  const isApproved = reviews.some((r) => r.state === \"APPROVED\");\n    23→  if (!isApproved) {\n    24→    core.info(\"🔥 Ship — PR not yet approved. Skipping.\");\n    25→    return { status: \"skipped\", reason: \"not-approved\" };\n    26→  }\n    27→\n    28→  // Check CI status\n    29→  const { data: checks } = await octokit.rest.checks.listForRef({\n    30→    ...context.repo,\n    31→    ref: pr.head.sha,\n    32→  });\n    33→\n    34→  const ciPassing = checks.check_runs\n    35→    .filter((c) => c.name !== \"kiln\") // Exclude our own check\n    36→    .every((c) => c.conclusion === \"success\" || c.conclusion === \"skipped\" || c.status === \"queued\");\n    37→\n    38→  if (!ciPassing) {\n    39→    core.info(\"🔥 Ship — CI not yet green. Will retry when checks complete.\");\n    40→    return { status: \"skipped\", reason: \"ci-pending\" };\n    41→  }\n    42→\n    43→  // Check auto_merge config\n    44→  if (!config.auto_merge) {\n    45→    core.info(\"🔥 Ship — Auto-merge disabled. PR is approved and ready for manual merge.\");\n    46→    await octokit.rest.issues.createComment({\n    47→      ...context.repo,\n    48→      issue_number: pr.number,\n    49→      body: \"✅ **Kiln** — PR approved and CI green. Auto-merge is disabled — merge when ready.\",\n    50→    });\n    51→    return { status: \"success\", reason: \"auto-merge-disabled\" };\n    52→  }\n    53→\n    54→  // Merge!\n    55→  core.info(`🔥 Ship — Merging PR #${pr.number}`);\n    56→\n    57→  try {\n    58→    await octokit.rest.pulls.merge({\n    59→      ...context.repo,\n    60→      pull_number: pr.number,\n    61→      merge_method: \"squash\",\n    62→      commit_title: `${pr.title} (#${pr.number})`,\n    63→    });\n    64→  } catch (error) {\n    65→    core.warning(`Merge failed: ${error.message}`);\n    66→    return { status: \"error\", reason: \"merge-failed\" };\n    67→  }\n    68→\n    69→  // Extract and close the linked issue\n    70→  const issueMatch = pr.body?.match(/Closes #(\\d+)/);\n    71→  if (issueMatch) {\n    72→    const issueNumber = parseInt(issueMatch[1]);\n    73→\n    74→    await transitionLabel(octokit, context, issueNumber, \"in-review\", \"done\", prefix);\n    75→\n    76→    await octokit.rest.issues.update({\n    77→      ...context.repo,\n    78→      issue_number: issueNumber,\n    79→      state: \"closed\",\n    80→    });\n    81→\n    82→    await octokit.rest.issues.createComment({\n    83→      ...context.repo,\n    84→      issue_number: issueNumber,\n    85→      body: [\n    86→        \"🔥 **Kiln** — Shipped!\",\n    87→        \"\",\n    88→        `Implementation merged via #${pr.number}.`,\n    89→        \"\",\n    90→        \"*Fired in the Kiln.* 🏷️\",\n    91→      ].join(\"\\n\"),\n    92→    });\n    93→\n    94→    core.info(`🔥 Ship — Issue #${issueNumber} closed.`);\n    95→  }\n    96→\n    97→  core.info(\"🔥 Shipped! 🚀\");\n    98→  return { status: \"success\" };\n    99→};\n   100→"}]},"parent_tool_use_id":null,"session_id":"2a8b2ce2-e0c8-48b6-8ab6-0a0f1560652c","uuid":"fd7edf43-4445-4e20-ba26-7f5356d36ef5","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/ship.js","content":"const core = require(\"@actions/core\");\nconst { transitionLabel } = require(\"../labels\");\n\nmodule.exports = async function ship(ctx) {\n  const { octokit, context, config } = ctx;\n  const pr = context.payload.pull_request;\n  const prefix = config.labels?.prefix || \"kiln\";\n\n  if (!pr) {\n    core.info(\"🔥 Ship — No PR in payload, skipping.\");\n    return { status: \"skipped\" };\n  }\n\n  core.info(`🔥 Ship — Checking if PR #${pr.number} is ready to merge`);\n\n  // Verify conditions: approved + CI green\n  const { data: reviews } = await octokit.rest.pulls.listReviews({\n    ...context.repo,\n    pull_number: pr.number,\n  });\n\n  const isApproved = reviews.some((r) => r.state === \"APPROVED\");\n  if (!isApproved) {\n    core.info(\"🔥 Ship — PR not yet approved. Skipping.\");\n    return { status: \"skipped\", reason: \"not-approved\" };\n  }\n\n  // Check CI status\n  const { data: checks } = await octokit.rest.checks.listForRef({\n    ...context.repo,\n    ref: pr.head.sha,\n  });\n\n  const ciPassing = checks.check_runs\n    .filter((c) => c.name !== \"kiln\") // Exclude our own check\n    .every((c) => c.conclusion === \"success\" || c.conclusion === \"skipped\" || c.status === \"queued\");\n\n  if (!ciPassing) {\n    core.info(\"🔥 Ship — CI not yet green. Will retry when checks complete.\");\n    return { status: \"skipped\", reason: \"ci-pending\" };\n  }\n\n  // Check auto_merge config\n  if (!config.auto_merge) {\n    core.info(\"🔥 Ship — Auto-merge disabled. PR is approved and ready for manual merge.\");\n    await octokit.rest.issues.createComment({\n      ...context.repo,\n      issue_number: pr.number,\n      body: \"✅ **Kiln** — PR approved and CI green. Auto-merge is disabled — merge when ready.\",\n    });\n    return { status: \"success\", reason: \"auto-merge-disabled\" };\n  }\n\n  // Merge!\n  core.info(`🔥 Ship — Merging PR #${pr.number}`);\n\n  try {\n    await octokit.rest.pulls.merge({\n      ...context.repo,\n      pull_number: pr.number,\n      merge_method: \"squash\",\n      commit_title: `${pr.title} (#${pr.number})`,\n    });\n  } catch (error) {\n    core.warning(`Merge failed: ${error.message}`);\n    return { status: \"error\", reason: \"merge-failed\" };\n  }\n\n  // Extract and close the linked issue\n  const issueMatch = pr.body?.match(/Closes #(\\d+)/);\n  if (issueMatch) {\n    const issueNumber = parseInt(issueMatch[1]);\n\n    await transitionLabel(octokit, context, issueNumber, \"in-review\", \"done\", prefix);\n\n    await octokit.rest.issues.update({\n      ...context.repo,\n      issue_number: issueNumber,\n      state: \"closed\",\n    });\n\n    await octokit.rest.issues.createComment({\n      ...context.repo,\n      issue_number: issueNumber,\n      body: [\n        \"🔥 **Kiln** — Shipped!\",\n        \"\",\n        `Implementation merged via #${pr.number}.`,\n        \"\",\n        \"*Fired in the Kiln.* 🏷️\",\n      ].join(\"\\n\"),\n    });\n\n    core.info(`🔥 Ship — Issue #${issueNumber} closed.`);\n  }\n\n  core.info(\"🔥 Shipped! 🚀\");\n  return { status: \"success\" };\n};\n","numLines":100,"startLine":1,"totalLines":100}}}
