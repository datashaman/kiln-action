{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017E3YWSwQv25WqQNkNG3FXB","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import { runClaude } from \"../claude\";\n     3→import { transitionLabel } from \"../labels\";\n     4→import { KilnContext, StageResult } from \"../types\";\n     5→\n     6→export default async function triage(ctx: KilnContext): Promise<StageResult> {\n     7→  const { octokit, context, config, anthropicKey, timeoutMinutes } = ctx;\n     8→  const issue = context.payload.issue!;\n     9→  const prefix = config.labels?.prefix || \"kiln\";\n    10→\n    11→  core.info(`🔥 Triage — Issue #${issue.number}: ${issue.title}`);\n    12→\n    13→  const prompt = `You are the Kiln triage agent. Analyze this issue and respond with ONLY a JSON block.\n    14→\n    15→**Issue #${issue.number}**\n    16→**Title:** ${issue.title}\n    17→**Body:** ${issue.body || \"(empty)\"}\n    18→\n    19→Classify and assess:\n    20→1. Type: feature, bug, improvement, or chore\n    21→2. Complexity: xs, s, m, l, xl\n    22→3. Is there enough information to write a technical spec? (clear_enough: true/false)\n    23→4. Write a brief comment for the issue author.\n    24→\n    25→If NOT clear enough, your comment should politely ask for the specific missing information.\n    26→If clear enough, your comment should confirm your understanding of what needs to be done.\n    27→\n    28→Respond with ONLY this JSON:\n    29→\\`\\`\\`json\n    30→{\n    31→  \"type\": \"feature\",\n    32→  \"complexity\": \"m\",\n    33→  \"clear_enough\": true,\n    34→  \"comment\": \"Your comment here\"\n    35→}\n    36→\\`\\`\\``;\n    37→\n    38→  const output = runClaude(prompt, { anthropicKey, timeoutMinutes });\n    39→\n    40→  let result: {\n    41→    type: string;\n    42→    complexity: string;\n    43→    clear_enough: boolean;\n    44→    comment: string;\n    45→  };\n    46→  try {\n    47→    const jsonMatch =\n    48→      output.match(/```json\\s*([\\s\\S]*?)\\s*```/) ||\n    49→      output.match(/\\{[\\s\\S]*\\}/);\n    50→    const jsonStr = jsonMatch ? jsonMatch[1] || jsonMatch[0] : output;\n    51→    result = JSON.parse(jsonStr);\n    52→  } catch (error) {\n    53→    const message = error instanceof Error ? error.message : String(error);\n    54→    core.warning(`Failed to parse triage response: ${message}`);\n    55→    core.warning(`Raw output: ${output}`);\n    56→    result = {\n    57→      type: \"feature\",\n    58→      complexity: \"m\",\n    59→      clear_enough: true,\n    60→      comment: \"🔥 **Kiln** — Triaged. Moving to specification.\",\n    61→    };\n    62→  }\n    63→\n    64→  await octokit.rest.issues.createComment({\n    65→    ...context.repo,\n    66→    issue_number: issue.number,\n    67→    body: `🔥 **Kiln Triage**\\n\\n${result.comment}\\n\\n---\\n*Type: \\`${result.type}\\` · Size: \\`${result.complexity}\\`*`,\n    68→  });\n    69→\n    70→  const labels = [`type:${result.type}`, `size:${result.complexity}`];\n    71→  await octokit.rest.issues.addLabels({\n    72→    ...context.repo,\n    73→    issue_number: issue.number,\n    74→    labels,\n    75→  });\n    76→\n    77→  if (result.clear_enough) {\n    78→    await transitionLabel(\n    79→      octokit,\n    80→      context,\n    81→      issue.number,\n    82→      null,\n    83→      \"specifying\",\n    84→      prefix,\n    85→    );\n    86→    return { status: \"success\", nextStage: \"specify\" };\n    87→  }\n    88→\n    89→  await octokit.rest.issues.addLabels({\n    90→    ...context.repo,\n    91→    issue_number: issue.number,\n    92→    labels: [\"needs-info\"],\n    93→  });\n    94→\n    95→  return { status: \"success\", nextStage: \"waiting-for-info\" };\n    96→}\n    97→"}]},"parent_tool_use_id":null,"session_id":"8981eff5-58b5-4df5-8b71-0aaa41565c79","uuid":"0cefb918-fee5-4f24-bb14-0941c1d29356","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/triage.ts","content":"import * as core from \"@actions/core\";\nimport { runClaude } from \"../claude\";\nimport { transitionLabel } from \"../labels\";\nimport { KilnContext, StageResult } from \"../types\";\n\nexport default async function triage(ctx: KilnContext): Promise<StageResult> {\n  const { octokit, context, config, anthropicKey, timeoutMinutes } = ctx;\n  const issue = context.payload.issue!;\n  const prefix = config.labels?.prefix || \"kiln\";\n\n  core.info(`🔥 Triage — Issue #${issue.number}: ${issue.title}`);\n\n  const prompt = `You are the Kiln triage agent. Analyze this issue and respond with ONLY a JSON block.\n\n**Issue #${issue.number}**\n**Title:** ${issue.title}\n**Body:** ${issue.body || \"(empty)\"}\n\nClassify and assess:\n1. Type: feature, bug, improvement, or chore\n2. Complexity: xs, s, m, l, xl\n3. Is there enough information to write a technical spec? (clear_enough: true/false)\n4. Write a brief comment for the issue author.\n\nIf NOT clear enough, your comment should politely ask for the specific missing information.\nIf clear enough, your comment should confirm your understanding of what needs to be done.\n\nRespond with ONLY this JSON:\n\\`\\`\\`json\n{\n  \"type\": \"feature\",\n  \"complexity\": \"m\",\n  \"clear_enough\": true,\n  \"comment\": \"Your comment here\"\n}\n\\`\\`\\``;\n\n  const output = runClaude(prompt, { anthropicKey, timeoutMinutes });\n\n  let result: {\n    type: string;\n    complexity: string;\n    clear_enough: boolean;\n    comment: string;\n  };\n  try {\n    const jsonMatch =\n      output.match(/```json\\s*([\\s\\S]*?)\\s*```/) ||\n      output.match(/\\{[\\s\\S]*\\}/);\n    const jsonStr = jsonMatch ? jsonMatch[1] || jsonMatch[0] : output;\n    result = JSON.parse(jsonStr);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.warning(`Failed to parse triage response: ${message}`);\n    core.warning(`Raw output: ${output}`);\n    result = {\n      type: \"feature\",\n      complexity: \"m\",\n      clear_enough: true,\n      comment: \"🔥 **Kiln** — Triaged. Moving to specification.\",\n    };\n  }\n\n  await octokit.rest.issues.createComment({\n    ...context.repo,\n    issue_number: issue.number,\n    body: `🔥 **Kiln Triage**\\n\\n${result.comment}\\n\\n---\\n*Type: \\`${result.type}\\` · Size: \\`${result.complexity}\\`*`,\n  });\n\n  const labels = [`type:${result.type}`, `size:${result.complexity}`];\n  await octokit.rest.issues.addLabels({\n    ...context.repo,\n    issue_number: issue.number,\n    labels,\n  });\n\n  if (result.clear_enough) {\n    await transitionLabel(\n      octokit,\n      context,\n      issue.number,\n      null,\n      \"specifying\",\n      prefix,\n    );\n    return { status: \"success\", nextStage: \"specify\" };\n  }\n\n  await octokit.rest.issues.addLabels({\n    ...context.repo,\n    issue_number: issue.number,\n    labels: [\"needs-info\"],\n  });\n\n  return { status: \"success\", nextStage: \"waiting-for-info\" };\n}\n","numLines":97,"startLine":1,"totalLines":97}}}
