IONS:\n    43→1. Read the specification at: ${specPath}\n    44→2. Read the existing codebase to understand conventions, patterns, and style\n    45→3. Implement EVERYTHING described in the spec\n    46→\n    47→RULES:\n    48→- Follow existing project conventions exactly (naming, structure, patterns)\n    49→- Write ALL tests described in the spec's Test Plan\n    50→- Run the test suite and fix any failures\n    51→- Run linting/formatting and fix any issues\n    52→- Use conventional commits: feat:, fix:, test:, refactor:, etc.\n    53→- Keep commits atomic and well-described\n    54→- Each commit message should reference #${issueNum}\n    55→\n    56→DO NOT modify these protected paths:\n    57→${protectedList}\n    58→\n    59→DO NOT:\n    60→- Change anything outside the scope of the spec\n    61→- Skip writing tests\n    62→- Leave TODO or FIXME comments — implement everything\n    63→- Modify unrelated files\n    64→\n    65→After implementing, commit all changes and push to the current branch.`;\n    66→\n    67→  await runClaudeEdit(prompt, { anthropicKey, timeoutMinutes });\n    68→\n    69→  // Push the branch\n    70→  try {\n    71→    execSync(`git push origin ${branchName} --force`);\n    72→  } catch (error) {\n    73→    core.warning(`Push failed (Claude may have already pushed): ${error.message}`);\n    74→  }\n    75→\n    76→  // Create the implementation PR\n    77→  const { data: pr } = await octokit.rest.pulls.create({\n    78→    ...context.repo,\n    79→    title: `🔨 Kiln: ${issue.title}`,\n    80→    body: [\n    81→      `## Implementation for #${issueNum}`,\n    82→      \"\",\n    83→      `📋 Spec: \\`${specPath}\\``,\n    84→      \"\",\n    85→      \"🔥 *Fired in the Kiln*\",\n    86→      \"\",\n    87→      \"### Checklist\",\n    88→      \"- [ ] All acceptance criteria from spec are met\",\n    89→      \"- [ ] Tests passing\",\n    90→      \"- [ ] Lint passing\",\n    91→      \"- [ ] No changes outside spec scope\",\n    92→      \"\",\n    93→      `Closes #${issueNum}`,\n    94→    ].join(\"\\n\"),\n    95→    head: branchName,\n    96→    base: \"main\",\n    97→  });\n    98→\n    99→  // Label the PR\n   100→  await octokit.rest.issues.addLabels({\n   101→    ...context.repo,\n   102→    issue_number: pr.number,\n   103→    labels: [`${prefix}:implementation`, \"needs-review\"],\n   104→  });\n   105→\n   106→  // Comment on issue\n   107→  await octokit.rest.issues.createComment({\n   108→    ...context.repo,\n   109→    issue_number: issueNum,\n   110→    body: `🔍 **Kiln** — Implementation PR ready: #${pr.number}`,\n   111→  });\n   112→\n   113→  // Transition issue label\n   114→  await transitionLabel(octokit, context, issueNum, \"implementing\", \"in-review\", prefix);\n   115→\n   116→  return { status: \"success\", prNumber: pr.number };\n   117→};\n   118→"}]},"parent_tool_use_id":null,"session_id":"2a8b2ce2-e0c8-48b6-8ab6-0a0f1560652c","uuid":"a7c80978-1c4a-4098-b2f6-78d1cc415a88","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/implement.js","content":"const core = require(\"@actions/core\");\nconst fs = require(\"fs\");\nconst { execSync } = require(\"child_process\");\nconst { runClaudeEdit } = require(\"../claude\");\nconst { transitionLabel } = require(\"../labels\");\n\nmodule.exports = async function implement(ctx) {\n  const { octokit, context, config, anthropicKey, timeoutMinutes } = ctx;\n  const issue = context.payload.issue;\n  const prefix = config.labels?.prefix || \"kiln\";\n  const issueNum = issue.number;\n  const branchName = `kiln/impl/issue-${issueNum}`;\n  const specPath = `specs/issue-${issueNum}.md`;\n\n  core.info(`🔥 Implement — Issue #${issueNum}: ${issue.title}`);\n\n  // Pull latest main (spec should be merged)\n  execSync(\"git fetch origin main && git checkout main && git pull origin main\");\n\n  // Verify spec exists\n  if (!fs.existsSync(specPath)) {\n    core.setFailed(`Spec not found at ${specPath}. Was the spec PR merged?`);\n    return { status: \"error\" };\n  }\n\n  // Configure git\n  execSync('git config user.name \"kiln[bot]\"');\n  execSync('git config user.email \"kiln[bot]@users.noreply.github.com\"');\n\n  // Create implementation branch\n  execSync(`git checkout -b ${branchName}`);\n\n  // Build protected paths list for the prompt\n  const protectedPaths = config.protected_paths || [\".github/\", \".env\", \"CLAUDE.md\"];\n  const protectedList = protectedPaths.map((p) => `- ${p}`).join(\"\\n\");\n\n  const prompt = `You are the Kiln implementation agent. You write production-quality code.\n\n**Issue #${issueNum}**\n**Title:** ${issue.title}\n\nINSTRUCTIONS:\n1. Read the specification at: ${specPath}\n2. Read the existing codebase to understand conventions, patterns, and style\n3. Implement EVERYTHING described in the spec\n\nRULES:\n- Follow existing project conventions exactly (naming, structure, patterns)\n- Write ALL tests described in the spec's Test Plan\n- Run the test suite and fix any failures\n- Run linting/formatting and fix any issues\n- Use conventional commits: feat:, fix:, test:, refactor:, etc.\n- Keep commits atomic and well-described\n- Each commit message should reference #${issueNum}\n\nDO NOT modify these protected paths:\n${protectedList}\n\nDO NOT:\n- Change anything outside the scope of the spec\n- Skip writing tests\n- Leave TODO or FIXME comments — implement everything\n- Modify unrelated files\n\nAfter implementing, commit all changes and push to the current branch.`;\n\n  await runClaudeEdit(prompt, { anthropicKey, timeoutMinutes });\n\n  // Push the branch\n  try {\n    execSync(`git push origin ${branchName} --force`);\n  } catch (error) {\n    core.warning(`Push failed (Claude may have already pushed): ${error.message}`);\n  }\n\n  // Create the implementation PR\n  const { data: pr } = await octokit.rest.pulls.create({\n    ...context.repo,\n    title: `🔨 Kiln: ${issue.title}`,\n    body: [\n      `## Implementation for #${issueNum}`,\n      \"\",\n      `📋 Spec: \\`${specPath}\\``,\n      \"\",\n      \"🔥 *Fired in the Kiln*\",\n      \"\",\n      \"### Checklist\",\n      \"- [ ] All acceptance criteria from spec are met\",\n      \"- [ ] Tests passing\",\n      \"- [ ] Lint passing\",\n      \"- [ ] No changes outside spec scope\",\n      \"\",\n      `Closes #${issueNum}`,\n    ].join(\"\\n\"),\n    head: branchName,\n    base: \"main\",\n  });\n\n  // Label the PR\n  await octokit.rest.issues.addLabels({\n    ...context.repo,\n    issue_number: pr.number,\n    labels: [`${prefix}:implementation`, \"needs-review\"],\n  });\n\n  // Comment on issue\n  await octokit.rest.issues.createComment({\n    ...context.repo,\n    issue_number: issueNum,\n    body: `🔍 **Kiln** — Implementation PR ready: #${pr.number}`,\n  });\n\n  // Transition issue label\n  await transitionLabel(octokit, context, issueNum, \"implementing\", \"in-review\", prefix);\n\n  return { status: \"success\", prNumber: pr.number };\n};\n","numLines":118,"startLine":1,"totalLines":118}}}
