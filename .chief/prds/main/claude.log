{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y38WPLpS6z9ywSq3AfpgdV","type":"tool_result","content":"     1→const core = require(\"@actions/core\");\n     2→const github = require(\"@actions/github\");\n     3→const { loadConfig } = require(\"./config\");\n     4→const { ensureLabels } = require(\"./labels\");\n     5→const { detectStage } = require(\"./router\");\n     6→\n     7→// Stage handlers\n     8→const triage = require(\"./stages/triage\");\n     9→const specify = require(\"./stages/specify\");\n    10→const approveSpec = require(\"./stages/approve-spec\");\n    11→const implement = require(\"./stages/implement\");\n    12→const review = require(\"./stages/review\");\n    13→const fix = require(\"./stages/fix\");\n    14→const ship = require(\"./stages/ship\");\n    15→\n    16→const STAGES = {\n    17→  triage,\n    18→  specify,\n    19→  \"approve-spec\": approveSpec,\n    20→  implement,\n    21→  review,\n    22→  fix,\n    23→  ship,\n    24→};\n    25→\n    26→async function run() {\n    27→  try {\n    28→    const token = core.getInput(\"github_token\");\n    29→    const anthropicKey = core.getInput(\"anthropic_api_key\");\n    30→    const configPath = core.getInput(\"config_path\");\n    31→    const forceStage = core.getInput(\"stage\");\n    32→    const timeoutMinutes = parseInt(core.getInput(\"timeout_minutes\"), 10);\n    33→\n    34→    const octokit = github.getOctokit(token);\n    35→    const context = github.context;\n    36→\n    37→    // Load config from repo (or defaults)\n    38→    const config = await loadConfig(configPath);\n    39→\n    40→    // Ensure labels exist in the repo\n    41→    await ensureLabels(octokit, context, config);\n    42→\n    43→    // Check for emergency stop\n    44→    if (await isBlocked(octokit, context, config)) {\n    45→      core.info(\"🛑 Kiln is blocked on this issue. Skipping.\");\n    46→      core.setOutput(\"stage\", \"none\");\n    47→      core.setOutput(\"result\", \"blocked\");\n    48→      return;\n    49→    }\n    50→\n    51→    // Determine which stage to run\n    52→    const stage = forceStage !== \"auto\" ? forceStage : detectStage(context);\n    53→\n    54→    if (!stage) {\n    55→      core.info(\"🔥 Kiln — No matching stage for this event. Skipping.\");\n    56→      core.setOutput(\"stage\", \"none\");\n    57→      core.setOutput(\"result\", \"skipped\");\n    58→      return;\n    59→    }\n    60→\n    61→    core.info(`🔥 Kiln — Running stage: ${stage}`);\n    62→\n    63→    const handler = STAGES[stage];\n    64→    if (!handler) {\n    65→      core.setFailed(`Unknown stage: ${stage}`);\n    66→      return;\n    67→    }\n    68→\n    69→    // Build shared context for all stages\n    70→    const ctx = {\n    71→      octokit,\n    72→      context,\n    73→      config,\n    74→      anthropicKey,\n    75→      timeoutMinutes,\n    76→      token,\n    77→    };\n    78→\n    79→    const result = await handler(ctx);\n    80→\n    81→    core.setOutput(\"stage\", stage);\n    82→    core.setOutput(\"result\", result?.status || \"success\");\n    83→    if (result?.prNumber) {\n    84→      core.setOutput(\"pr_number\", result.prNumber.toString());\n    85→    }\n    86→\n    87→    core.info(`🔥 Kiln — Stage \"${stage}\" completed.`);\n    88→  } catch (error) {\n    89→    core.setFailed(`🔥 Kiln failed: ${error.message}`);\n    90→  }\n    91→}\n    92→\n    93→async function isBlocked(octokit, context, config) {\n    94→  const prefix = config.labels?.prefix || \"kiln\";\n    95→  const blockedLabel = `${prefix}:blocked`;\n    96→\n    97→  // Get issue number from either issue or PR event\n    98→  let issueNumber = context.payload.issue?.number;\n    99→  if (!issueNumber && context.payload.pull_request) {\n   100→    // Try to extract from PR body \"Closes #123\"\n   101→    const match = context.payload.pull_request.body?.match(/Closes #(\\d+)/);\n   102→    if (match) issueNumber = parseInt(match[1]);\n   103→  }\n   104→\n   105→  if (!issueNumber) return false;\n   106→\n   107→  try {\n   108→    const { data: issue } = await octokit.rest.issues.get({\n   109→      ...context.repo,\n   110→      issue_number: issueNumber,\n   111→    });\n   112→    return issue.labels.some((l) => l.name === blockedLabel);\n   113→  } catch {\n   114→    return false;\n   115→  }\n   116→}\n   117→\n   118→run();\n   119→"}]},"parent_tool_use_id":null,"session_id":"2a8b2ce2-e0c8-48b6-8ab6-0a0f1560652c","uuid":"eea5a34b-4fa0-4283-8571-9898863cf452","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/index.js","content":"const core = require(\"@actions/core\");\nconst github = require(\"@actions/github\");\nconst { loadConfig } = require(\"./config\");\nconst { ensureLabels } = require(\"./labels\");\nconst { detectStage } = require(\"./router\");\n\n// Stage handlers\nconst triage = require(\"./stages/triage\");\nconst specify = require(\"./stages/specify\");\nconst approveSpec = require(\"./stages/approve-spec\");\nconst implement = require(\"./stages/implement\");\nconst review = require(\"./stages/review\");\nconst fix = require(\"./stages/fix\");\nconst ship = require(\"./stages/ship\");\n\nconst STAGES = {\n  triage,\n  specify,\n  \"approve-spec\": approveSpec,\n  implement,\n  review,\n  fix,\n  ship,\n};\n\nasync function run() {\n  try {\n    const token = core.getInput(\"github_token\");\n    const anthropicKey = core.getInput(\"anthropic_api_key\");\n    const configPath = core.getInput(\"config_path\");\n    const forceStage = core.getInput(\"stage\");\n    const timeoutMinutes = parseInt(core.getInput(\"timeout_minutes\"), 10);\n\n    const octokit = github.getOctokit(token);\n    const context = github.context;\n\n    // Load config from repo (or defaults)\n    const config = await loadConfig(configPath);\n\n    // Ensure labels exist in the repo\n    await ensureLabels(octokit, context, config);\n\n    // Check for emergency stop\n    if (await isBlocked(octokit, context, config)) {\n      core.info(\"🛑 Kiln is blocked on this issue. Skipping.\");\n      core.setOutput(\"stage\", \"none\");\n      core.setOutput(\"result\", \"blocked\");\n      return;\n    }\n\n    // Determine which stage to run\n    const stage = forceStage !== \"auto\" ? forceStage : detectStage(context);\n\n    if (!stage) {\n      core.info(\"🔥 Kiln — No matching stage for this event. Skipping.\");\n      core.setOutput(\"stage\", \"none\");\n      core.setOutput(\"result\", \"skipped\");\n      return;\n    }\n\n    core.info(`🔥 Kiln — Running stage: ${stage}`);\n\n    const handler = STAGES[stage];\n    if (!handler) {\n      core.setFailed(`Unknown stage: ${stage}`);\n      return;\n    }\n\n    // Build shared context for all stages\n    const ctx = {\n      octokit,\n      context,\n      config,\n      anthropicKey,\n      timeoutMinutes,\n      token,\n    };\n\n    const result = await handler(ctx);\n\n    core.setOutput(\"stage\", stage);\n    core.setOutput(\"result\", result?.status || \"success\");\n    if (result?.prNumber) {\n      core.setOutput(\"pr_number\", result.prNumber.toString());\n    }\n\n    core.info(`🔥 Kiln — Stage \"${stage}\" completed.`);\n  } catch (error) {\n    core.setFailed(`🔥 Kiln failed: ${error.message}`);\n  }\n}\n\nasync function isBlocked(octokit, context, config) {\n  const prefix = config.labels?.prefix || \"kiln\";\n  const blockedLabel = `${prefix}:blocked`;\n\n  // Get issue number from either issue or PR event\n  let issueNumber = context.payload.issue?.number;\n  if (!issueNumber && context.payload.pull_request) {\n    // Try to extract from PR body \"Closes #123\"\n    const match = context.payload.pull_request.body?.match(/Closes #(\\d+)/);\n    if (match) issueNumber = parseInt(match[1]);\n  }\n\n  if (!issueNumber) return false;\n\n  try {\n    const { data: issue } = await octokit.rest.issues.get({\n      ...context.repo,\n      issue_number: issueNumber,\n    });\n    return issue.labels.some((l) => l.name === blockedLabel);\n  } catch {\n    return false;\n  }\n}\n\nrun();\n","numLines":119,"startLine":1,"totalLines":119}}}
