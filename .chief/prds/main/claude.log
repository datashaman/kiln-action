{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014EZHT1zYaRSZea5pej61up","type":"tool_result","content":"     1→import triage from \"./triage\";\n     2→import { KilnContext, KilnConfig, Octokit } from \"../types\";\n     3→import { Context } from \"@actions/github/lib/context\";\n     4→\n     5→jest.mock(\"@actions/core\");\n     6→jest.mock(\"../claude\");\n     7→jest.mock(\"../labels\");\n     8→\n     9→import * as core from \"@actions/core\";\n    10→import { runClaude } from \"../claude\";\n    11→import { transitionLabel } from \"../labels\";\n    12→\n    13→const mockedRunClaude = runClaude as unknown as jest.Mock;\n    14→const mockedTransitionLabel = transitionLabel as unknown as jest.Mock;\n    15→\n    16→function makeOctokit(): Octokit {\n    17→  return {\n    18→    rest: {\n    19→      issues: {\n    20→        createComment: jest.fn().mockResolvedValue({}),\n    21→        addLabels: jest.fn().mockResolvedValue({}),\n    22→      },\n    23→    },\n    24→  } as unknown as Octokit;\n    25→}\n    26→\n    27→function makeConfig(prefix = \"kiln\"): KilnConfig {\n    28→  return { labels: { prefix } } as unknown as KilnConfig;\n    29→}\n    30→\n    31→function makeContext(issuePayload: Record<string, unknown>): Context {\n    32→  return {\n    33→    eventName: \"issues\",\n    34→    payload: {\n    35→      action: \"opened\",\n    36→      issue: issuePayload,\n    37→    },\n    38→    repo: { owner: \"test-owner\", repo: \"test-repo\" },\n    39→  } as unknown as Context;\n    40→}\n    41→\n    42→function makeCtx(overrides: Partial<KilnContext> = {}): KilnContext {\n    43→  return {\n    44→    octokit: makeOctokit(),\n    45→    context: makeContext({\n    46→      number: 1,\n    47→      title: \"Add dark mode\",\n    48→      body: \"I want dark mode support for the app.\",\n    49→      labels: [],\n    50→    }),\n    51→    config: makeConfig(),\n    52→    anthropicKey: \"sk-ant-test-key\",\n    53→    timeoutMinutes: 30,\n    54→    token: \"ghp-test-token\",\n    55→    ...overrides,\n    56→  };\n    57→}\n    58→\n    59→const VALID_RESPONSE = JSON.stringify({\n    60→  type: \"feature\",\n    61→  complexity: \"m\",\n    62→  clear_enough: true,\n    63→  comment: \"I understand you want dark mode support. Moving to specification.\",\n    64→  labels: [\"ui\", \"theme\"],\n    65→});\n    66→\n    67→const UNCLEAR_RESPONSE = JSON.stringify({\n    68→  type: \"feature\",\n    69→  complexity: \"l\",\n    70→  clear_enough: false,\n    71→  comment:\n    72→    \"Could you clarify which pages should support dark mode? Also, should it persist across sessions?\",\n    73→  labels: [],\n    74→});\n    75→\n    76→beforeEach(() => {\n    77→  jest.clearAllMocks();\n    78→  mockedTransitionLabel.mockResolvedValue(undefined);\n    79→});\n    80→\n    81→describe(\"triage\", () => {\n    82→  // ── AC: Triggers on issues.opened ─────────────────────\n    83→  describe(\"triggers on issues.opened\", () => {\n    84→    it(\"processes an opened issue\", async () => {\n    85→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n    86→      const ctx = makeCtx();\n    87→      const result = await triage(ctx);\n    88→      expect(result.status).toBe(\"success\");\n    89→    });\n    90→\n    91→    it(\"logs the issue number and title\", async () => {\n    92→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n    93→      const ctx = makeCtx();\n    94→      await triage(ctx);\n    95→      expect(core.info).toHaveBeenCalledWith(\n    96→        expect.stringContaining(\"Issue #1: Add dark mode\"),\n    97→      );\n    98→    });\n    99→  });\n   100→\n   101→  // ── AC: Sends issue title and body to Claude ──────────\n   102→  describe(\"sends issue context to Claude\", () => {\n   103→    it(\"passes issue title and body in the prompt\", async () => {\n   104→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n   105→      const ctx = makeCtx();\n   106→      await triage(ctx);\n   107→\n   108→      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n   109→      expect(prompt).toContain(\"Add dark mode\");\n   110→      expect(prompt).toContain(\"I want dark mode support for the app.\");\n   111→    });\n   112→\n   113→    it(\"passes issue number in the prompt\", async () => {\n   114→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n   115→      const ctx = makeCtx();\n   116→      await triage(ctx);\n   117→\n   118→      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n   119→      expect(prompt).toContain(\"Issue #1\");\n   120→    });\n   121→\n   122→    it(\"handles empty issue body\", async () => {\n   123→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n   124→      const ctx = makeCtx({\n   125→        context: makeContext({\n   126→          number: 2,\n   127→          title: \"Bug\",\n   128→          body: null,\n   129→          labels: [],\n   130→        }),\n   131→      });\n   132→      await triage(ctx);\n   133→\n   134→      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n   135→      expect(prompt).toContain(\"(empty)\");\n   136→    });\n   137→\n   138→    it(\"passes anthropic key and timeout to runClaude\", async () => {\n   139→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n   140→      const ctx = makeCtx({ anthropicKey: \"sk-ant-custom\", timeoutMinutes: 15 });\n   141→      await triage(ctx);\n   142→\n   143→      expect(mockedRunClaude).toHaveBeenCalledWith(expect.any(String), {\n   144→        anthropicKey: \"sk-ant-custom\",\n   145→        timeoutMinutes: 15,\n   146→      });\n   147→    });\n   148→  });\n   149→\n   150→  // ── AC: Claude responds with structured JSON ──────────\n   151→  describe(\"parses Claude JSON response\", () => {\n   152→    it(\"parses JSON from code block\", async () => {\n   153→      mockedRunClaude.mockReturnValue(\n   154→        '```json\\n{\"type\":\"bug\",\"complexity\":\"s\",\"clear_enough\":true,\"comment\":\"Got it.\",\"labels\":[]}\\n```',\n   155→      );\n   156→      const ctx = makeCtx();\n   157→      const result = await triage(ctx);\n   158→      expect(result.status).toBe(\"success\");\n   159→    });\n   160→\n   161→    it(\"parses raw JSON without code block\", async () => {\n   162→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n   163→      const ctx = makeCtx();\n   164→      const result = await triage(ctx);\n   165→      expect(result.status).toBe(\"success\");\n   166→    });\n   167→\n   168→    it(\"falls back to defaults on parse failure\", async () => {\n   169→      mockedRunClaude.mockReturnValue(\"This is not JSON at all\");\n   170→      const ctx = makeCtx();\n   171→      const result = await triage(ctx);\n   172→\n   173→      expect(result.status).toBe(\"success\");\n   174→      expect(core.warning).toHaveBeenCalledWith(\n   175→        expect.stringContaining(\"Failed to parse triage response\"),\n   176→      );\n   177→      // Default: clear_enough=true → moves to specify\n   178→      expect(result.nextStage).toBe(\"specify\");\n   179→    });\n   180→\n   181→    it(\"logs raw output on parse failure\", async () => {\n   182→      mockedRunClaude.mockReturnValue(\"garbage output\");\n   183→      const ctx = makeCtx();\n   184→      await triage(ctx);\n   185→\n   186→      expect(core.warning).toHaveBeenCalledWith(\n   187→        expect.stringContaining(\"Raw output: garbage output\"),\n   188→      );\n   189→    });\n   190→  });\n   191→\n   192→  // ── AC: Applies type and size labels ──────────────────\n   193→  describe(\"applies labels\", () => {\n   194→    it(\"applies type:{type} and size:{complexity} labels\", async () => {\n   195→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n   196→      const ctx = makeCtx();\n   197→      await triage(ctx);\n   198→\n   199→      expect(ctx.octokit.rest.issues.addLabels).toHaveBeenCalledWith(\n   200→        expect.objectContaining({\n 