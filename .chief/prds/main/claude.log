{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N22ae4x1BBhJQg7RPZMgrv","type":"tool_result","content":"     1→const core = require(\"@actions/core\");\n     2→const fs = require(\"fs\");\n     3→const yaml = require(\"js-yaml\");\n     4→\n     5→const DEFAULTS = {\n     6→  protected_paths: [\".github/\", \".env\", \"CLAUDE.md\", \".kiln/\"],\n     7→  human_review: {\n     8→    spec: \"required\",\n     9→    implementation: \"auto\",\n    10→  },\n    11→  auto_merge: true,\n    12→  timeout_minutes: 30,\n    13→  labels: {\n    14→    prefix: \"kiln\",\n    15→  },\n    16→  agents: {\n    17→    triage: { enabled: true },\n    18→    spec: { enabled: true },\n    19→    implement: { enabled: true, run_tests: true, run_lint: true },\n    20→    review: { enabled: true, auto_approve: false },\n    21→    fix: { enabled: true, max_iterations: 3 },\n    22→  },\n    23→};\n    24→\n    25→async function loadConfig(configPath) {\n    26→  if (!fs.existsSync(configPath)) {\n    27→    core.info(`No config found at ${configPath}, using defaults.`);\n    28→    return DEFAULTS;\n    29→  }\n    30→\n    31→  try {\n    32→    const raw = fs.readFileSync(configPath, \"utf-8\");\n    33→    const userConfig = yaml.load(raw) || {};\n    34→    return deepMerge(DEFAULTS, userConfig);\n    35→  } catch (error) {\n    36→    core.warning(`Failed to parse config at ${configPath}: ${error.message}`);\n    37→    return DEFAULTS;\n    38→  }\n    39→}\n    40→\n    41→function deepMerge(target, source) {\n    42→  const result = { ...target };\n    43→  for (const key of Object.keys(source)) {\n    44→    if (\n    45→      source[key] &&\n    46→      typeof source[key] === \"object\" &&\n    47→      !Array.isArray(source[key]) &&\n    48→      target[key] &&\n    49→      typeof target[key] === \"object\" &&\n    50→      !Array.isArray(target[key])\n    51→    ) {\n    52→      result[key] = deepMerge(target[key], source[key]);\n    53→    } else {\n    54→      result[key] = source[key];\n    55→    }\n    56→  }\n    57→  return result;\n    58→}\n    59→\n    60→module.exports = { loadConfig };\n    61→"}]},"parent_tool_use_id":null,"session_id":"2a8b2ce2-e0c8-48b6-8ab6-0a0f1560652c","uuid":"b6f8a4bd-df3c-483b-a104-831d8f195a76","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/config.js","content":"const core = require(\"@actions/core\");\nconst fs = require(\"fs\");\nconst yaml = require(\"js-yaml\");\n\nconst DEFAULTS = {\n  protected_paths: [\".github/\", \".env\", \"CLAUDE.md\", \".kiln/\"],\n  human_review: {\n    spec: \"required\",\n    implementation: \"auto\",\n  },\n  auto_merge: true,\n  timeout_minutes: 30,\n  labels: {\n    prefix: \"kiln\",\n  },\n  agents: {\n    triage: { enabled: true },\n    spec: { enabled: true },\n    implement: { enabled: true, run_tests: true, run_lint: true },\n    review: { enabled: true, auto_approve: false },\n    fix: { enabled: true, max_iterations: 3 },\n  },\n};\n\nasync function loadConfig(configPath) {\n  if (!fs.existsSync(configPath)) {\n    core.info(`No config found at ${configPath}, using defaults.`);\n    return DEFAULTS;\n  }\n\n  try {\n    const raw = fs.readFileSync(configPath, \"utf-8\");\n    const userConfig = yaml.load(raw) || {};\n    return deepMerge(DEFAULTS, userConfig);\n  } catch (error) {\n    core.warning(`Failed to parse config at ${configPath}: ${error.message}`);\n    return DEFAULTS;\n  }\n}\n\nfunction deepMerge(target, source) {\n  const result = { ...target };\n  for (const key of Object.keys(source)) {\n    if (\n      source[key] &&\n      typeof source[key] === \"object\" &&\n      !Array.isArray(source[key]) &&\n      target[key] &&\n      typeof target[key] === \"object\" &&\n      !Array.isArray(target[key])\n    ) {\n      result[key] = deepMerge(target[key], source[key]);\n    } else {\n      result[key] = source[key];\n    }\n  }\n  return result;\n}\n\nmodule.exports = { loadConfig };\n","numLines":61,"startLine":1,"totalLines":61}}}
