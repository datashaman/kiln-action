r_enough\":true,\"comment\":\"Got it.\",\"labels\":[]}\\n```',\n   155→      );\n   156→      const ctx = makeCtx();\n   157→      const result = await triage(ctx);\n   158→      expect(result.status).toBe(\"success\");\n   159→    });\n   160→\n   161→    it(\"parses raw JSON without code block\", async () => {\n   162→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n   163→      const ctx = makeCtx();\n   164→      const result = await triage(ctx);\n   165→      expect(result.status).toBe(\"success\");\n   166→    });\n   167→\n   168→    it(\"falls back to defaults on parse failure\", async () => {\n   169→      mockedRunClaude.mockReturnValue(\"This is not JSON at all\");\n   170→      const ctx = makeCtx();\n   171→      const result = await triage(ctx);\n   172→\n   173→      expect(result.status).toBe(\"success\");\n   174→      expect(core.warning).toHaveBeenCalledWith(\n   175→        expect.stringContaining(\"Failed to parse triage response\"),\n   176→      );\n   177→      // Default: clear_enough=true → moves to specify\n   178→      expect(result.nextStage).toBe(\"specify\");\n   179→    });\n   180→\n   181→    it(\"logs raw output on parse failure\", async () => {\n   182→      mockedRunClaude.mockReturnValue(\"garbage output\");\n   183→      const ctx = makeCtx();\n   184→      await triage(ctx);\n   185→\n   186→      expect(core.warning).toHaveBeenCalledWith(\n   187→        expect.stringContaining(\"Raw output: garbage output\"),\n   188→      );\n   189→    });\n   190→  });\n   191→\n   192→  // ── AC: Applies type and size labels ──────────────────\n   193→  describe(\"applies labels\", () => {\n   194→    it(\"applies type:{type} and size:{complexity} labels\", async () => {\n   195→      mockedRunClaude.mockReturnValue(VALID_RESPONSE);\n   196→      const ctx = makeCtx();\n   197→      await triage(ctx);\n   198→\n   199→      expect(ctx.octokit.rest.issues.addLabels).toHaveBeenCalledWith(\n   200→        expect.objectContaining({\n 