{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cc2Hos8GfjuRvcvLU1yLbn","type":"tool_result","content":"     1→import * as fs from \"fs\";\n     2→\n     3→import specify from \"./specify\";\n     4→import { KilnContext, KilnConfig, Octokit } from \"../types\";\n     5→import { Context } from \"@actions/github/lib/context\";\n     6→\n     7→jest.mock(\"@actions/core\");\n     8→jest.mock(\"../claude\");\n     9→jest.mock(\"../labels\");\n    10→jest.mock(\"child_process\", () => ({\n    11→  execSync: jest.fn().mockReturnValue(\"\"),\n    12→}));\n    13→\n    14→import * as core from \"@actions/core\";\n    15→import { runClaudeEdit } from \"../claude\";\n    16→import { transitionLabel } from \"../labels\";\n    17→import { execSync } from \"child_process\";\n    18→\n    19→const mockedRunClaudeEdit = runClaudeEdit as unknown as jest.Mock;\n    20→const mockedTransitionLabel = transitionLabel as unknown as jest.Mock;\n    21→const mockedExecSync = execSync as unknown as jest.Mock;\n    22→\n    23→// Spy on fs functions to avoid breaking @actions/core which depends on fs.promises\n    24→let existsSyncSpy: jest.SpyInstance;\n    25→let mkdirSyncSpy: jest.SpyInstance;\n    26→let readFileSyncSpy: jest.SpyInstance;\n    27→\n    28→function makeOctokit(): Octokit {\n    29→  return {\n    30→    rest: {\n    31→      pulls: {\n    32→        create: jest.fn().mockResolvedValue({\n    33→          data: { number: 10 },\n    34→        }),\n    35→      },\n    36→      issues: {\n    37→        createComment: jest.fn().mockResolvedValue({}),\n    38→        addLabels: jest.fn().mockResolvedValue({}),\n    39→      },\n    40→    },\n    41→  } as unknown as Octokit;\n    42→}\n    43→\n    44→function makeConfig(\n    45→  overrides: Partial<KilnConfig> = {},\n    46→  prefix = \"kiln\",\n    47→): KilnConfig {\n    48→  return {\n    49→    labels: { prefix },\n    50→    ...overrides,\n    51→  } as unknown as KilnConfig;\n    52→}\n    53→\n    54→function makeContext(issuePayload: Record<string, unknown> = {}): Context {\n    55→  return {\n    56→    eventName: \"issues\",\n    57→    payload: {\n    58→      action: \"labeled\",\n    59→      issue: {\n    60→        number: 5,\n    61→        title: \"Add user authentication\",\n    62→        body: \"We need OAuth2 login support.\",\n    63→        labels: [{ name: \"kiln:specifying\" }],\n    64→        ...issuePayload,\n    65→      },\n    66→    },\n    67→    repo: { owner: \"test-owner\", repo: \"test-repo\" },\n    68→  } as unknown as Context;\n    69→}\n    70→\n    71→function makeCtx(overrides: Partial<KilnContext> = {}): KilnContext {\n    72→  return {\n    73→    octokit: makeOctokit(),\n    74→    context: makeContext(),\n    75→    config: makeConfig(),\n    76→    anthropicKey: \"sk-ant-test-key\",\n    77→    timeoutMinutes: 30,\n    78→    token: \"ghp-test-token\",\n    79→    ...overrides,\n    80→  };\n    81→}\n    82→\n    83→beforeEach(() => {\n    84→  jest.clearAllMocks();\n    85→  mockedTransitionLabel.mockResolvedValue(undefined);\n    86→  mockedRunClaudeEdit.mockReturnValue(\"Spec created successfully\");\n    87→  mockedExecSync.mockReturnValue(\"\");\n    88→\n    89→  existsSyncSpy = jest.spyOn(fs, \"existsSync\").mockImplementation((path) => {\n    90→    if (String(path) === \"specs/issue-5.md\") return true;\n    91→    return false;\n    92→  });\n    93→  mkdirSyncSpy = jest.spyOn(fs, \"mkdirSync\").mockReturnValue(undefined);\n    94→  readFileSyncSpy = jest.spyOn(fs, \"readFileSync\");\n    95→});\n    96→\n    97→afterEach(() => {\n    98→  existsSyncSpy.mockRestore();\n    99→  mkdirSyncSpy.mockRestore();\n   100→  readFileSyncSpy.mockRestore();\n   101→});\n   102→\n   103→describe(\"specify\", () => {\n   104→  // ── AC: Triggers when issue receives kiln:specifying label ──\n   105→  describe(\"triggers on kiln:specifying label\", () => {\n   106→    it(\"processes an issue with kiln:specifying label\", async () => {\n   107→      const ctx = makeCtx();\n   108→      const result = await specify(ctx);\n   109→      expect(result.status).toBe(\"success\");\n   110→    });\n   111→\n   112→    it(\"logs the issue number and title\", async () => {\n   113→      const ctx = makeCtx();\n   114→      await specify(ctx);\n   115→      expect(core.info).toHaveBeenCalledWith(\n   116→        expect.stringContaining(\"Issue #5: Add user authentication\"),\n   117→      );\n   118→    });\n   119→  });\n   120→\n   121→  // ── AC: Checks out the repo and sends issue context to Claude ──\n   122→  describe(\"checks out repo and invokes Claude\", () => {\n   123→    it(\"creates a spec branch kiln/spec/issue-{number}\", async () => {\n   124→      const ctx = makeCtx();\n   125→      await specify(ctx);\n   126→\n   127→      expect(mockedExecSync).toHaveBeenCalledWith(\n   128→        \"git checkout -b kiln/spec/issue-5\",\n   129→      );\n   130→    });\n   131→\n   132→    it(\"configures git user before branching\", async () => {\n   133→      const ctx = makeCtx();\n   134→      await specify(ctx);\n   135→\n   136→      const calls = mockedExecSync.mock.calls.map(\n   137→        (c: unknown[]) => c[0] as string,\n   138→      );\n   139→      const configNameIdx = calls.findIndex((c: string) =>\n   140→        c.includes(\"git config user.name\"),\n   141→      );\n   142→      const configEmailIdx = calls.findIndex((c: string) =>\n   143→        c.includes(\"git config user.email\"),\n   144→      );\n   145→      const checkoutIdx = calls.findIndex((c: string) =>\n   146→        c.includes(\"git checkout\"),\n   147→      );\n   148→\n   149→      expect(configNameIdx).toBeLessThan(checkoutIdx);\n   150→      expect(configEmailIdx).toBeLessThan(checkoutIdx);\n   151→    });\n   152→\n   153→    it(\"creates specs directory\", async () => {\n   154→      const ctx = makeCtx();\n   155→      await specify(ctx);\n   156→\n   157→      expect(mkdirSyncSpy).toHaveBeenCalledWith(\"specs\", { recursive: true });\n   158→    });\n   159→\n   160→    it(\"sends issue title and body to Claude via runClaudeEdit\", async () => {\n   161→      const ctx = makeCtx();\n   162→      await specify(ctx);\n   163→\n   164→      expect(mockedRunClaudeEdit).toHaveBeenCalledWith(\n   165→        expect.stringContaining(\"Add user authentication\"),\n   166→        expect.objectContaining({\n   167→          anthropicKey: \"sk-ant-test-key\",\n   168→          timeoutMinutes: 30,\n   169→        }),\n   170→      );\n   171→\n   172→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   173→      expect(prompt).toContain(\"We need OAuth2 login support.\");\n   174→    });\n   175→\n   176→    it(\"includes issue number in the prompt\", async () => {\n   177→      const ctx = makeCtx();\n   178→      await specify(ctx);\n   179→\n   180→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   181→      expect(prompt).toContain(\"Issue #5\");\n   182→    });\n   183→\n   184→    it(\"handles empty issue body\", async () => {\n   185→      existsSyncSpy.mockImplementation((path: unknown) => {\n   186→        if (String(path) === \"specs/issue-7.md\") return true;\n   187→        return false;\n   188→      });\n   189→      const ctx = makeCtx({\n   190→        context: makeContext({ number: 7, title: \"Bug\", body: null }),\n   191→      });\n   192→      await specify(ctx);\n   193→\n   194→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   195→      expect(prompt).toContain(\"(empty)\");\n   196→    });\n   197→\n   198→    it(\"invokes Claude in edit mode (not read-only)\", async () => {\n   199→      const ctx = makeCtx();\n   200→      await specify(ctx);\n   201→\n   202→      expect(mockedRunClaudeEdit).toHaveBeenCalled();\n   203→    });\n   204→  });\n   205→\n   206→  // ── AC: Claude creates spec file with required sections ──\n   207→  describe(\"spec file creation\", () => {\n   208→    it(\"instructs Claude to create spec at specs/issue-{number}.md\", async () => {\n   209→      const ctx = makeCtx();\n   210→      await specify(ctx);\n   211→\n   212→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   213→      expect(prompt).toContain(\"specs/issue-5.md\");\n   214→    });\n   215→\n   216→    it(\"includes spec template with all required sections in prompt\", async () => {\n   217→      const ctx = makeCtx();\n   218→      await specify(ctx);\n   219→\n   220→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   221→      expect(prompt).toContain(\"Overview\");\n   222→      expect(prompt).toContain(\"Requirements\");\n   223→      expect(prompt).toContain(\"Technical Design\");\n   224→      expect(prompt).toContain(\"Test Plan\");\n   225→      expect(prompt).toContain(\"Out of Scope\");\n   226→      expect(prompt).toContain(\"Implementation Notes\");\n   227→    });\n   228→\n   229→    it(\"verifies spec file was created after Claude runs\", async () => {\n   230→      const ctx = makeCtx();\n   231→      await specify(ctx);\n   232→\n   233→      expect(existsSyncSpy).toHaveBeenCalledWith(\"specs/issue-5.md\");\n   234→    });\n   235→\n   236→    it(\"fails if spec file was not created\", async () => {\n   237→      existsSyncSpy.mockReturnValue(false);\n   238→      const ctx = makeCtx();\n   239→      const result = await specify(ctx);\n   240→\n   241→      expect(result.status).toBe(\"error\");\n   242→      expect(core.setFailed).toHaveBeenCalledWith(\n   243→        \"Spec agent did not create specs/issue-5.md\",\n   244→      );\n   245→    });\n   246→  });\n   247→\n   248→  // ── AC: Custom spec template ──\n   249→  describe(\"custom spec template\", () => {\n   250→    it(\"uses custom spec template from config.spec_template\", async () => {\n   251→      existsSyncSpy.mockImplementation((path: unknown) => {\n   252→        if (String(path) === \"custom-template.md\") return true;\n   253→        if (String(path) === \"specs/issue-5.md\") return true;\n   254→        return false;\n   255→      });\n   256→      readFileSyncSpy.mockReturnValue(\"# Custom Template\\n## My Section\");\n   257→\n   258→      const ctx = makeCtx({\n   259→        config: makeConfig({ spec_template: \"custom-template.md\" }),\n   260→      });\n   261→      await specify(ctx);\n   262→\n   263→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   264→      expect(prompt).toContain(\"# Custom Template\");\n   265→      expect(prompt).toContain(\"## My Section\");\n   266→    });\n   267→\n   268→    it(\"uses custom spec template from config.agents.spec.template\", async () => {\n   269→      existsSyncSpy.mockImplementation((path: unknown) => {\n   270→        if (String(path) === \"agent-template.md\") return true;\n   271→        if (String(path) === \"specs/issue-5.md\") return true;\n   272→        return false;\n   273→      });\n   274→      readFileSyncSpy.mockReturnValue(\"# Agent Template\");\n   275→\n   276→      const ctx = makeCtx({\n   277→        config: makeConfig({\n   278→          agents: {\n   279→            spec: { enabled: true, template: \"agent-template.md\" },\n   280→          } as KilnConfig[\"agents\"],\n   281→        }),\n   282→      });\n   283→      await specify(ctx);\n   284→\n   285→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   286→      expect(prompt).toContain(\"# Agent Template\");\n   287→    });\n   288→\n   289→    it(\"falls back to default template when custom path does not exist\", async () => {\n   290→      existsSyncSpy.mockImplementation((path: unknown) => {\n   291→        if (String(path) === \"nonexistent.md\") return false;\n   292→        if (String(path) === \"specs/issue-5.md\") return true;\n   293→        return false;\n   294→      });\n   295→\n   296→      const ctx = makeCtx({\n   297→        config: makeConfig({ spec_template: \"nonexistent.md\" }),\n   298→      });\n   299→      await specify(ctx);\n   300→\n   301→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   302→      expect(prompt).toContain(\"Overview\");\n   303→      expect(prompt).toContain(\"Requirements\");\n   304→    });\n   305→  });\n   306→\n   307→  // ── AC: Claude commits spec to branch and pushes ──\n   308→  describe(\"commits and pushes spec branch\", () => {\n   309→    it(\"commits the spec file\", async () => {\n   310→      const ctx = makeCtx();\n   311→      await specify(ctx);\n   312→\n   313→      const calls = mockedExecSync.mock.calls.map(\n   314→        (c: unknown[]) => c[0] as string,\n   315→      );\n   316→      const commitCall = calls.find((c: string) => c.includes(\"git commit\"));\n   317→      expect(commitCall).toBeDefined();\n   318→      expect(commitCall).toContain(\"docs: add spec for issue #5\");\n   319→    });\n   320→\n   321→    it(\"pushes the branch to origin\", async () => {\n   322→      const ctx = makeCtx();\n   323→      await specify(ctx);\n   324→\n   325→      expect(mockedExecSync).toHaveBeenCalledWith(\n   326→        \"git push origin kiln/spec/issue-5 --force\",\n   327→      );\n   328→    });\n   329→\n   330→    it(\"handles already-committed case gracefully\", async () => {\n   331→      mockedExecSync.mockImplementation((cmd: string) => {\n   332→        if (\n   333→          typeof cmd === \"string\" &&\n   334→          (cmd.includes(\"git add\") || cmd.includes(\"git commit\"))\n   335→        ) {\n   336→          throw new Error(\"nothing to commit\");\n   337→        }\n   338→        return \"\";\n   339→      });\n   340→\n   341→      const ctx = makeCtx();\n   342→      const result = await specify(ctx);\n   343→      expect(result.status).toBe(\"success\");\n   344→    });\n   345→  });\n   346→\n   347→  // ── AC: Opens PR titled \"📋 Kiln Spec: {issue title}\" ──\n   348→  describe(\"creates spec PR\", () => {\n   349→    it('opens PR titled \"📋 Kiln Spec: {issue title}\"', async () => {\n   350→      const ctx = makeCtx();\n   351→      await specify(ctx);\n   352→\n   353→      expect(ctx.octokit.rest.pulls.create).toHaveBeenCalledWith(\n   354→        expect.objectContaining({\n   355→          owner: \"test-owner\",\n   356→          repo: \"test-repo\",\n   357→          title: \"📋 Kiln Spec: Add user authentication\",\n   358→          head: \"kiln/spec/issue-5\",\n   359→          base: \"main\",\n   360→        }),\n   361→      );\n   362→    });\n   363→\n   364→    it(\"PR body references the issue number\", async () => {\n   365→      const ctx = makeCtx();\n   366→      await specify(ctx);\n   367→\n   368→      expect(ctx.octokit.rest.pulls.create).toHaveBeenCalledWith(\n   369→        expect.objectContaining({\n   370→          body: expect.stringContaining(\"#5\"),\n   371→        }),\n   372→      );\n   373→    });\n   374→\n   375→    it(\"PR body includes review instructions\", async () => {\n   376→      const ctx = makeCtx();\n   377→      await specify(ctx);\n   378→\n   379→      expect(ctx.octokit.rest.pulls.create).toHaveBeenCalledWith(\n   380→        expect.objectContaining({\n   381→          body: expect.stringContaining(\n   382→            \"Approve this PR to trigger implementation\",\n   383→          ),\n   384→        }),\n   385→      );\n   386→    });\n   387→\n   388→    it(\"returns the PR number\", async () => {\n   389→      const ctx = makeCtx();\n   390→      const result = await specify(ctx);\n   391→\n   392→      expect(result.prNumber).toBe(10);\n   393→    });\n   394→  });\n   395→\n   396→  // ── AC: PR is labeled with kiln:spec and needs-human-review ──\n   397→  describe(\"PR labels\", () => {\n   398→    it(\"labels PR with kiln:spec and needs-human-review\", async () => {\n   399→      const ctx = makeCtx();\n   400→      await specify(ctx);\n   401→\n   402→      expect(ctx.octokit.rest.issues.addLabels).toHaveBeenCalledWith(\n   403→        expect.objectContaining({\n   404→          owner: \"test-owner\",\n   405→          repo: \"test-repo\",\n   406→          issue_number: 10,\n   407→          labels: [\"kiln:spec\", \"needs-human-review\"],\n   408→        }),\n   409→      );\n   410→    });\n   411→\n   412→    it(\"uses custom label prefix for spec label\", async () => {\n   413→      const ctx = makeCtx({ config: makeConfig({}, \"myapp\") });\n   414→      await specify(ctx);\n   415→\n   416→      expect(ctx.octokit.rest.issues.addLabels).toHaveBeenCalledWith(\n   417→        expect.objectContaining({\n   418→          labels: [\"myapp:spec\", \"needs-human-review\"],\n   419→        }),\n   420→      );\n   421→    });\n   422→  });\n   423→\n   424→  // ── AC: Issue updated: kiln:specifying removed, kiln:spec-review added ──\n   425→  describe(\"issue label transition\", () => {\n   426→    it(\"transitions issue from specifying to spec-review\", async () => {\n   427→      const ctx = makeCtx();\n   428→      await specify(ctx);\n   429→\n   430→      expect(mockedTransitionLabel).toHaveBeenCalledWith(\n   431→        ctx.octokit,\n   432→        ctx.context,\n   433→        5,\n   434→        \"specifying\",\n   435→        \"spec-review\",\n   436→        \"kiln\",\n   437→      );\n   438→    });\n   439→\n   440→    it(\"uses custom label prefix for transition\", async () => {\n   441→      const ctx = makeCtx({ config: makeConfig({}, \"myapp\") });\n   442→      await specify(ctx);\n   443→\n   444→      expect(mockedTransitionLabel).toHaveBeenCalledWith(\n   445→        expect.anything(),\n   446→        expect.anything(),\n   447→        5,\n   448→        \"specifying\",\n   449→        \"spec-review\",\n   450→        \"myapp\",\n   451→      );\n   452→    });\n   453→  });\n   454→\n   455→  // ── AC: Comment posted on issue linking to spec PR ──\n   456→  describe(\"issue comment\", () => {\n   457→    it(\"posts comment on issue linking to spec PR\", async () => {\n   458→      const ctx = makeCtx();\n   459→      await specify(ctx);\n   460→\n   461→      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n   462→        expect.objectContaining({\n   463→          owner: \"test-owner\",\n   464→          repo: \"test-repo\",\n   465→          issue_number: 5,\n   466→          body: expect.stringContaining(\"#10\"),\n   467→        }),\n   468→      );\n   469→    });\n   470→\n   471→    it(\"comment is Kiln-branded\", async () => {\n   472→      const ctx = makeCtx();\n   473→      await specify(ctx);\n   474→\n   475→      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n   476→        expect.objectContaining({\n   477→          body: expect.stringContaining(\"**Kiln**\"),\n   478→        }),\n   479→      );\n   480→    });\n   481→\n   482→    it(\"comment mentions spec review\", async () => {\n   483→      const ctx = makeCtx();\n   484→      await specify(ctx);\n   485→\n   486→      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n   487→        expect.objectContaining({\n   488→          body: expect.stringContaining(\"review\"),\n   489→        }),\n   490→      );\n   491→    });\n   492→  });\n   493→\n   494→  // ── Edge cases ──\n   495→  describe(\"edge cases\", () => {\n   496→    it(\"handles different issue numbers correctly\", async () => {\n   497→      existsSyncSpy.mockImplementation((path: unknown) => {\n   498→        if (String(path) === \"specs/issue-42.md\") return true;\n   499→        return false;\n   500→      });\n   501→      const ctx = makeCtx({\n   502→        context: makeContext({\n   503→          number: 42,\n   504→          title: \"Fix login bug\",\n   505→          body: \"Login is broken.\",\n   506→        }),\n   507→      });\n   508→      await specify(ctx);\n   509→\n   510→      expect(mockedExecSync).toHaveBeenCalledWith(\n   511→        \"git checkout -b kiln/spec/issue-42\",\n   512→      );\n   513→      expect(ctx.octokit.rest.pulls.create).toHaveBeenCalledWith(\n   514→        expect.objectContaining({\n   515→          title: \"📋 Kiln Spec: Fix login bug\",\n   516→          head: \"kiln/spec/issue-42\",\n   517→        }),\n   518→      );\n   519→    });\n   520→\n   521→    it(\"instructs Claude to commit and push\", async () => {\n   522→      const ctx = makeCtx();\n   523→      await specify(ctx);\n   524→\n   525→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   526→      expect(prompt).toContain(\"commit\");\n   527→      expect(prompt).toContain(\"push\");\n   528→    });\n   529→\n   530→    it(\"passes correct anthropicKey and timeout to runClaudeEdit\", async () => {\n   531→      const ctx = makeCtx({\n   532→        anthropicKey: \"sk-ant-custom\",\n   533→        timeoutMinutes: 15,\n   534→      });\n   535→      await specify(ctx);\n   536→\n   537→      expect(mockedRunClaudeEdit).toHaveBeenCalledWith(expect.any(String), {\n   538→        anthropicKey: \"sk-ant-custom\",\n   539→        timeoutMinutes: 15,\n   540→      });\n   541→    });\n   542→\n   543→    it(\"returns success status when everything works\", async () => {\n   544→      const ctx = makeCtx();\n   545→      const result = await specify(ctx);\n   546→\n   547→      expect(result.status).toBe(\"success\");\n   548→    });\n   549→  });\n   550→});\n   551→"}]},"parent_tool_use_id":null,"session_id":"9f060dfe-dd73-41ed-8761-620bfcb4f31f","uuid":"f232e5b7-e97a-4b75-a031-85fe4904a201","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/specify.test.ts","content":"import * as fs from \"fs\";\n\nimport specify from \"./specify\";\nimport { KilnContext, KilnConfig, Octokit } from \"../types\";\nimport { Context } from \"@actions/github/lib/context\";\n\njest.mock(\"@actions/core\");\njest.mock(\"../claude\");\njest.mock(\"../labels\");\njest.mock(\"child_process\", () => ({\n  execSync: jest.fn().mockReturnValue(\"\"),\n}));\n\nimport * as core from \"@actions/core\";\nimport { runClaudeEdit } from \"../claude\";\nimport { transitionLabel } from \"../labels\";\nimport { execSync } from \"child_process\";\n\nconst mockedRunClaudeEdit = runClaudeEdit as unknown as jest.Mock;\nconst mockedTransitionLabel = transitionLabel as unknown as jest.Mock;\nconst mockedExecSync = execSync as unknown as jest.Mock;\n\n// Spy on fs functions to avoid breaking @actions/core which depends on fs.promises\nlet existsSyncSpy: jest.SpyInstance;\nlet mkdirSyncSpy: jest.SpyInstance;\nlet readFileSyncSpy: jest.SpyInstance;\n\nfunction makeOctokit(): Octokit {\n  return {\n    rest: {\n      pulls: {\n        create: jest.fn().mockResolvedValue({\n          data: { number: 10 },\n        }),\n      },\n      issues: {\n        createComment: jest.fn().mockResolvedValue({}),\n        addLabels: jest.fn().mockResolvedValue({}),\n      },\n    },\n  } as unknown as Octokit;\n}\n\nfunction makeConfig(\n  overrides: Partial<KilnConfig> = {},\n  prefix = \"kiln\",\n): KilnConfig {\n  return {\n    labels: { prefix },\n    ...overrides,\n  } as unknown as KilnConfig;\n}\n\nfunction makeContext(issuePayload: Record<string, unknown> = {}): Context {\n  return {\n    eventName: \"issues\",\n    payload: {\n      action: \"labeled\",\n      issue: {\n        number: 5,\n        title: \"Add user authentication\",\n        body: \"We need OAuth2 login support.\",\n        labels: [{ name: \"kiln:specifying\" }],\n        ...issuePayload,\n      },\n    },\n    repo: { owner: \"test-owner\", repo: \"test-repo\" },\n  } as unknown as Context;\n}\n\nfunction makeCtx(overrides: Partial<KilnContext> = {}): KilnContext {\n  return {\n    octokit: makeOctokit(),\n    context: makeContext(),\n    config: makeConfig(),\n    anthropicKey: \"sk-ant-test-key\",\n    timeoutMinutes: 30,\n    token: \"ghp-test-token\",\n    ...overrides,\n  };\n}\n\nbeforeEach(() => {\n  jest.clearAllMocks();\n  mockedTransitionLabel.mockResolvedValue(undefined);\n  mockedRunClaudeEdit.mockReturnValue(\"Spec created successfully\");\n  mockedExecSync.mockReturnValue(\"\");\n\n  existsSyncSpy = jest.spyOn(fs, \"existsSync\").mockImplementation((path) => {\n    if (String(path) === \"specs/issue-5.md\") return true;\n    return false;\n  });\n  mkdirSyncSpy = jest.spyOn(fs, \"mkdirSync\").mockReturnValue(undefined);\n  readFileSyncSpy = jest.spyOn(fs, \"readFileSync\");\n});\n\nafterEach(() => {\n  existsSyncSpy.mockRestore();\n  mkdirSyncSpy.mockRestore();\n  readFileSyncSpy.mockRestore();\n});\n\ndescribe(\"specify\", () => {\n  // ── AC: Triggers when issue receives kiln:specifying label ──\n  describe(\"triggers on kiln:specifying label\", () => {\n    it(\"processes an issue with kiln:specifying label\", async () => {\n      const ctx = makeCtx();\n      const result = await specify(ctx);\n      expect(result.status).toBe(\"success\");\n    });\n\n    it(\"logs the issue number and title\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n      expect(core.info).toHaveBeenCalledWith(\n        expect.stringContaining(\"Issue #5: Add user authentication\"),\n      );\n    });\n  });\n\n  // ── AC: Checks out the repo and sends issue context to Claude ──\n  describe(\"checks out repo and invokes Claude\", () => {\n    it(\"creates a spec branch kiln/spec/issue-{number}\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(mockedExecSync).toHaveBeenCalledWith(\n        \"git checkout -b kiln/spec/issue-5\",\n      );\n    });\n\n    it(\"configures git user before branching\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      const calls = mockedExecSync.mock.calls.map(\n        (c: unknown[]) => c[0] as string,\n      );\n      const configNameIdx = calls.findIndex((c: string) =>\n        c.includes(\"git config user.name\"),\n      );\n      const configEmailIdx = calls.findIndex((c: string) =>\n        c.includes(\"git config user.email\"),\n      );\n      const checkoutIdx = calls.findIndex((c: string) =>\n        c.includes(\"git checkout\"),\n      );\n\n      expect(configNameIdx).toBeLessThan(checkoutIdx);\n      expect(configEmailIdx).toBeLessThan(checkoutIdx);\n    });\n\n    it(\"creates specs directory\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(mkdirSyncSpy).toHaveBeenCalledWith(\"specs\", { recursive: true });\n    });\n\n    it(\"sends issue title and body to Claude via runClaudeEdit\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(mockedRunClaudeEdit).toHaveBeenCalledWith(\n        expect.stringContaining(\"Add user authentication\"),\n        expect.objectContaining({\n          anthropicKey: \"sk-ant-test-key\",\n          timeoutMinutes: 30,\n        }),\n      );\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"We need OAuth2 login support.\");\n    });\n\n    it(\"includes issue number in the prompt\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"Issue #5\");\n    });\n\n    it(\"handles empty issue body\", async () => {\n      existsSyncSpy.mockImplementation((path: unknown) => {\n        if (String(path) === \"specs/issue-7.md\") return true;\n        return false;\n      });\n      const ctx = makeCtx({\n        context: makeContext({ number: 7, title: \"Bug\", body: null }),\n      });\n      await specify(ctx);\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"(empty)\");\n    });\n\n    it(\"invokes Claude in edit mode (not read-only)\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(mockedRunClaudeEdit).toHaveBeenCalled();\n    });\n  });\n\n  // ── AC: Claude creates spec file with required sections ──\n  describe(\"spec file creation\", () => {\n    it(\"instructs Claude to create spec at specs/issue-{number}.md\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"specs/issue-5.md\");\n    });\n\n    it(\"includes spec template with all required sections in prompt\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"Overview\");\n      expect(prompt).toContain(\"Requirements\");\n      expect(prompt).toContain(\"Technical Design\");\n      expect(prompt).toContain(\"Test Plan\");\n      expect(prompt).toContain(\"Out of Scope\");\n      expect(prompt).toContain(\"Implementation Notes\");\n    });\n\n    it(\"verifies spec file was created after Claude runs\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(existsSyncSpy).toHaveBeenCalledWith(\"specs/issue-5.md\");\n    });\n\n    it(\"fails if spec file was not created\", async () => {\n      existsSyncSpy.mockReturnValue(false);\n      const ctx = makeCtx();\n      const result = await specify(ctx);\n\n      expect(result.status).toBe(\"error\");\n      expect(core.setFailed).toHaveBeenCalledWith(\n        \"Spec agent did not create specs/issue-5.md\",\n      );\n    });\n  });\n\n  // ── AC: Custom spec template ──\n  describe(\"custom spec template\", () => {\n    it(\"uses custom spec template from config.spec_template\", async () => {\n      existsSyncSpy.mockImplementation((path: unknown) => {\n        if (String(path) === \"custom-template.md\") return true;\n        if (String(path) === \"specs/issue-5.md\") return true;\n        return false;\n      });\n      readFileSyncSpy.mockReturnValue(\"# Custom Template\\n## My Section\");\n\n      const ctx = makeCtx({\n        config: makeConfig({ spec_template: \"custom-template.md\" }),\n      });\n      await specify(ctx);\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"# Custom Template\");\n      expect(prompt).toContain(\"## My Section\");\n    });\n\n    it(\"uses custom spec template from config.agents.spec.template\", async () => {\n      existsSyncSpy.mockImplementation((path: unknown) => {\n        if (String(path) === \"agent-template.md\") return true;\n        if (String(path) === \"specs/issue-5.md\") return true;\n        return false;\n      });\n      readFileSyncSpy.mockReturnValue(\"# Agent Template\");\n\n      const ctx = makeCtx({\n        config: makeConfig({\n          agents: {\n            spec: { enabled: true, template: \"agent-template.md\" },\n          } as KilnConfig[\"agents\"],\n        }),\n      });\n      await specify(ctx);\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"# Agent Template\");\n    });\n\n    it(\"falls back to default template when custom path does not exist\", async () => {\n      existsSyncSpy.mockImplementation((path: unknown) => {\n        if (String(path) === \"nonexistent.md\") return false;\n        if (String(path) === \"specs/issue-5.md\") return true;\n        return false;\n      });\n\n      const ctx = makeCtx({\n        config: makeConfig({ spec_template: \"nonexistent.md\" }),\n      });\n      await specify(ctx);\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"Overview\");\n      expect(prompt).toContain(\"Requirements\");\n    });\n  });\n\n  // ── AC: Claude commits spec to branch and pushes ──\n  describe(\"commits and pushes spec branch\", () => {\n    it(\"commits the spec file\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      const calls = mockedExecSync.mock.calls.map(\n        (c: unknown[]) => c[0] as string,\n      );\n      const commitCall = calls.find((c: string) => c.includes(\"git commit\"));\n      expect(commitCall).toBeDefined();\n      expect(commitCall).toContain(\"docs: add spec for issue #5\");\n    });\n\n    it(\"pushes the branch to origin\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(mockedExecSync).toHaveBeenCalledWith(\n        \"git push origin kiln/spec/issue-5 --force\",\n      );\n    });\n\n    it(\"handles already-committed case gracefully\", async () => {\n      mockedExecSync.mockImplementation((cmd: string) => {\n        if (\n          typeof cmd === \"string\" &&\n          (cmd.includes(\"git add\") || cmd.includes(\"git commit\"))\n        ) {\n          throw new Error(\"nothing to commit\");\n        }\n        return \"\";\n      });\n\n      const ctx = makeCtx();\n      const result = await specify(ctx);\n      expect(result.status).toBe(\"success\");\n    });\n  });\n\n  // ── AC: Opens PR titled \"📋 Kiln Spec: {issue title}\" ──\n  describe(\"creates spec PR\", () => {\n    it('opens PR titled \"📋 Kiln Spec: {issue title}\"', async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(ctx.octokit.rest.pulls.create).toHaveBeenCalledWith(\n        expect.objectContaining({\n          owner: \"test-owner\",\n          repo: \"test-repo\",\n          title: \"📋 Kiln Spec: Add user authentication\",\n          head: \"kiln/spec/issue-5\",\n          base: \"main\",\n        }),\n      );\n    });\n\n    it(\"PR body references the issue number\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(ctx.octokit.rest.pulls.create).toHaveBeenCalledWith(\n        expect.objectContaining({\n          body: expect.stringContaining(\"#5\"),\n        }),\n      );\n    });\n\n    it(\"PR body includes review instructions\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(ctx.octokit.rest.pulls.create).toHaveBeenCalledWith(\n        expect.objectContaining({\n          body: expect.stringContaining(\n            \"Approve this PR to trigger implementation\",\n          ),\n        }),\n      );\n    });\n\n    it(\"returns the PR number\", async () => {\n      const ctx = makeCtx();\n      const result = await specify(ctx);\n\n      expect(result.prNumber).toBe(10);\n    });\n  });\n\n  // ── AC: PR is labeled with kiln:spec and needs-human-review ──\n  describe(\"PR labels\", () => {\n    it(\"labels PR with kiln:spec and needs-human-review\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(ctx.octokit.rest.issues.addLabels).toHaveBeenCalledWith(\n        expect.objectContaining({\n          owner: \"test-owner\",\n          repo: \"test-repo\",\n          issue_number: 10,\n          labels: [\"kiln:spec\", \"needs-human-review\"],\n        }),\n      );\n    });\n\n    it(\"uses custom label prefix for spec label\", async () => {\n      const ctx = makeCtx({ config: makeConfig({}, \"myapp\") });\n      await specify(ctx);\n\n      expect(ctx.octokit.rest.issues.addLabels).toHaveBeenCalledWith(\n        expect.objectContaining({\n          labels: [\"myapp:spec\", \"needs-human-review\"],\n        }),\n      );\n    });\n  });\n\n  // ── AC: Issue updated: kiln:specifying removed, kiln:spec-review added ──\n  describe(\"issue label transition\", () => {\n    it(\"transitions issue from specifying to spec-review\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(mockedTransitionLabel).toHaveBeenCalledWith(\n        ctx.octokit,\n        ctx.context,\n        5,\n        \"specifying\",\n        \"spec-review\",\n        \"kiln\",\n      );\n    });\n\n    it(\"uses custom label prefix for transition\", async () => {\n      const ctx = makeCtx({ config: makeConfig({}, \"myapp\") });\n      await specify(ctx);\n\n      expect(mockedTransitionLabel).toHaveBeenCalledWith(\n        expect.anything(),\n        expect.anything(),\n        5,\n        \"specifying\",\n        \"spec-review\",\n        \"myapp\",\n      );\n    });\n  });\n\n  // ── AC: Comment posted on issue linking to spec PR ──\n  describe(\"issue comment\", () => {\n    it(\"posts comment on issue linking to spec PR\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n        expect.objectContaining({\n          owner: \"test-owner\",\n          repo: \"test-repo\",\n          issue_number: 5,\n          body: expect.stringContaining(\"#10\"),\n        }),\n      );\n    });\n\n    it(\"comment is Kiln-branded\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n        expect.objectContaining({\n          body: expect.stringContaining(\"**Kiln**\"),\n        }),\n      );\n    });\n\n    it(\"comment mentions spec review\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n        expect.objectContaining({\n          body: expect.stringContaining(\"review\"),\n        }),\n      );\n    });\n  });\n\n  // ── Edge cases ──\n  describe(\"edge cases\", () => {\n    it(\"handles different issue numbers correctly\", async () => {\n      existsSyncSpy.mockImplementation((path: unknown) => {\n        if (String(path) === \"specs/issue-42.md\") return true;\n        return false;\n      });\n      const ctx = makeCtx({\n        context: makeContext({\n          number: 42,\n          title: \"Fix login bug\",\n          body: \"Login is broken.\",\n        }),\n      });\n      await specify(ctx);\n\n      expect(mockedExecSync).toHaveBeenCalledWith(\n        \"git checkout -b kiln/spec/issue-42\",\n      );\n      expect(ctx.octokit.rest.pulls.create).toHaveBeenCalledWith(\n        expect.objectContaining({\n          title: \"📋 Kiln Spec: Fix login bug\",\n          head: \"kiln/spec/issue-42\",\n        }),\n      );\n    });\n\n    it(\"instructs Claude to commit and push\", async () => {\n      const ctx = makeCtx();\n      await specify(ctx);\n\n      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"commit\");\n      expect(prompt).toContain(\"push\");\n    });\n\n    it(\"passes correct anthropicKey and timeout to runClaudeEdit\", async () => {\n      const ctx = makeCtx({\n        anthropicKey: \"sk-ant-custom\",\n        timeoutMinutes: 15,\n      });\n      await specify(ctx);\n\n      expect(mockedRunClaudeEdit).toHaveBeenCalledWith(expect.any(String), {\n        anthropicKey: \"sk-ant-custom\",\n        timeoutMinutes: 15,\n      });\n    });\n\n    it(\"returns success status when everything works\", async () => {\n      const ctx = makeCtx();\n      const result = await specify(ctx);\n\n      expect(result.status).toBe(\"success\");\n    });\n  });\n});\n","numLines":551,"startLine":1,"totalLines":551}}}
