{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013WZKeNdFwmeY7BS2w518XT","type":"tool_result","content":"     1→import { Context } from \"@actions/github/lib/context\";\n     2→\n     3→/**\n     4→ * Detects which Kiln stage to run based on the GitHub event.\n     5→ *\n     6→ * Event → Stage mapping:\n     7→ *\n     8→ *   issues.opened                                        → triage\n     9→ *   issues.labeled  (kiln:specifying)                    → specify\n    10→ *   pull_request_review.submitted (approved + spec PR)   → approve-spec\n    11→ *   issues.labeled  (kiln:implementing)                  → implement\n    12→ *   pull_request.opened (impl PR)                        → review\n    13→ *   pull_request_review.submitted (changes_requested)    → fix\n    14→ *   pull_request_review.submitted (approved + impl PR)   → ship\n    15→ *   check_suite.completed (impl PR, all green)           → ship\n    16→ */\n    17→export function detectStage(context: Context): string | null {\n    18→  const { eventName, payload } = context;\n    19→\n    20→  // ── Issue Events ──────────────────────────────────────\n    21→  if (eventName === \"issues\") {\n    22→    // New issue opened → triage\n    23→    if (payload.action === \"opened\") {\n    24→      return \"triage\";\n    25→    }\n    26→\n    27→    // Labeled events — check which label was just added\n    28→    if (payload.action === \"labeled\") {\n    29→      const added = payload.label?.name as string | undefined;\n    30→\n    31→      if (added?.endsWith(\":specifying\")) return \"specify\";\n    32→      if (added?.endsWith(\":implementing\")) return \"implement\";\n    33→    }\n    34→  }\n    35→\n    36→  // ── Issue Comment Events ──────────────────────────────\n    37→  if (eventName === \"issue_comment\") {\n    38→    if (payload.action === \"created\") {\n    39→      const labels =\n    40→        (payload.issue?.labels as Array<{ name: string }>) || [];\n    41→      const labelNames = labels.map((l) => l.name);\n    42→      if (\n    43→        labelNames.some(\n    44→          (n) => n.endsWith(\":intake\") || n.endsWith(\":needs-info\"),\n    45→        )\n    46→      ) {\n    47→        return \"triage\";\n    48→      }\n    49→    }\n    50→  }\n    51→\n    52→  // ── Pull Request Events ───────────────────────────────\n    53→  if (eventName === \"pull_request\") {\n    54→    const labels =\n    55→      (payload.pull_request?.labels as Array<{ name: string }>) || [];\n    56→    const labelNames = labels.map((l) => l.name);\n    57→\n    58→    // Impl PR opened or updated → review\n    59→    if (\n    60→      (payload.action === \"opened\" || payload.action === \"synchronize\") &&\n    61→      labelNames.some((l) => l.endsWith(\":implementation\"))\n    62→    ) {\n    63→      return \"review\";\n    64→    }\n    65→  }\n    66→\n    67→  // ── PR Review Events ──────────────────────────────────\n    68→  if (eventName === \"pull_request_review\") {\n    69→    const labels =\n    70→      (payload.pull_request?.labels as Array<{ name: string }>) || [];\n    71→    const labelNames = labels.map((l) => l.name);\n    72→    const state = payload.review?.state as string | undefined;\n    73→\n    74→    // Spec PR approved → approve-spec (triggers implementation)\n    75→    if (state === \"approved\" && labelNames.some((l) => l.endsWith(\":spec\"))) {\n    76→      return \"approve-spec\";\n    77→    }\n    78→\n    79→    // Impl PR: changes requested → fix\n    80→    if (\n    81→      state === \"changes_requested\" &&\n    82→      labelNames.some((l) => l.endsWith(\":implementation\"))\n    83→    ) {\n    84→      return \"fix\";\n    85→    }\n    86→\n    87→    // Impl PR: approved → ship\n    88→    if (\n    89→      state === \"approved\" &&\n    90→      labelNames.some((l) => l.endsWith(\":implementation\"))\n    91→    ) {\n    92→      return \"ship\";\n    93→    }\n    94→  }\n    95→\n    96→  // ── Check Suite (CI) Events ───────────────────────────\n    97→  if (eventName === \"check_suite\" && payload.action === \"completed\") {\n    98→    const prs =\n    99→      (payload.check_suite?.pull_requests as Array<unknown>) || [];\n   100→    if (prs.length > 0) {\n   101→      return \"ship\";\n   102→    }\n   103→  }\n   104→\n   105→  return null;\n   106→}\n   107→"}]},"parent_tool_use_id":null,"session_id":"942cf364-60e4-40c3-bc94-9e511a2c0dff","uuid":"072e1de3-1961-4bbb-b58f-6d6ac649dfa5","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/router.ts","content":"import { Context } from \"@actions/github/lib/context\";\n\n/**\n * Detects which Kiln stage to run based on the GitHub event.\n *\n * Event → Stage mapping:\n *\n *   issues.opened                                        → triage\n *   issues.labeled  (kiln:specifying)                    → specify\n *   pull_request_review.submitted (approved + spec PR)   → approve-spec\n *   issues.labeled  (kiln:implementing)                  → implement\n *   pull_request.opened (impl PR)                        → review\n *   pull_request_review.submitted (changes_requested)    → fix\n *   pull_request_review.submitted (approved + impl PR)   → ship\n *   check_suite.completed (impl PR, all green)           → ship\n */\nexport function detectStage(context: Context): string | null {\n  const { eventName, payload } = context;\n\n  // ── Issue Events ──────────────────────────────────────\n  if (eventName === \"issues\") {\n    // New issue opened → triage\n    if (payload.action === \"opened\") {\n      return \"triage\";\n    }\n\n    // Labeled events — check which label was just added\n    if (payload.action === \"labeled\") {\n      const added = payload.label?.name as string | undefined;\n\n      if (added?.endsWith(\":specifying\")) return \"specify\";\n      if (added?.endsWith(\":implementing\")) return \"implement\";\n    }\n  }\n\n  // ── Issue Comment Events ──────────────────────────────\n  if (eventName === \"issue_comment\") {\n    if (payload.action === \"created\") {\n      const labels =\n        (payload.issue?.labels as Array<{ name: string }>) || [];\n      const labelNames = labels.map((l) => l.name);\n      if (\n        labelNames.some(\n          (n) => n.endsWith(\":intake\") || n.endsWith(\":needs-info\"),\n        )\n      ) {\n        return \"triage\";\n      }\n    }\n  }\n\n  // ── Pull Request Events ───────────────────────────────\n  if (eventName === \"pull_request\") {\n    const labels =\n      (payload.pull_request?.labels as Array<{ name: string }>) || [];\n    const labelNames = labels.map((l) => l.name);\n\n    // Impl PR opened or updated → review\n    if (\n      (payload.action === \"opened\" || payload.action === \"synchronize\") &&\n      labelNames.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      return \"review\";\n    }\n  }\n\n  // ── PR Review Events ──────────────────────────────────\n  if (eventName === \"pull_request_review\") {\n    const labels =\n      (payload.pull_request?.labels as Array<{ name: string }>) || [];\n    const labelNames = labels.map((l) => l.name);\n    const state = payload.review?.state as string | undefined;\n\n    // Spec PR approved → approve-spec (triggers implementation)\n    if (state === \"approved\" && labelNames.some((l) => l.endsWith(\":spec\"))) {\n      return \"approve-spec\";\n    }\n\n    // Impl PR: changes requested → fix\n    if (\n      state === \"changes_requested\" &&\n      labelNames.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      return \"fix\";\n    }\n\n    // Impl PR: approved → ship\n    if (\n      state === \"approved\" &&\n      labelNames.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      return \"ship\";\n    }\n  }\n\n  // ── Check Suite (CI) Events ───────────────────────────\n  if (eventName === \"check_suite\" && payload.action === \"completed\") {\n    const prs =\n      (payload.check_suite?.pull_requests as Array<unknown>) || [];\n    if (prs.length > 0) {\n      return \"ship\";\n    }\n  }\n\n  return null;\n}\n","numLines":107,"startLine":1,"totalLines":107}}}
