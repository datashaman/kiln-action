{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SibBxCSC7og6ecw5VtSgPQ","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import { transitionLabel } from \"../labels\";\n     3→import { KilnContext, StageResult } from \"../types\";\n     4→\n     5→export default async function approveSpec(\n     6→  ctx: KilnContext,\n     7→): Promise<StageResult> {\n     8→  const { octokit, context, config } = ctx;\n     9→  const pr = context.payload.pull_request!;\n    10→  const prefix = config.labels?.prefix || \"kiln\";\n    11→\n    12→  core.info(`🔥 Approve Spec — PR #${pr.number}: ${pr.title}`);\n    13→\n    14→  try {\n    15→    await octokit.rest.pulls.merge({\n    16→      ...context.repo,\n    17→      pull_number: pr.number,\n    18→      merge_method: \"squash\",\n    19→      commit_title: `${pr.title} (#${pr.number})`,\n    20→    });\n    21→    core.info(`Spec PR #${pr.number} merged.`);\n    22→  } catch (error) {\n    23→    const message = error instanceof Error ? error.message : String(error);\n    24→    core.setFailed(`Failed to merge spec PR: ${message}`);\n    25→    return { status: \"error\" };\n    26→  }\n    27→\n    28→  const issueMatch = (pr.body as string | undefined)?.match(\n    29→    /Tracking issue: #(\\d+)/,\n    30→  );\n    31→  if (!issueMatch) {\n    32→    core.warning(\"Could not find linked issue number in spec PR body.\");\n    33→    return { status: \"success\" };\n    34→  }\n    35→\n    36→  const issueNumber = parseInt(issueMatch[1], 10);\n    37→\n    38→  await transitionLabel(\n    39→    octokit,\n    40→    context,\n    41→    issueNumber,\n    42→    \"spec-review\",\n    43→    \"implementing\",\n    44→    prefix,\n    45→  );\n    46→\n    47→  await octokit.rest.issues.createComment({\n    48→    ...context.repo,\n    49→    issue_number: issueNumber,\n    50→    body: `🔨 **Kiln** — Spec approved and merged. Starting implementation.`,\n    51→  });\n    52→\n    53→  return { status: \"success\", nextStage: \"implement\" };\n    54→}\n    55→"}]},"parent_tool_use_id":null,"session_id":"c724d35f-7b14-4623-85ef-5de838552fab","uuid":"963e8307-a22f-443d-8fd0-8b70e2bace1a","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/approve-spec.ts","content":"import * as core from \"@actions/core\";\nimport { transitionLabel } from \"../labels\";\nimport { KilnContext, StageResult } from \"../types\";\n\nexport default async function approveSpec(\n  ctx: KilnContext,\n): Promise<StageResult> {\n  const { octokit, context, config } = ctx;\n  const pr = context.payload.pull_request!;\n  const prefix = config.labels?.prefix || \"kiln\";\n\n  core.info(`🔥 Approve Spec — PR #${pr.number}: ${pr.title}`);\n\n  try {\n    await octokit.rest.pulls.merge({\n      ...context.repo,\n      pull_number: pr.number,\n      merge_method: \"squash\",\n      commit_title: `${pr.title} (#${pr.number})`,\n    });\n    core.info(`Spec PR #${pr.number} merged.`);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.setFailed(`Failed to merge spec PR: ${message}`);\n    return { status: \"error\" };\n  }\n\n  const issueMatch = (pr.body as string | undefined)?.match(\n    /Tracking issue: #(\\d+)/,\n  );\n  if (!issueMatch) {\n    core.warning(\"Could not find linked issue number in spec PR body.\");\n    return { status: \"success\" };\n  }\n\n  const issueNumber = parseInt(issueMatch[1], 10);\n\n  await transitionLabel(\n    octokit,\n    context,\n    issueNumber,\n    \"spec-review\",\n    \"implementing\",\n    prefix,\n  );\n\n  await octokit.rest.issues.createComment({\n    ...context.repo,\n    issue_number: issueNumber,\n    body: `🔨 **Kiln** — Spec approved and merged. Starting implementation.`,\n  });\n\n  return { status: \"success\", nextStage: \"implement\" };\n}\n","numLines":55,"startLine":1,"totalLines":55}}}
