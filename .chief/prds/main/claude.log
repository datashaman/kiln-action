 issueNum = issue.number;\n    65→  const branchName = `kiln/spec/issue-${issueNum}`;\n    66→\n    67→  core.info(`🔥 Specify — Issue #${issueNum}: ${issue.title}`);\n    68→\n    69→  execSync('git config user.name \"kiln[bot]\"');\n    70→  execSync('git config user.email \"kiln[bot]@users.noreply.github.com\"');\n    71→  execSync(`git checkout -b ${branchName}`);\n    72→\n    73→  fs.mkdirSync(\"specs\", { recursive: true });\n    74→\n    75→  let specTemplate = DEFAULT_SPEC_TEMPLATE;\n    76→  const templatePath =\n    77→    config.spec_template || config.agents?.spec?.template;\n    78→  if (templatePath && fs.existsSync(templatePath)) {\n    79→    specTemplate = fs.readFileSync(templatePath, \"utf-8\");\n    80→    core.info(`🔥 Using custom spec template: ${templatePath}`);\n    81→  }\n    82→\n    83→  const prompt = `You are the Kiln spec agent. Your job is to produce a detailed, implementable specification.\n    84→\n    85→**Issue #${issueNum}**\n    86→**Title:** ${issue.title}\n    87→**Body:** ${issue.body || \"(empty)\"}\n    88→\n    89→First, read the existing codebase to understand the project structure, conventions, tech stack, and patterns.\n    90→\n    91→Then create the spec file at: specs/issue-${issueNum}.md\n    92→\n    93→Use this structure for the spec:\n    94→\n    95→${specTemplate}\n    96→\n    97→Important:\n    98→- Be specific about which files to create or modify\n    99→- Include concrete type/interface definitions where relevant\n   100→- Acceptance criteria must be testable\n   101→- Reference existing patterns in the codebase\n   102→- The implementation agent will use this spec as its SOLE instruction set\n   103→\n   104→After creating the spec file, commit it to the current branch with message:\n   105→\"docs: add spec for issue #${issueNum}\"\n   106→\n   107→Then push the branch.`;\n   108→\n   109→  runClaudeEdit(prompt, { anthropicKey, timeoutMinutes });\n   110→\n   111→  const specPath = `specs/issue-${issueNum}.md`;\n   112→  if (!fs.existsSync(specPath)) {\n   113→    core.setFailed(`Spec agent did not create ${specPath}`);\n   114→    return { status: \"error\" };\n   115→  }\n   116→\n   117→  try {\n   118→    execSync(\n   119→      `git add -A && git commit -m \"docs: add spec for issue #${issueNum}\" --allow-empty`,\n   120→    );\n   121→  } catch {\n   122→    // Already committed by Claude\n   123→  }\n   124→  execSync(`git push origin ${branchName} --force`);\n   125→\n   126→  const { data: pr } = await octokit.rest.pulls.create({\n   127→    ...context.repo,\n   128→    title: `📋 Kiln Spec: ${issue.title}`,\n   129→    body: [\n   130→      `## Specification for #${issueNum}`,\n   131→      \"\",\n   132→      \"🔥 *Fired in the Kiln*\",\n   133→      \"\",\n   134→      `Review the spec at \\`${specPath}\\`.`,\n   135→      \"**Approve this PR to trigger implementation.**\",\n   136→      \"\",\n   137→      \"---\",\n   138→      `Tracking issue: #${issueNum}`,\n   139→    ].join(\"\\n\"),\n   140→    head: branchName,\n   141→    base: \"main\",\n   142→  });\n   143→\n   144→  await octokit.rest.issues.addLabels({\n   145→    ...context.repo,\n   146→    issue_number: pr.number,\n   147→    labels: [`${prefix}:spec`, \"needs-human-review\"],\n   148→  });\n   149→\n   150→  await octokit.rest.issues.createComment({\n   151→    ...context.repo,\n   152→    issue_number: issueNum,\n   153→    body: `📋 **Kiln** — Spec ready for review: #${pr.number}\\n\\nApprove the spec PR to start implementation.`,\n   154→  });\n   155→\n   156→  await transitionLabel(\n   157→    octokit,\n   158→    context,\n   159→    issueNum,\n   160→    \"specifying\",\n   161→    \"spec-review\",\n   162→    prefix,\n   163→  );\n   164→\n   165→  return { status: \"success\", prNumber: pr.number };\n   166→}\n   167→"}]},"parent_tool_use_id":null,"session_id":"9f060dfe-dd73-41ed-8761-620bfcb4f31f","uuid":"1df34590-9a3d-4698-b490-7a9acad7bc0b","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/specify.ts","content":"import * as core from \"@actions/core\";\nimport * as fs from \"fs\";\nimport { execSync } from \"child_process\";\nimport { runClaudeEdit } from \"../claude\";\nimport { transitionLabel } from \"../labels\";\nimport { KilnContext, StageResult } from \"../types\";\n\nconst DEFAULT_SPEC_TEMPLATE = `# Spec: [Title]\n\n## 1. Overview\nWhat this change does and why it's needed.\n\n## 2. Requirements\n- [ ] Acceptance criterion 1\n- [ ] Acceptance criterion 2\n- [ ] Acceptance criterion 3\n\n## 3. Technical Design\n\n### Files to create/modify\n| File | Action | Purpose |\n|---|---|---|\n| path/to/file | create/modify | description |\n\n### Key interfaces / types\n\\`\\`\\`typescript\n// Define key interfaces here\n\\`\\`\\`\n\n### Data flow\nDescribe how data moves through the system.\n\n### Edge cases\n- Edge case 1\n- Edge case 2\n\n## 4. Test Plan\n\n### Unit tests\n- Test case 1\n- Test case 2\n\n### Integration tests\n- Test case 1\n\n### Manual verification\n- Step 1\n- Step 2\n\n## 5. Out of Scope\nWhat this change does NOT cover.\n\n## 6. Implementation Notes\n- Suggested order of implementation\n- Potential pitfalls or gotchas\n`;\n\nexport default async function specify(\n  ctx: KilnContext,\n): Promise<StageResult> {\n  const { octokit, context, config, anthropicKey, timeoutMinutes } = ctx;\n  const issue = context.payload.issue!;\n  const prefix = config.labels?.prefix || \"kiln\";\n  const issueNum = issue.number;\n  const branchName = `kiln/spec/issue-${issueNum}`;\n\n  core.info(`🔥 Specify — Issue #${issueNum}: ${issue.title}`);\n\n  execSync('git config user.name \"kiln[bot]\"');\n  execSync('git config user.email \"kiln[bot]@users.noreply.github.com\"');\n  execSync(`git checkout -b ${branchName}`);\n\n  fs.mkdirSync(\"specs\", { recursive: true });\n\n  let specTemplate = DEFAULT_SPEC_TEMPLATE;\n  const templatePath =\n    config.spec_template || config.agents?.spec?.template;\n  if (templatePath && fs.existsSync(templatePath)) {\n    specTemplate = fs.readFileSync(templatePath, \"utf-8\");\n    core.info(`🔥 Using custom spec template: ${templatePath}`);\n  }\n\n  const prompt = `You are the Kiln spec agent. Your job is to produce a detailed, implementable specification.\n\n**Issue #${issueNum}**\n**Title:** ${issue.title}\n**Body:** ${issue.body || \"(empty)\"}\n\nFirst, read the existing codebase to understand the project structure, conventions, tech stack, and patterns.\n\nThen create the spec file at: specs/issue-${issueNum}.md\n\nUse this structure for the spec:\n\n${specTemplate}\n\nImportant:\n- Be specific about which files to create or modify\n- Include concrete type/interface definitions where relevant\n- Acceptance criteria must be testable\n- Reference existing patterns in the codebase\n- The implementation agent will use this spec as its SOLE instruction set\n\nAfter creating the spec file, commit it to the current branch with message:\n\"docs: add spec for issue #${issueNum}\"\n\nThen push the branch.`;\n\n  runClaudeEdit(prompt, { anthropicKey, timeoutMinutes });\n\n  const specPath = `specs/issue-${issueNum}.md`;\n  if (!fs.existsSync(specPath)) {\n    core.setFailed(`Spec agent did not create ${specPath}`);\n    return { status: \"error\" };\n  }\n\n  try {\n    execSync(\n      `git add -A && git commit -m \"docs: add spec for issue #${issueNum}\" --allow-empty`,\n    );\n  } catch {\n    // Already committed by Claude\n  }\n  execSync(`git push origin ${branchName} --force`);\n\n  const { data: pr } = await octokit.rest.pulls.create({\n    ...context.repo,\n    title: `📋 Kiln Spec: ${issue.title}`,\n    body: [\n      `## Specification for #${issueNum}`,\n      \"\",\n      \"🔥 *Fired in the Kiln*\",\n      \"\",\n      `Review the spec at \\`${specPath}\\`.`,\n      \"**Approve this PR to trigger implementation.**\",\n      \"\",\n      \"---\",\n      `Tracking issue: #${issueNum}`,\n    ].join(\"\\n\"),\n    head: branchName,\n    base: \"main\",\n  });\n\n  await octokit.rest.issues.addLabels({\n    ...context.repo,\n    issue_number: pr.number,\n    labels: [`${prefix}:spec`, \"needs-human-review\"],\n  });\n\n  await octokit.rest.issues.createComment({\n    ...context.repo,\n    issue_number: issueNum,\n    body: `📋 **Kiln** — Spec ready for review: #${pr.number}\\n\\nApprove the spec PR to start implementation.`,\n  });\n\n  await transitionLabel(\n    octokit,\n    context,\n    issueNum,\n    \"specifying\",\n    \"spec-review\",\n    prefix,\n  );\n\n  return { status: \"success\", prNumber: pr.number };\n}\n","numLines":167,"startLine":1,"totalLines":167}}}
