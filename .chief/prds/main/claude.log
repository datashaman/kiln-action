{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LjPtSneVj1NGcSoSp1S7UC","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import * as github from \"@actions/github\";\n     3→import { loadConfig } from \"./config\";\n     4→import { ensureLabels } from \"./labels\";\n     5→import { detectStage } from \"./router\";\n     6→import { KilnContext, StageResult } from \"./types\";\n     7→\n     8→import triage from \"./stages/triage\";\n     9→import specify from \"./stages/specify\";\n    10→import approveSpec from \"./stages/approve-spec\";\n    11→import implement from \"./stages/implement\";\n    12→import review from \"./stages/review\";\n    13→import fix from \"./stages/fix\";\n    14→import ship from \"./stages/ship\";\n    15→\n    16→type StageHandler = (ctx: KilnContext) => Promise<StageResult>;\n    17→\n    18→const STAGES: Record<string, StageHandler> = {\n    19→  triage,\n    20→  specify,\n    21→  \"approve-spec\": approveSpec,\n    22→  implement,\n    23→  review,\n    24→  fix,\n    25→  ship,\n    26→};\n    27→\n    28→async function isBlocked(\n    29→  octokit: KilnContext[\"octokit\"],\n    30→  context: KilnContext[\"context\"],\n    31→  config: KilnContext[\"config\"],\n    32→): Promise<boolean> {\n    33→  const prefix = config.labels?.prefix || \"kiln\";\n    34→  const blockedLabel = `${prefix}:blocked`;\n    35→\n    36→  let issueNumber = context.payload.issue?.number as number | undefined;\n    37→  if (!issueNumber && context.payload.pull_request) {\n    38→    const match = (\n    39→      context.payload.pull_request.body as string | undefined\n    40→    )?.match(/Closes #(\\d+)/);\n    41→    if (match) issueNumber = parseInt(match[1], 10);\n    42→  }\n    43→\n    44→  if (!issueNumber) return false;\n    45→\n    46→  try {\n    47→    const { data: issue } = await octokit.rest.issues.get({\n    48→      ...context.repo,\n    49→      issue_number: issueNumber,\n    50→    });\n    51→    return issue.labels.some(\n    52→      (l) => (typeof l === \"string\" ? l : l.name) === blockedLabel,\n    53→    );\n    54→  } catch {\n    55→    return false;\n    56→  }\n    57→}\n    58→\n    59→async function run(): Promise<void> {\n    60→  try {\n    61→    const token = core.getInput(\"github_token\");\n    62→    const anthropicKey = core.getInput(\"anthropic_api_key\");\n    63→    const configPath = core.getInput(\"config_path\");\n    64→    const forceStage = core.getInput(\"stage\");\n    65→    const timeoutMinutes = parseInt(core.getInput(\"timeout_minutes\"), 10);\n    66→\n    67→    const octokit = github.getOctokit(token);\n    68→    const context = github.context;\n    69→\n    70→    const config = await loadConfig(configPath);\n    71→\n    72→    await ensureLabels(octokit, context, config);\n    73→\n    74→    if (await isBlocked(octokit, context, config)) {\n    75→      core.info(\"🛑 Kiln is blocked on this issue. Skipping.\");\n    76→      core.setOutput(\"stage\", \"none\");\n    77→      core.setOutput(\"result\", \"blocked\");\n    78→      return;\n    79→    }\n    80→\n    81→    const stage = forceStage !== \"auto\" ? forceStage : detectStage(context);\n    82→\n    83→    if (!stage) {\n    84→      core.info(\"🔥 Kiln — No matching stage for this event. Skipping.\");\n    85→      core.setOutput(\"stage\", \"none\");\n    86→      core.setOutput(\"result\", \"skipped\");\n    87→      return;\n    88→    }\n    89→\n    90→    core.info(`🔥 Kiln — Running stage: ${stage}`);\n    91→\n    92→    const handler = STAGES[stage];\n    93→    if (!handler) {\n    94→      core.setFailed(`Unknown stage: ${stage}`);\n    95→      return;\n    96→    }\n    97→\n    98→    const ctx: KilnContext = {\n    99→      octokit,\n   100→      context,\n   101→      config,\n   102→      anthropicKey,\n   103→      timeoutMinutes,\n   104→      token,\n   105→    };\n   106→\n   107→    const result = await handler(ctx);\n   108→\n   109→    core.setOutput(\"stage\", stage);\n   110→    core.setOutput(\"result\", result?.status || \"success\");\n   111→    if (result?.prNumber) {\n   112→      core.setOutput(\"pr_number\", result.prNumber.toString());\n   113→    }\n   114→\n   115→    core.info(`🔥 Kiln — Stage \"${stage}\" completed.`);\n   116→  } catch (error) {\n   117→    const message = error instanceof Error ? error.message : String(error);\n   118→    core.setFailed(`🔥 Kiln failed: ${message}`);\n   119→  }\n   120→}\n   121→\n   122→run();\n   123→"}]},"parent_tool_use_id":null,"session_id":"942cf364-60e4-40c3-bc94-9e511a2c0dff","uuid":"8295e9db-bf56-4709-9848-ddb51cf3baa7","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/index.ts","content":"import * as core from \"@actions/core\";\nimport * as github from \"@actions/github\";\nimport { loadConfig } from \"./config\";\nimport { ensureLabels } from \"./labels\";\nimport { detectStage } from \"./router\";\nimport { KilnContext, StageResult } from \"./types\";\n\nimport triage from \"./stages/triage\";\nimport specify from \"./stages/specify\";\nimport approveSpec from \"./stages/approve-spec\";\nimport implement from \"./stages/implement\";\nimport review from \"./stages/review\";\nimport fix from \"./stages/fix\";\nimport ship from \"./stages/ship\";\n\ntype StageHandler = (ctx: KilnContext) => Promise<StageResult>;\n\nconst STAGES: Record<string, StageHandler> = {\n  triage,\n  specify,\n  \"approve-spec\": approveSpec,\n  implement,\n  review,\n  fix,\n  ship,\n};\n\nasync function isBlocked(\n  octokit: KilnContext[\"octokit\"],\n  context: KilnContext[\"context\"],\n  config: KilnContext[\"config\"],\n): Promise<boolean> {\n  const prefix = config.labels?.prefix || \"kiln\";\n  const blockedLabel = `${prefix}:blocked`;\n\n  let issueNumber = context.payload.issue?.number as number | undefined;\n  if (!issueNumber && context.payload.pull_request) {\n    const match = (\n      context.payload.pull_request.body as string | undefined\n    )?.match(/Closes #(\\d+)/);\n    if (match) issueNumber = parseInt(match[1], 10);\n  }\n\n  if (!issueNumber) return false;\n\n  try {\n    const { data: issue } = await octokit.rest.issues.get({\n      ...context.repo,\n      issue_number: issueNumber,\n    });\n    return issue.labels.some(\n      (l) => (typeof l === \"string\" ? l : l.name) === blockedLabel,\n    );\n  } catch {\n    return false;\n  }\n}\n\nasync function run(): Promise<void> {\n  try {\n    const token = core.getInput(\"github_token\");\n    const anthropicKey = core.getInput(\"anthropic_api_key\");\n    const configPath = core.getInput(\"config_path\");\n    const forceStage = core.getInput(\"stage\");\n    const timeoutMinutes = parseInt(core.getInput(\"timeout_minutes\"), 10);\n\n    const octokit = github.getOctokit(token);\n    const context = github.context;\n\n    const config = await loadConfig(configPath);\n\n    await ensureLabels(octokit, context, config);\n\n    if (await isBlocked(octokit, context, config)) {\n      core.info(\"🛑 Kiln is blocked on this issue. Skipping.\");\n      core.setOutput(\"stage\", \"none\");\n      core.setOutput(\"result\", \"blocked\");\n      return;\n    }\n\n    const stage = forceStage !== \"auto\" ? forceStage : detectStage(context);\n\n    if (!stage) {\n      core.info(\"🔥 Kiln — No matching stage for this event. Skipping.\");\n      core.setOutput(\"stage\", \"none\");\n      core.setOutput(\"result\", \"skipped\");\n      return;\n    }\n\n    core.info(`🔥 Kiln — Running stage: ${stage}`);\n\n    const handler = STAGES[stage];\n    if (!handler) {\n      core.setFailed(`Unknown stage: ${stage}`);\n      return;\n    }\n\n    const ctx: KilnContext = {\n      octokit,\n      context,\n      config,\n      anthropicKey,\n      timeoutMinutes,\n      token,\n    };\n\n    const result = await handler(ctx);\n\n    core.setOutput(\"stage\", stage);\n    core.setOutput(\"result\", result?.status || \"success\");\n    if (result?.prNumber) {\n      core.setOutput(\"pr_number\", result.prNumber.toString());\n    }\n\n    core.info(`🔥 Kiln — Stage \"${stage}\" completed.`);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.setFailed(`🔥 Kiln failed: ${message}`);\n  }\n}\n\nrun();\n","numLines":123,"startLine":1,"totalLines":123}}}
