{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BHfP6BKNCC2bWe5iWUYPus","type":"tool_result","content":"     1→import retriage from \"./retriage\";\n     2→import { KilnContext, KilnConfig, Octokit } from \"../types\";\n     3→import { Context } from \"@actions/github/lib/context\";\n     4→\n     5→jest.mock(\"@actions/core\");\n     6→jest.mock(\"../claude\");\n     7→jest.mock(\"../labels\");\n     8→\n     9→import * as core from \"@actions/core\";\n    10→import { runClaude } from \"../claude\";\n    11→import { transitionLabel } from \"../labels\";\n    12→\n    13→const mockedRunClaude = runClaude as unknown as jest.Mock;\n    14→const mockedTransitionLabel = transitionLabel as unknown as jest.Mock;\n    15→\n    16→function makeOctokit(): Octokit {\n    17→  return {\n    18→    rest: {\n    19→      issues: {\n    20→        createComment: jest.fn().mockResolvedValue({}),\n    21→        addLabels: jest.fn().mockResolvedValue({}),\n    22→        listComments: jest.fn().mockResolvedValue({\n    23→          data: [\n    24→            {\n    25→              user: { login: \"author-user\" },\n    26→              body: \"Here is the additional info you requested.\",\n    27→            },\n    28→          ],\n    29→        }),\n    30→      },\n    31→    },\n    32→  } as unknown as Octokit;\n    33→}\n    34→\n    35→function makeConfig(prefix = \"kiln\"): KilnConfig {\n    36→  return { labels: { prefix } } as unknown as KilnConfig;\n    37→}\n    38→\n    39→function makeContext(\n    40→  overrides: {\n    41→    issuePayload?: Record<string, unknown>;\n    42→    commentPayload?: Record<string, unknown>;\n    43→  } = {},\n    44→): Context {\n    45→  return {\n    46→    eventName: \"issue_comment\",\n    47→    payload: {\n    48→      action: \"created\",\n    49→      issue: overrides.issuePayload || {\n    50→        number: 42,\n    51→        title: \"Add dark mode\",\n    52→        body: \"I want dark mode support.\",\n    53→        labels: [{ name: \"kiln:needs-info\" }],\n    54→      },\n    55→      comment: overrides.commentPayload || {\n    56→        user: { login: \"author-user\", type: \"User\" },\n    57→        body: \"Here is the additional info you requested.\",\n    58→      },\n    59→    },\n    60→    repo: { owner: \"test-owner\", repo: \"test-repo\" },\n    61→  } as unknown as Context;\n    62→}\n    63→\n    64→function makeCtx(overrides: Partial<KilnContext> = {}): KilnContext {\n    65→  return {\n    66→    octokit: makeOctokit(),\n    67→    context: makeContext(),\n    68→    config: makeConfig(),\n    69→    anthropicKey: \"sk-ant-test-key\",\n    70→    timeoutMinutes: 30,\n    71→    token: \"ghp-test-token\",\n    72→    ...overrides,\n    73→  };\n    74→}\n    75→\n    76→const CLEAR_RESPONSE = JSON.stringify({\n    77→  type: \"feature\",\n    78→  complexity: \"m\",\n    79→  clear_enough: true,\n    80→  comment:\n    81→    \"Thanks for the clarification! I now understand you want dark mode for all pages. Moving to specification.\",\n    82→  labels: [],\n    83→});\n    84→\n    85→const UNCLEAR_RESPONSE = JSON.stringify({\n    86→  type: \"feature\",\n    87→  complexity: \"l\",\n    88→  clear_enough: false,\n    89→  comment:\n    90→    \"Thanks for the update, but I still need to know: should dark mode persist across sessions?\",\n    91→  labels: [],\n    92→});\n    93→\n    94→beforeEach(() => {\n    95→  jest.clearAllMocks();\n    96→  mockedTransitionLabel.mockResolvedValue(undefined);\n    97→});\n    98→\n    99→describe(\"retriage\", () => {\n   100→  // ── AC: Triggers on issue_comment.created ───────────\n   101→  describe(\"triggers on issue_comment.created\", () => {\n   102→    it(\"processes a comment event\", async () => {\n   103→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   104→      const ctx = makeCtx();\n   105→      const result = await retriage(ctx);\n   106→      expect(result.status).toBe(\"success\");\n   107→    });\n   108→\n   109→    it(\"logs the issue number and title\", async () => {\n   110→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   111→      const ctx = makeCtx();\n   112→      await retriage(ctx);\n   113→      expect(core.info).toHaveBeenCalledWith(\n   114→        expect.stringContaining(\"Issue #42: Add dark mode\"),\n   115→      );\n   116→    });\n   117→  });\n   118→\n   119→  // ── AC: Only runs if issue has kiln:intake or kiln:needs-info ──\n   120→  // (This is handled by the router, but we verify the handler runs correctly)\n   121→  describe(\"handles issues with intake/needs-info labels\", () => {\n   122→    it(\"runs for issue with kiln:needs-info label\", async () => {\n   123→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   124→      const ctx = makeCtx();\n   125→      const result = await retriage(ctx);\n   126→      expect(result.status).toBe(\"success\");\n   127→      expect(mockedRunClaude).toHaveBeenCalled();\n   128→    });\n   129→\n   130→    it(\"runs for issue with kiln:intake label\", async () => {\n   131→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   132→      const ctx = makeCtx({\n   133→        context: makeContext({\n   134→          issuePayload: {\n   135→            number: 42,\n   136→            title: \"Add dark mode\",\n   137→            body: \"I want dark mode support.\",\n   138→            labels: [{ name: \"kiln:intake\" }],\n   139→          },\n   140→        }),\n   141→      });\n   142→      const result = await retriage(ctx);\n   143→      expect(result.status).toBe(\"success\");\n   144→      expect(mockedRunClaude).toHaveBeenCalled();\n   145→    });\n   146→  });\n   147→\n   148→  // ── AC: Ignores comments from bots/actions ──────────\n   149→  describe(\"ignores bot comments\", () => {\n   150→    it(\"ignores comments from Bot user type\", async () => {\n   151→      const ctx = makeCtx({\n   152→        context: makeContext({\n   153→          commentPayload: {\n   154→            user: { login: \"some-bot\", type: \"Bot\" },\n   155→            body: \"Automated message\",\n   156→          },\n   157→        }),\n   158→      });\n   159→      const result = await retriage(ctx);\n   160→\n   161→      expect(result.status).toBe(\"success\");\n   162→      expect(result.nextStage).toBe(\"waiting-for-info\");\n   163→      expect(mockedRunClaude).not.toHaveBeenCalled();\n   164→    });\n   165→\n   166→    it(\"ignores comments from github-actions[bot]\", async () => {\n   167→      const ctx = makeCtx({\n   168→        context: makeContext({\n   169→          commentPayload: {\n   170→            user: { login: \"github-actions[bot]\", type: \"Bot\" },\n   171→            body: \"Kiln triage comment\",\n   172→          },\n   173→        }),\n   174→      });\n   175→      const result = await retriage(ctx);\n   176→\n   177→      expect(result.status).toBe(\"success\");\n   178→      expect(result.nextStage).toBe(\"waiting-for-info\");\n   179→      expect(mockedRunClaude).not.toHaveBeenCalled();\n   180→    });\n   181→\n   182→    it(\"logs when ignoring bot comment\", async () => {\n   183→      const ctx = makeCtx({\n   184→        context: makeContext({\n   185→          commentPayload: {\n   186→            user: { login: \"some-bot\", type: \"Bot\" },\n   187→            body: \"Automated message\",\n   188→          },\n   189→        }),\n   190→      });\n   191→      await retriage(ctx);\n   192→\n   193→      expect(core.info).toHaveBeenCalledWith(\n   194→        expect.stringContaining(\"Ignoring bot comment from some-bot\"),\n   195→      );\n   196→    });\n   197→\n   198→    it(\"processes comments from regular users\", async () => {\n   199→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   200→      const ctx = makeCtx({\n   201→        context: makeContext({\n   202→          commentPayload: {\n   203→            user: { login: \"human-user\", type: \"User\" },\n   204→            body: \"Here is the info\",\n   205→          },\n   206→        }),\n   207→      });\n   208→      const result = await retriage(ctx);\n   209→\n   210→      expect(result.status).toBe(\"success\");\n   211→      expect(mockedRunClaude).toHaveBeenCalled();\n   212→    });\n   213→  });\n   214→\n   215→  // ── AC: Sends full issue body + all comments to Claude ────\n   216→  describe(\"sends full context to Claude\", () => {\n   217→    it(\"includes issue title, body, and comments in the prompt\", async () => {\n   218→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   219→      const ctx = makeCtx();\n   220→      await retriage(ctx);\n   221→\n   222→      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n   223→      expect(prompt).toContain(\"Add dark mode\");\n   224→      expect(prompt).toContain(\"I want dark mode support.\");\n   225→      expect(prompt).toContain(\"@author-user\");\n   226→      expect(prompt).toContain(\n   227→        \"Here is the additional info you requested.\",\n   228→      );\n   229→    });\n   230→\n   231→    it(\"fetches comments from the GitHub API\", async () => {\n   232→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   233→      const ctx = makeCtx();\n   234→      await retriage(ctx);\n   235→\n   236→      expect(ctx.octokit.rest.issues.listComments).toHaveBeenCalledWith(\n   237→        expect.objectContaining({\n   238→          owner: \"test-owner\",\n   239→          repo: \"test-repo\",\n   240→          issue_number: 42,\n   241→          per_page: 100,\n   242→        }),\n   243→      );\n   244→    });\n   245→\n   246→    it(\"includes multiple comments in the prompt\", async () => {\n   247→      const octokit = makeOctokit();\n   248→      (octokit.rest.issues.listComments as unknown as jest.Mock).mockResolvedValue({\n   249→        data: [\n   250→          { user: { login: \"author\" }, body: \"First comment\" },\n   251→          { user: { login: \"maintainer\" }, body: \"What framework?\" },\n   252→          { user: { login: \"author\" }, body: \"Using React\" },\n   253→        ],\n   254→      });\n   255→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   256→      const ctx = makeCtx({ octokit });\n   257→      await retriage(ctx);\n   258→\n   259→      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n   260→      expect(prompt).toContain(\"@author\");\n   261→      expect(prompt).toContain(\"First comment\");\n   262→      expect(prompt).toContain(\"@maintainer\");\n   263→      expect(prompt).toContain(\"What framework?\");\n   264→      expect(prompt).toContain(\"Using React\");\n   265→    });\n   266→\n   267→    it(\"handles empty issue body\", async () => {\n   268→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   269→      const ctx = makeCtx({\n   270→        context: makeContext({\n   271→          issuePayload: {\n   272→            number: 42,\n   273→            title: \"Add dark mode\",\n   274→            body: null,\n   275→            labels: [{ name: \"kiln:needs-info\" }],\n   276→          },\n   277→        }),\n   278→      });\n   279→      await retriage(ctx);\n   280→\n   281→      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n   282→      expect(prompt).toContain(\"(empty)\");\n   283→    });\n   284→\n   285→    it(\"passes anthropic key and timeout to runClaude\", async () => {\n   286→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   287→      const ctx = makeCtx({\n   288→        anthropicKey: \"sk-ant-custom\",\n   289→        timeoutMinutes: 15,\n   290→      });\n   291→      await retriage(ctx);\n   292→\n   293→      expect(mockedRunClaude).toHaveBeenCalledWith(expect.any(String), {\n   294→        anthropicKey: \"sk-ant-custom\",\n   295→        timeoutMinutes: 15,\n   296→      });\n   297→    });\n   298→\n   299→    it(\"mentions re-triage context in the prompt\", async () => {\n   300→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   301→      const ctx = makeCtx();\n   302→      await retriage(ctx);\n   303→\n   304→      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n   305→      expect(prompt).toMatch(/re-?triage/i);\n   306→    });\n   307→  });\n   308→\n   309→  // ── AC: If now clear → remove needs-info, apply specifying ──\n   310→  describe(\"clear_enough is true\", () => {\n   311→    it(\"transitions from needs-info to specifying\", async () => {\n   312→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   313→      const ctx = makeCtx();\n   314→      await retriage(ctx);\n   315→\n   316→      expect(mockedTransitionLabel).toHaveBeenCalledWith(\n   317→        ctx.octokit,\n   318→        ctx.context,\n   319→        42,\n   320→        \"needs-info\",\n   321→        \"specifying\",\n   322→        \"kiln\",\n   323→      );\n   324→    });\n   325→\n   326→    it(\"returns nextStage: specify\", async () => {\n   327→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   328→      const ctx = makeCtx();\n   329→      const result = await retriage(ctx);\n   330→\n   331→      expect(result.nextStage).toBe(\"specify\");\n   332→    });\n   333→\n   334→    it(\"posts confirmation comment\", async () => {\n   335→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   336→      const ctx = makeCtx();\n   337→      await retriage(ctx);\n   338→\n   339→      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n   340→        expect.objectContaining({\n   341→          issue_number: 42,\n   342→          body: expect.stringContaining(\n   343→            \"Thanks for the clarification\",\n   344→          ),\n   345→        }),\n   346→      );\n   347→    });\n   348→\n   349→    it(\"uses custom label prefix\", async () => {\n   350→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   351→      const ctx = makeCtx({ config: makeConfig(\"myapp\") });\n   352→      await retriage(ctx);\n   353→\n   354→      expect(mockedTransitionLabel).toHaveBeenCalledWith(\n   355→        expect.anything(),\n   356→        expect.anything(),\n   357→        42,\n   358→        \"needs-info\",\n   359→        \"specifying\",\n   360→        \"myapp\",\n   361→      );\n   362→    });\n   363→  });\n   364→\n   365→  // ── AC: If still unclear → keep needs-info, post follow-up ──\n   366→  describe(\"clear_enough is false\", () => {\n   367→    it(\"does NOT transition labels\", async () => {\n   368→      mockedRunClaude.mockReturnValue(UNCLEAR_RESPONSE);\n   369→      const ctx = makeCtx();\n   370→      await retriage(ctx);\n   371→\n   372→      expect(mockedTransitionLabel).not.toHaveBeenCalled();\n   373→    });\n   374→\n   375→    it(\"returns nextStage: waiting-for-info\", async () => {\n   376→      mockedRunClaude.mockReturnValue(UNCLEAR_RESPONSE);\n   377→      const ctx = makeCtx();\n   378→      const result = await retriage(ctx);\n   379→\n   380→      expect(result.nextStage).toBe(\"waiting-for-info\");\n   381→    });\n   382→\n   383→    it(\"posts follow-up clarification request\", async () => {\n   384→      mockedRunClaude.mockReturnValue(UNCLEAR_RESPONSE);\n   385→      const ctx = makeCtx();\n   386→      await retriage(ctx);\n   387→\n   388→      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n   389→        expect.objectContaining({\n   390→          issue_number: 42,\n   391→          body: expect.stringContaining(\n   392→            \"should dark mode persist across sessions\",\n   393→          ),\n   394→        }),\n   395→      );\n   396→    });\n   397→\n   398→    it(\"keeps kiln:needs-info label (no label changes)\", async () => {\n   399→      mockedRunClaude.mockReturnValue(UNCLEAR_RESPONSE);\n   400→      const ctx = makeCtx();\n   401→      await retriage(ctx);\n   402→\n   403→      // No label transitions should happen\n   404→      expect(mockedTransitionLabel).not.toHaveBeenCalled();\n   405→      // No addLabels calls for needs-info (it's already there)\n   406→      expect(ctx.octokit.rest.issues.addLabels).not.toHaveBeenCalled();\n   407→    });\n   408→  });\n   409→\n   410→  // ── AC: Posts Kiln-branded comment ────────────────────\n   411→  describe(\"branded comment\", () => {\n   412→    it(\"posts a Kiln-branded re-triage comment\", async () => {\n   413→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   414→      const ctx = makeCtx();\n   415→      await retriage(ctx);\n   416→\n   417→      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n   418→        expect.objectContaining({\n   419→          body: expect.stringMatching(/^🔥 \\*\\*Kiln Re-triage\\*\\*/),\n   420→        }),\n   421→      );\n   422→    });\n   423→  });\n   424→\n   425→  // ── JSON parsing ───────────────────────────────────────\n   426→  describe(\"parses Claude JSON response\", () => {\n   427→    it(\"parses JSON from code block\", async () => {\n   428→      mockedRunClaude.mockReturnValue(\n   429→        '```json\\n{\"type\":\"bug\",\"complexity\":\"s\",\"clear_enough\":true,\"comment\":\"Got it.\",\"labels\":[]}\\n```',\n   430→      );\n   431→      const ctx = makeCtx();\n   432→      const result = await retriage(ctx);\n   433→      expect(result.status).toBe(\"success\");\n   434→      expect(result.nextStage).toBe(\"specify\");\n   435→    });\n   436→\n   437→    it(\"parses raw JSON without code block\", async () => {\n   438→      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n   439→      const ctx = makeCtx();\n   440→      const result = await retriage(ctx);\n   441→      expect(result.status).toBe(\"success\");\n   442→    });\n   443→\n   444→    it(\"falls back to defaults on parse failure\", async () => {\n   445→      mockedRunClaude.mockReturnValue(\"This is not JSON at all\");\n   446→      const ctx = makeCtx();\n   447→      const result = await retriage(ctx);\n   448→\n   449→      expect(result.status).toBe(\"success\");\n   450→      expect(core.warning).toHaveBeenCalledWith(\n   451→        expect.stringContaining(\"Failed to parse re-triage response\"),\n   452→      );\n   453→      // Default: clear_enough=true → moves to specify\n   454→      expect(result.nextStage).toBe(\"specify\");\n   455→    });\n   456→\n   457→    it(\"logs raw output on parse failure\", async () => {\n   458→      mockedRunClaude.mockReturnValue(\"garbage output\");\n   459→      const ctx = makeCtx();\n   460→      await retriage(ctx);\n   461→\n   462→      expect(core.warning).toHaveBeenCalledWith(\n   463→        expect.stringContaining(\"Raw output: garbage output\"),\n   464→      );\n   465→    });\n   466→  });\n   467→});\n   468→"}]},"parent_tool_use_id":null,"session_id":"9f060dfe-dd73-41ed-8761-620bfcb4f31f","uuid":"235c9d04-9f47-44f0-8bc6-021ee48ba20d","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/retriage.test.ts","content":"import retriage from \"./retriage\";\nimport { KilnContext, KilnConfig, Octokit } from \"../types\";\nimport { Context } from \"@actions/github/lib/context\";\n\njest.mock(\"@actions/core\");\njest.mock(\"../claude\");\njest.mock(\"../labels\");\n\nimport * as core from \"@actions/core\";\nimport { runClaude } from \"../claude\";\nimport { transitionLabel } from \"../labels\";\n\nconst mockedRunClaude = runClaude as unknown as jest.Mock;\nconst mockedTransitionLabel = transitionLabel as unknown as jest.Mock;\n\nfunction makeOctokit(): Octokit {\n  return {\n    rest: {\n      issues: {\n        createComment: jest.fn().mockResolvedValue({}),\n        addLabels: jest.fn().mockResolvedValue({}),\n        listComments: jest.fn().mockResolvedValue({\n          data: [\n            {\n              user: { login: \"author-user\" },\n              body: \"Here is the additional info you requested.\",\n            },\n          ],\n        }),\n      },\n    },\n  } as unknown as Octokit;\n}\n\nfunction makeConfig(prefix = \"kiln\"): KilnConfig {\n  return { labels: { prefix } } as unknown as KilnConfig;\n}\n\nfunction makeContext(\n  overrides: {\n    issuePayload?: Record<string, unknown>;\n    commentPayload?: Record<string, unknown>;\n  } = {},\n): Context {\n  return {\n    eventName: \"issue_comment\",\n    payload: {\n      action: \"created\",\n      issue: overrides.issuePayload || {\n        number: 42,\n        title: \"Add dark mode\",\n        body: \"I want dark mode support.\",\n        labels: [{ name: \"kiln:needs-info\" }],\n      },\n      comment: overrides.commentPayload || {\n        user: { login: \"author-user\", type: \"User\" },\n        body: \"Here is the additional info you requested.\",\n      },\n    },\n    repo: { owner: \"test-owner\", repo: \"test-repo\" },\n  } as unknown as Context;\n}\n\nfunction makeCtx(overrides: Partial<KilnContext> = {}): KilnContext {\n  return {\n    octokit: makeOctokit(),\n    context: makeContext(),\n    config: makeConfig(),\n    anthropicKey: \"sk-ant-test-key\",\n    timeoutMinutes: 30,\n    token: \"ghp-test-token\",\n    ...overrides,\n  };\n}\n\nconst CLEAR_RESPONSE = JSON.stringify({\n  type: \"feature\",\n  complexity: \"m\",\n  clear_enough: true,\n  comment:\n    \"Thanks for the clarification! I now understand you want dark mode for all pages. Moving to specification.\",\n  labels: [],\n});\n\nconst UNCLEAR_RESPONSE = JSON.stringify({\n  type: \"feature\",\n  complexity: \"l\",\n  clear_enough: false,\n  comment:\n    \"Thanks for the update, but I still need to know: should dark mode persist across sessions?\",\n  labels: [],\n});\n\nbeforeEach(() => {\n  jest.clearAllMocks();\n  mockedTransitionLabel.mockResolvedValue(undefined);\n});\n\ndescribe(\"retriage\", () => {\n  // ── AC: Triggers on issue_comment.created ───────────\n  describe(\"triggers on issue_comment.created\", () => {\n    it(\"processes a comment event\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      const result = await retriage(ctx);\n      expect(result.status).toBe(\"success\");\n    });\n\n    it(\"logs the issue number and title\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n      expect(core.info).toHaveBeenCalledWith(\n        expect.stringContaining(\"Issue #42: Add dark mode\"),\n      );\n    });\n  });\n\n  // ── AC: Only runs if issue has kiln:intake or kiln:needs-info ──\n  // (This is handled by the router, but we verify the handler runs correctly)\n  describe(\"handles issues with intake/needs-info labels\", () => {\n    it(\"runs for issue with kiln:needs-info label\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      const result = await retriage(ctx);\n      expect(result.status).toBe(\"success\");\n      expect(mockedRunClaude).toHaveBeenCalled();\n    });\n\n    it(\"runs for issue with kiln:intake label\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx({\n        context: makeContext({\n          issuePayload: {\n            number: 42,\n            title: \"Add dark mode\",\n            body: \"I want dark mode support.\",\n            labels: [{ name: \"kiln:intake\" }],\n          },\n        }),\n      });\n      const result = await retriage(ctx);\n      expect(result.status).toBe(\"success\");\n      expect(mockedRunClaude).toHaveBeenCalled();\n    });\n  });\n\n  // ── AC: Ignores comments from bots/actions ──────────\n  describe(\"ignores bot comments\", () => {\n    it(\"ignores comments from Bot user type\", async () => {\n      const ctx = makeCtx({\n        context: makeContext({\n          commentPayload: {\n            user: { login: \"some-bot\", type: \"Bot\" },\n            body: \"Automated message\",\n          },\n        }),\n      });\n      const result = await retriage(ctx);\n\n      expect(result.status).toBe(\"success\");\n      expect(result.nextStage).toBe(\"waiting-for-info\");\n      expect(mockedRunClaude).not.toHaveBeenCalled();\n    });\n\n    it(\"ignores comments from github-actions[bot]\", async () => {\n      const ctx = makeCtx({\n        context: makeContext({\n          commentPayload: {\n            user: { login: \"github-actions[bot]\", type: \"Bot\" },\n            body: \"Kiln triage comment\",\n          },\n        }),\n      });\n      const result = await retriage(ctx);\n\n      expect(result.status).toBe(\"success\");\n      expect(result.nextStage).toBe(\"waiting-for-info\");\n      expect(mockedRunClaude).not.toHaveBeenCalled();\n    });\n\n    it(\"logs when ignoring bot comment\", async () => {\n      const ctx = makeCtx({\n        context: makeContext({\n          commentPayload: {\n            user: { login: \"some-bot\", type: \"Bot\" },\n            body: \"Automated message\",\n          },\n        }),\n      });\n      await retriage(ctx);\n\n      expect(core.info).toHaveBeenCalledWith(\n        expect.stringContaining(\"Ignoring bot comment from some-bot\"),\n      );\n    });\n\n    it(\"processes comments from regular users\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx({\n        context: makeContext({\n          commentPayload: {\n            user: { login: \"human-user\", type: \"User\" },\n            body: \"Here is the info\",\n          },\n        }),\n      });\n      const result = await retriage(ctx);\n\n      expect(result.status).toBe(\"success\");\n      expect(mockedRunClaude).toHaveBeenCalled();\n    });\n  });\n\n  // ── AC: Sends full issue body + all comments to Claude ────\n  describe(\"sends full context to Claude\", () => {\n    it(\"includes issue title, body, and comments in the prompt\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"Add dark mode\");\n      expect(prompt).toContain(\"I want dark mode support.\");\n      expect(prompt).toContain(\"@author-user\");\n      expect(prompt).toContain(\n        \"Here is the additional info you requested.\",\n      );\n    });\n\n    it(\"fetches comments from the GitHub API\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      expect(ctx.octokit.rest.issues.listComments).toHaveBeenCalledWith(\n        expect.objectContaining({\n          owner: \"test-owner\",\n          repo: \"test-repo\",\n          issue_number: 42,\n          per_page: 100,\n        }),\n      );\n    });\n\n    it(\"includes multiple comments in the prompt\", async () => {\n      const octokit = makeOctokit();\n      (octokit.rest.issues.listComments as unknown as jest.Mock).mockResolvedValue({\n        data: [\n          { user: { login: \"author\" }, body: \"First comment\" },\n          { user: { login: \"maintainer\" }, body: \"What framework?\" },\n          { user: { login: \"author\" }, body: \"Using React\" },\n        ],\n      });\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx({ octokit });\n      await retriage(ctx);\n\n      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"@author\");\n      expect(prompt).toContain(\"First comment\");\n      expect(prompt).toContain(\"@maintainer\");\n      expect(prompt).toContain(\"What framework?\");\n      expect(prompt).toContain(\"Using React\");\n    });\n\n    it(\"handles empty issue body\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx({\n        context: makeContext({\n          issuePayload: {\n            number: 42,\n            title: \"Add dark mode\",\n            body: null,\n            labels: [{ name: \"kiln:needs-info\" }],\n          },\n        }),\n      });\n      await retriage(ctx);\n\n      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n      expect(prompt).toContain(\"(empty)\");\n    });\n\n    it(\"passes anthropic key and timeout to runClaude\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx({\n        anthropicKey: \"sk-ant-custom\",\n        timeoutMinutes: 15,\n      });\n      await retriage(ctx);\n\n      expect(mockedRunClaude).toHaveBeenCalledWith(expect.any(String), {\n        anthropicKey: \"sk-ant-custom\",\n        timeoutMinutes: 15,\n      });\n    });\n\n    it(\"mentions re-triage context in the prompt\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      const prompt = mockedRunClaude.mock.calls[0][0] as string;\n      expect(prompt).toMatch(/re-?triage/i);\n    });\n  });\n\n  // ── AC: If now clear → remove needs-info, apply specifying ──\n  describe(\"clear_enough is true\", () => {\n    it(\"transitions from needs-info to specifying\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      expect(mockedTransitionLabel).toHaveBeenCalledWith(\n        ctx.octokit,\n        ctx.context,\n        42,\n        \"needs-info\",\n        \"specifying\",\n        \"kiln\",\n      );\n    });\n\n    it(\"returns nextStage: specify\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      const result = await retriage(ctx);\n\n      expect(result.nextStage).toBe(\"specify\");\n    });\n\n    it(\"posts confirmation comment\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n        expect.objectContaining({\n          issue_number: 42,\n          body: expect.stringContaining(\n            \"Thanks for the clarification\",\n          ),\n        }),\n      );\n    });\n\n    it(\"uses custom label prefix\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx({ config: makeConfig(\"myapp\") });\n      await retriage(ctx);\n\n      expect(mockedTransitionLabel).toHaveBeenCalledWith(\n        expect.anything(),\n        expect.anything(),\n        42,\n        \"needs-info\",\n        \"specifying\",\n        \"myapp\",\n      );\n    });\n  });\n\n  // ── AC: If still unclear → keep needs-info, post follow-up ──\n  describe(\"clear_enough is false\", () => {\n    it(\"does NOT transition labels\", async () => {\n      mockedRunClaude.mockReturnValue(UNCLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      expect(mockedTransitionLabel).not.toHaveBeenCalled();\n    });\n\n    it(\"returns nextStage: waiting-for-info\", async () => {\n      mockedRunClaude.mockReturnValue(UNCLEAR_RESPONSE);\n      const ctx = makeCtx();\n      const result = await retriage(ctx);\n\n      expect(result.nextStage).toBe(\"waiting-for-info\");\n    });\n\n    it(\"posts follow-up clarification request\", async () => {\n      mockedRunClaude.mockReturnValue(UNCLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n        expect.objectContaining({\n          issue_number: 42,\n          body: expect.stringContaining(\n            \"should dark mode persist across sessions\",\n          ),\n        }),\n      );\n    });\n\n    it(\"keeps kiln:needs-info label (no label changes)\", async () => {\n      mockedRunClaude.mockReturnValue(UNCLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      // No label transitions should happen\n      expect(mockedTransitionLabel).not.toHaveBeenCalled();\n      // No addLabels calls for needs-info (it's already there)\n      expect(ctx.octokit.rest.issues.addLabels).not.toHaveBeenCalled();\n    });\n  });\n\n  // ── AC: Posts Kiln-branded comment ────────────────────\n  describe(\"branded comment\", () => {\n    it(\"posts a Kiln-branded re-triage comment\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      expect(ctx.octokit.rest.issues.createComment).toHaveBeenCalledWith(\n        expect.objectContaining({\n          body: expect.stringMatching(/^🔥 \\*\\*Kiln Re-triage\\*\\*/),\n        }),\n      );\n    });\n  });\n\n  // ── JSON parsing ───────────────────────────────────────\n  describe(\"parses Claude JSON response\", () => {\n    it(\"parses JSON from code block\", async () => {\n      mockedRunClaude.mockReturnValue(\n        '```json\\n{\"type\":\"bug\",\"complexity\":\"s\",\"clear_enough\":true,\"comment\":\"Got it.\",\"labels\":[]}\\n```',\n      );\n      const ctx = makeCtx();\n      const result = await retriage(ctx);\n      expect(result.status).toBe(\"success\");\n      expect(result.nextStage).toBe(\"specify\");\n    });\n\n    it(\"parses raw JSON without code block\", async () => {\n      mockedRunClaude.mockReturnValue(CLEAR_RESPONSE);\n      const ctx = makeCtx();\n      const result = await retriage(ctx);\n      expect(result.status).toBe(\"success\");\n    });\n\n    it(\"falls back to defaults on parse failure\", async () => {\n      mockedRunClaude.mockReturnValue(\"This is not JSON at all\");\n      const ctx = makeCtx();\n      const result = await retriage(ctx);\n\n      expect(result.status).toBe(\"success\");\n      expect(core.warning).toHaveBeenCalledWith(\n        expect.stringContaining(\"Failed to parse re-triage response\"),\n      );\n      // Default: clear_enough=true → moves to specify\n      expect(result.nextStage).toBe(\"specify\");\n    });\n\n    it(\"logs raw output on parse failure\", async () => {\n      mockedRunClaude.mockReturnValue(\"garbage output\");\n      const ctx = makeCtx();\n      await retriage(ctx);\n\n      expect(core.warning).toHaveBeenCalledWith(\n        expect.stringContaining(\"Raw output: garbage output\"),\n      );\n    });\n  });\n});\n","numLines":468,"startLine":1,"totalLines":468}}}
