esult!.issueNumber).toBe(7);\n    48→      expect(result!.labels).toEqual([\"kiln:intake\"]);\n    49→    });\n    50→\n    51→    it(\"returns re-triage when issue has kiln:needs-info label\", () => {\n    52→      const ctx = makeContext(\"issue_comment\", {\n    53→        action: \"created\",\n    54→        issue: { number: 8, labels: [{ name: \"kiln:needs-info\" }] },\n    55→      });\n    56→      const result = detectStage(ctx);\n    57→      expect(result).not.toBeNull();\n    58→      expect(result!.stage).toBe(\"re-triage\");\n    59→    });\n    60→\n    61→    it(\"returns null when issue has no matching labels\", () => {\n    62→      const ctx = makeContext(\"issue_comment\", {\n    63→        action: \"created\",\n    64→        issue: { number: 9, labels: [{ name: \"bug\" }] },\n    65→      });\n    66→      const result = detectStage(ctx);\n    67→      expect(result).toBeNull();\n    68→    });\n    69→  });\n    70→\n    71→  // ── issues.labeled (kiln:specifying) → specify ────────\n    72→  describe(\"issues.labeled → specify\", () => {\n    73→    it(\"returns specify when kiln:specifying label is added\", () => {\n    74→      const ctx = makeContext(\"issues\", {\n    75→        action: \"labeled\",\n    76→        label: { name: \"kiln:specifying\" },\n    77→        issue: { number: 10, labels: [{ name: \"kiln:specifying\" }] },\n    78→      });\n    79→      const result = detectStage(ctx);\n    80→      expect(result).not.toBeNull();\n    81→      expect(result!.stage).toBe(\"specify\");\n    82→      expect(result!.issueNumber).toBe(10);\n    83→    });\n    84→  });\n    85→\n    86→  // ── issues.labeled (kiln:implementing) → implement ────\n    87→  describe(\"issues.labeled → implement\", () => {\n    88→    it(\"returns implement when kiln:implementing label is added\", () => {\n    89→      const ctx = makeContext(\"issues\", {\n    90→        action: \"labeled\",\n    91→        label: { name: \"kiln:implementing\" },\n    92→