{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SJPYg4Yh2qzntp6VouybB1","type":"tool_result","content":"     1→import triage from \"./triage\";\n     2→import { KilnContext, KilnConfig, Octokit } from \"../types\";\n     3→import { Context } from \"@actions/github/lib/context\";\n     4→\n     5→jest.mock(\"@actions/core\");\n     6→jest.mock(\"../claude\");\n     7→jest.mock(\"../labels\");\n     8→\n     9→import * as core from \"@actions/core\";\n    10→import { runClaude } from \"../claude\";\n    11→import { transitionLabel } from \"../labels\";\n    12→\n    13→const mockedRunClaude = runClaude as unknown as jest.Mock;\n    14→const mockedTransitionLabel = transitionLabel as unknown as jest.Mock;\n    15→\n    16→function makeOctokit(): Octokit {\n    17→  return {\n    18→    rest: {\n    19→      issues: {\n    20→        createComment: jest.fn().mockResolvedValue({}),\n    21→        addLabels: jest.fn().mockResolvedValue({}),\n    22→      },\n    23→    },\n    24→  } as unknown as Octokit;\n    25→}\n    26→\n    27→function makeConfig(prefix = \"kiln\"): KilnConfig {\n    28→  return { labels: { prefix } } as unknown as KilnConfig;\n    29→}\n    30→\n    31→function makeContext(issuePayload: Record<string, unknown>): Context {\n    32→  return {\n    33→    eventName: \"issues\",\n    34→    payload: {\n    35→      action: \"opened\",\n    36→      issue: issuePayload,\n    37→    },\n    38→    repo: { owner: \"test-owner\", repo: \"test-repo\" },\n    39→  } as unknown as Context;\n    40→}\n    41→\n    42→function makeCtx(overrides: Partial<KilnContext> = {}): KilnContext {\n    43→  return {\n    44→    octokit: makeOctokit(),\n    45→    context: makeContext({\n    46→      number: 1,\n    47→      title: \"Add dark mode\",\n    48→      body: \"I want dark mode support for the app.\",\n    49→      labels: [],\n    50→    }),\n    51→    config: makeConfig(),\n    52→    anthropicKey: \"sk-ant-test-key\",\n    53→    