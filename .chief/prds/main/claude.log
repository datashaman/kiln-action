tation PR)`,\n      );\n      return result;\n    }\n\n    // Impl PR: approved → release\n    if (\n      state === \"approved\" &&\n      prLabels.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      const result: RouteResult = {\n        stage: \"release\",\n        prNumber,\n        labels: prLabels,\n        payload: payload as unknown as Record<string, unknown>,\n      };\n      core.info(\n        `🔥 Kiln Router — Matched stage: release (pull_request_review.submitted approved on implementation PR)`,\n      );\n      return result;\n    }\n  }\n\n  // ── Check Suite (CI) Events ───────────────────────────\n  if (eventName === \"check_suite\" && payload.action === \"completed\") {\n    const prs =\n      (payload.check_suite?.pull_requests as Array<unknown>) || [];\n    if (prs.length > 0) {\n      const result: RouteResult = {\n        stage: \"release\",\n        labels: [],\n        payload: payload as unknown as Record<string, unknown>,\n      };\n      core.info(\n        `🔥 Kiln Router — Matched stage: release (check_suite.completed with associated PRs)`,\n      );\n      return result;\n    }\n  }\n\n  core.info(\n    `🔥 Kiln Router — No matching stage for event: ${eventName}.${payload.action || \"\"}`,\n  );\n  return null;\n}\n\nfunction extractLabels(\n  labels: unknown,\n): string[] {\n  if (!Array.isArray(labels)) return [];\n  return labels.map((l: { name: string }) => l.name);\n}\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":6,"lines":["+import * as core from \"@actions/core\";"," import { Context } from \"@actions/github/lib/context\";","+import { RouteResult } from \"./types\";"," "," /**","  * Detects which Kiln stage to run based on the GitHub event."]},{"oldStart":6,"oldLines":90,"newStart":8,"newLines":167,"lines":["  * Event → Stage mapping:","  *","  *   issues.opened                                        → triage","+ *   issue_comment.created (kiln:intake or kiln:needs-info) → re-triage","  *   issues.