{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018KaC1Bg9KrRpb45FCkQxVW","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import { Context } from \"@actions/github/lib/context\";\n     3→import { Octokit, KilnConfig } from \"./types\";\n     4→\n     5→const LABEL_DEFS = [\n     6→  {\n     7→    suffix: \"intake\",\n     8→    color: \"c5def5\",\n     9→    description: \"Kiln: issue received, awaiting triage\",\n    10→  },\n    11→  {\n    12→    suffix: \"needs-info\",\n    13→    color: \"fbca04\",\n    14→    description: \"Kiln: waiting for clarification from author\",\n    15→  },\n    16→  {\n    17→    suffix: \"specifying\",\n    18→    color: \"c5def5\",\n    19→    description: \"Kiln: spec agent is writing the spec\",\n    20→  },\n    21→  { suffix: \"spec\", color: \"c5def5\", description: \"Kiln: spec PR\" },\n    22→  {\n    23→    suffix: \"spec-review\",\n    24→    color: \"fbca04\",\n    25→    description: \"Kiln: waiting for human spec approval\",\n    26→  },\n    27→  {\n    28→    suffix: \"implementing\",\n    29→    color: \"0e8a16\",\n    30→    description: \"Kiln: code agent is building\",\n    31→  },\n    32→  {\n    33→    suffix: \"implementation\",\n    34→    color: \"0e8a16\",\n    35→    description: \"Kiln: implementation PR\",\n    36→  },\n    37→  {\n    38→    suffix: \"in-review\",\n    39→    color: \"e4e669\",\n    40→    description: \"Kiln: under AI code review\",\n    41→  },\n    42→  {\n    43→    suffix: \"done\",\n    44→    color: \"0e8a16\",\n    45→    description: \"Kiln: shipped and closed\",\n    46→  },\n    47→  {\n    48→    suffix: \"blocked\",\n    49→    color: \"d93f0b\",\n    50→    description: \"Kiln: emergency stop — all automation halts\",\n    51→  },\n    52→];\n    53→\n    54→export async function ensureLabels(\n    55→  octokit: Octokit,\n    56→  context: Context,\n    57→  config: KilnConfig,\n    58→): Promise<void> {\n    59→  const prefix = config.labels?.prefix || \"kiln\";\n    60→\n    61→  const { data: existing } = await octokit.rest.issues.listLabelsForRepo({\n    62→    ...context.repo,\n    63→    per_page: 100,\n    64→  });\n    65→  const existingNames = new Set(existing.map((l) => l.name));\n    66→\n    67→  for (const def of LABEL_DEFS) {\n    68→    const name = `${prefix}:${def.suffix}`;\n    69→    if (!existingNames.has(name)) {\n    70→      try {\n    71→        await octokit.rest.issues.createLabel({\n    72→          ...context.repo,\n    73→          name,\n    74→          color: def.color,\n    75→          description: def.description,\n    76→        });\n    77→        core.info(`Created label: ${name}`);\n    78→      } catch (error) {\n    79→        const message = error instanceof Error ? error.message : String(error);\n    80→        core.warning(`Failed to create label ${name}: ${message}`);\n    81→      }\n    82→    }\n    83→  }\n    84→}\n    85→\n    86→export async function transitionLabel(\n    87→  octokit: Octokit,\n    88→  context: Context,\n    89→  issueNumber: number,\n    90→  fromSuffix: string | null,\n    91→  toSuffix: string,\n    92→  prefix: string,\n    93→): Promise<void> {\n    94→  if (fromSuffix) {\n    95→    const oldLabel = `${prefix}:${fromSuffix}`;\n    96→    try {\n    97→      await octokit.rest.issues.removeLabel({\n    98→        ...context.repo,\n    99→        issue_number: issueNumber,\n   100→        name: oldLabel,\n   101→      });\n   102→    } catch {\n   103→      // Label might not exist, that's fine\n   104→    }\n   105→  }\n   106→\n   107→  const newLabel = `${prefix}:${toSuffix}`;\n   108→  await octokit.rest.issues.addLabels({\n   109→    ...context.repo,\n   110→    issue_number: issueNumber,\n   111→    labels: [newLabel],\n   112→  });\n   113→}\n   114→"}]},"parent_tool_use_id":null,"session_id":"c724d35f-7b14-4623-85ef-5de838552fab","uuid":"8fd5498a-5963-4d2a-8466-990552f3d65e","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/labels.ts","content":"import * as core from \"@actions/core\";\nimport { Context } from \"@actions/github/lib/context\";\nimport { Octokit, KilnConfig } from \"./types\";\n\nconst LABEL_DEFS = [\n  {\n    suffix: \"intake\",\n    color: \"c5def5\",\n    description: \"Kiln: issue received, awaiting triage\",\n  },\n  {\n    suffix: \"needs-info\",\n    color: \"fbca04\",\n    description: \"Kiln: waiting for clarification from author\",\n  },\n  {\n    suffix: \"specifying\",\n    color: \"c5def5\",\n    description: \"Kiln: spec agent is writing the spec\",\n  },\n  { suffix: \"spec\", color: \"c5def5\", description: \"Kiln: spec PR\" },\n  {\n    suffix: \"spec-review\",\n    color: \"fbca04\",\n    description: \"Kiln: waiting for human spec approval\",\n  },\n  {\n    suffix: \"implementing\",\n    color: \"0e8a16\",\n    description: \"Kiln: code agent is building\",\n  },\n  {\n    suffix: \"implementation\",\n    color: \"0e8a16\",\n    description: \"Kiln: implementation PR\",\n  },\n  {\n    suffix: \"in-review\",\n    color: \"e4e669\",\n    description: \"Kiln: under AI code review\",\n  },\n  {\n    suffix: \"done\",\n    color: \"0e8a16\",\n    description: \"Kiln: shipped and closed\",\n  },\n  {\n    suffix: \"blocked\",\n    color: \"d93f0b\",\n    description: \"Kiln: emergency stop — all automation halts\",\n  },\n];\n\nexport async function ensureLabels(\n  octokit: Octokit,\n  context: Context,\n  config: KilnConfig,\n): Promise<void> {\n  const prefix = config.labels?.prefix || \"kiln\";\n\n  const { data: existing } = await octokit.rest.issues.listLabelsForRepo({\n    ...context.repo,\n    per_page: 100,\n  });\n  const existingNames = new Set(existing.map((l) => l.name));\n\n  for (const def of LABEL_DEFS) {\n    const name = `${prefix}:${def.suffix}`;\n    if (!existingNames.has(name)) {\n      try {\n        await octokit.rest.issues.createLabel({\n          ...context.repo,\n          name,\n          color: def.color,\n          description: def.description,\n        });\n        core.info(`Created label: ${name}`);\n      } catch (error) {\n        const message = error instanceof Error ? error.message : String(error);\n        core.warning(`Failed to create label ${name}: ${message}`);\n      }\n    }\n  }\n}\n\nexport async function transitionLabel(\n  octokit: Octokit,\n  context: Context,\n  issueNumber: number,\n  fromSuffix: string | null,\n  toSuffix: string,\n  prefix: string,\n): Promise<void> {\n  if (fromSuffix) {\n    const oldLabel = `${prefix}:${fromSuffix}`;\n    try {\n      await octokit.rest.issues.removeLabel({\n        ...context.repo,\n        issue_number: issueNumber,\n        name: oldLabel,\n      });\n    } catch {\n      // Label might not exist, that's fine\n    }\n  }\n\n  const newLabel = `${prefix}:${toSuffix}`;\n  await octokit.rest.issues.addLabels({\n    ...context.repo,\n    issue_number: issueNumber,\n    labels: [newLabel],\n  });\n}\n","numLines":114,"startLine":1,"totalLines":114}}}
