{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0132DdHdCJMhJTxkutPzycCd","type":"tool_result","content":"     1→import { checkBlocked } from \"./blocked\";\n     2→import { Context } from \"@actions/github/lib/context\";\n     3→import { KilnConfig, Octokit } from \"./types\";\n     4→\n     5→function makeOctokit(overrides: {\n     6→  issueLabels?: Array<{ name: string }>;\n     7→  getThrows?: boolean;\n     8→} = {}): Octokit {\n     9→  const createComment = jest.fn().mockResolvedValue({});\n    10→  const get = overrides.getThrows\n    11→    ? jest.fn().mockRejectedValue(new Error(\"Not found\"))\n    12→    : jest.fn().mockResolvedValue({\n    13→        data: { labels: overrides.issueLabels || [] },\n    14→      });\n    15→\n    16→  return {\n    17→    rest: {\n    18→      issues: { createComment, get },\n    19→    },\n    20→  } as unknown as Octokit;\n    21→}\n    22→\n    23→function makeConfig(prefix = \"kiln\"): KilnConfig {\n    24→  return { labels: { prefix } } as unknown as KilnConfig;\n    25→}\n    26→\n    27→function makeContext(\n    28→  eventName: string,\n    29→  payload: Record<string, unknown>,\n    30→): Context {\n    31→  return {\n    32→    eventName,\n    33→    payload,\n    34→    repo: { owner: \"test-owner\", repo: \"test-repo\" },\n    35→  } as unknown as Context;\n    36→}\n    37→\n    38→describe(\"checkBlocked\", () => {\n    39→  // ── Issue events ───────────────────────────────────────\n    40→  describe(\"issue events\", () => {\n    41→    it(\"returns true when issue has kiln:blocked label\", async () => {\n    42→      const octokit = makeOctokit();\n    43→      const ctx = makeContext(\"issues\", {\n    44→        action: \"opened\",\n    45→        issue: {\n    46→          number: 1,\n    47→          labels: [{ name: \"kiln:blocked\" }],\n    48→        },\n    49→      });\n    50→      const result = await checkBlocked(octokit, ctx, makeConfig());\n    51→      expect(result).toBe(true);\n    52→    });\n    53→\n    54→    it(\"posts a comment when issue is blocked\", async () => {\n    55→      const octokit = makeOctokit();\n    56→      const ctx = makeContext(\"issues\", {\n    57→        action: \"opened\",\n    58→        issue: {\n    59→          number: 1,\n    60→          labels: [{ name: \"kiln:blocked\" }],\n    61→        },\n    62→      });\n    63→      await checkBlocked(octokit, ctx, makeConfig());\n    64→      expect(octokit.rest.issues.createComment).toHaveBeenCalledWith({\n    65→        owner: \"test-owner\",\n    66→        repo: \"test-repo\",\n    67→        issue_number: 1,\n    68→        body: \"🔥 **Kiln** — Automation is blocked on this item. Remove kiln:blocked to resume.\",\n    69→      });\n    70→    });\n    71→\n    72→    it(\"returns false when issue does not have kiln:blocked label\", async () => {\n    73→      const octokit = makeOctokit();\n    74→      const ctx = makeContext(\"issues\", {\n    75→        action: \"opened\",\n    76→        issue: {\n    77→          number: 2,\n    78→          labels: [{ name: \"bug\" }, { name: \"kiln:intake\" }],\n    79→        },\n    80→      });\n    81→      const result = await checkBlocked(octokit, ctx, makeConfig());\n    82→      expect(result).toBe(false);\n    83→    });\n    84→\n    85→    it(\"returns false when no issue in payload\", async () => {\n    86→      const octokit = makeOctokit();\n    87→      const ctx = makeContext(\"push\", {});\n    88→      const result = await checkBlocked(octokit, ctx, makeConfig());\n    89→      expect(result).toBe(false);\n    90→    });\n    91→\n    92→    it(\"does not post a comment when not blocked\", async () => {\n    93→      const octokit = makeOctokit();\n    94→      const ctx = makeContext(\"issues\", {\n    95→        action: \"opened\",\n    96→        issue: { number: 3, labels: [] },\n    97→      });\n    98→      await checkBlocked(octokit, ctx, makeConfig());\n    99→      expect(octokit.rest.issues.createComment).not.toHaveBeenCalled();\n   100→    });\n   101→  });\n   102→\n   103→  // ── PR events — PR labels ─────────────────────────────\n   104→  describe(\"PR events — PR labels\", () => {\n   105→    it(\"returns true when PR has kiln:blocked label\", async () => {\n   106→      const octokit = makeOctokit();\n   107→      const ctx = makeContext(\"pull_request\", {\n   108→        action: \"opened\",\n   109→        pull_request: {\n   110→          number: 10,\n   111→          labels: [{ name: \"kiln:implementation\" }, { name: \"kiln:blocked\" }],\n   112→          body: \"Closes #5\",\n   113→        },\n   114→      });\n   115→      const result = await checkBlocked(octokit, ctx, makeConfig());\n   116→      expect(result).toBe(true);\n   117→    });\n   118→\n   119→    it(\"posts a comment on the PR when PR is blocked via PR labels\", async () => {\n   120→      const octokit = makeOctokit();\n   121→      const ctx = makeContext(\"pull_request\", {\n   122→        action: \"opened\",\n   123→        pull_request: {\n   124→          number: 10,\n   125→          labels: [{ name: \"kiln:blocked\" }],\n   126→          body: \"Closes #5\",\n   127→        },\n   128→      });\n   129→      await checkBlocked(octokit, ctx, makeConfig());\n   130→      expect(octokit.rest.issues.createComment).toHaveBeenCalledWith(\n   131→        expect.objectContaining({ issue_number: 10 }),\n   132→      );\n   133→    });\n   134→\n   135→    it(\"returns false when PR has no kiln:blocked label\", async () => {\n   136→      const octokit = makeOctokit();\n   137→      const ctx = makeContext(\"pull_request\", {\n   138→        action: \"opened\",\n   139→        pull_request: {\n   140→          number: 11,\n   141→          labels: [{ name: \"kiln:implementation\" }],\n   142→          body: \"Some PR body\",\n   143→        },\n   144→      });\n   145→      const result = await checkBlocked(octokit, ctx, makeConfig());\n   146→      expect(result).toBe(false);\n   147→    });\n   148→  });\n   149→\n   150→  // ── PR events — linked issue labels ───────────────────\n   151→  describe(\"PR events — linked issue labels\", () => {\n   152→    it(\"returns true when linked issue has kiln:blocked label\", async () => {\n   153→      const octokit = makeOctokit({\n   154→        issueLabels: [{ name: \"kiln:blocked\" }],\n   155→      });\n   156→      const ctx = makeContext(\"pull_request_review\", {\n   157→        action: \"submitted\",\n   158→        review: { state: \"approved\" },\n   159→        pull_request: {\n   160→          number: 20,\n   161→          labels: [{ name: \"kiln:implementation\" }],\n   162→          body: \"Closes #7\",\n   163→        },\n   164→      });\n   165→      const result = await checkBlocked(octokit, ctx, makeConfig());\n   166→      expect(result).toBe(true);\n   167→    });\n   168→\n   169→    it(\"posts a comment on the PR when blocked via linked issue\", async () => {\n   170→      const octokit = makeOctokit({\n   171→        issueLabels: [{ name: \"kiln:blocked\" }],\n   172→      });\n   173→      const ctx = makeContext(\"pull_request_review\", {\n   174→        action: \"submitted\",\n   175→        review: { state: \"approved\" },\n   176→        pull_request: {\n   177→          number: 20,\n   178→          labels: [{ name: \"kiln:implementation\" }],\n   179→          body: \"Closes #7\",\n   180→        },\n   181→      });\n   182→      await checkBlocked(octokit, ctx, makeConfig());\n   183→      expect(octokit.rest.issues.createComment).toHaveBeenCalledWith(\n   184→        expect.objectContaining({ issue_number: 20 }),\n   185→      );\n   186→    });\n   187→\n   188→    it(\"fetches the linked issue using the issue number from PR body\", async () => {\n   189→      const octokit = makeOctokit({ issueLabels: [] });\n   190→      const ctx = makeContext(\"pull_request\", {\n   191→        action: \"opened\",\n   192→        pull_request: {\n   193→          number: 21,\n   194→          labels: [],\n   195→          body: \"Closes #42\",\n   196→        },\n   197→      });\n   198→      await checkBlocked(octokit, ctx, makeConfig());\n   199→      expect(octokit.rest.issues.get).toHaveBeenCalledWith({\n   200→        owner: \"test-owner\",\n   201→        repo: \"test-repo\",\n   202→        issue_number: 42,\n   203→      });\n   204→    });\n   205→\n   206→    it(\"returns false when linked issue does not have kiln:blocked\", async () => {\n   207→      const octokit = makeOctokit({\n   208→        issueLabels: [{ name: \"kiln:implementing\" }],\n   209→      });\n   210→      const ctx = makeContext(\"pull_request\", {\n   211→        action: \"opened\",\n   212→        pull_request: {\n   213→          number: 22,\n   214→          labels: [],\n   215→          body: \"Closes #8\",\n   216→        },\n   217→      });\n   218→      const result = await checkBlocked(octokit, ctx, makeConfig());\n   219→      expect(result).toBe(false);\n   220→    });\n   221→\n   222→    it(\"returns false when issue fetch fails\", async () => {\n   223→      const octokit = makeOctokit({ getThrows: true });\n   224→      const ctx = makeContext(\"pull_request\", {\n   225→        action: \"opened\",\n   226→        pull_request: {\n   227→          number: 23,\n   228→          labels: [],\n   229→          body: \"Closes #999\",\n   230→        },\n   231→      });\n   232→      const result = await checkBlocked(octokit, ctx, makeConfig());\n   233→      expect(result).toBe(false);\n   234→    });\n   235→\n   236→    it(\"returns false when PR body has no Closes reference\", async () => {\n   237→      const octokit = makeOctokit();\n   238→      const ctx = makeContext(\"pull_request\", {\n   239→        action: \"opened\",\n   240→        pull_request: {\n   241→          number: 24,\n   242→          labels: [],\n   243→          body: \"Just a regular PR\",\n   244→        },\n   245→      });\n   246→      const result = await checkBlocked(octokit, ctx, makeConfig());\n   247→      expect(result).toBe(false);\n   248→    });\n   249→  });\n   250→\n   251→  // ── Custom label prefix ────────────────────────────────\n   252→  describe(\"custom label prefix\", () => {\n   253→    it(\"uses custom prefix for blocked label check\", async () => {\n   254→      const octokit = makeOctokit();\n   255→      const ctx = makeContext(\"issues\", {\n   256→        action: \"opened\",\n   257→        issue: {\n   258→          number: 30,\n   259→          labels: [{ name: \"myprefix:blocked\" }],\n   260→        },\n   261→      });\n   262→      const result = await checkBlocked(octokit, ctx, makeConfig(\"myprefix\"));\n   263→      expect(result).toBe(true);\n   264→    });\n   265→\n   266→    it(\"does not match kiln:blocked when prefix is custom\", async () => {\n   267→      const octokit = makeOctokit();\n   268→      const ctx = makeContext(\"issues\", {\n   269→        action: \"opened\",\n   270→        issue: {\n   271→          number: 31,\n   272→          labels: [{ name: \"kiln:blocked\" }],\n   273→        },\n   274→      });\n   275→      const result = await checkBlocked(octokit, ctx, makeConfig(\"myprefix\"));\n   276→      expect(result).toBe(false);\n   277→    });\n   278→  });\n   279→\n   280→  // ── All stages covered ─────────────────────────────────\n   281→  describe(\"covers all stages\", () => {\n   282→    it(\"blocks triage (issues.opened)\", async () => {\n   283→      const octokit = makeOctokit();\n   284→      const ctx = makeContext(\"issues\", {\n   285→        action: \"opened\",\n   286→        issue: { number: 40, labels: [{ name: \"kiln:blocked\" }] },\n   287→      });\n   288→      expect(await checkBlocked(octokit, ctx, makeConfig())).toBe(true);\n   289→    });\n   290→\n   291→    it(\"blocks re-triage (issue_comment.created)\", async () => {\n   292→      const octokit = makeOctokit();\n   293→      const ctx = makeContext(\"issue_comment\", {\n   294→        action: \"created\",\n   295→        issue: {\n   296→          number: 41,\n   297→          labels: [{ name: \"kiln:needs-info\" }, { name: \"kiln:blocked\" }],\n   298→        },\n   299→      });\n   300→      expect(await checkBlocked(octokit, ctx, makeConfig())).toBe(true);\n   301→    });\n   302→\n   303→    it(\"blocks specify (issues.labeled)\", async () => {\n   304→      const octokit = makeOctokit();\n   305→      const ctx = makeContext(\"issues\", {\n   306→        action: \"labeled\",\n   307→        label: { name: \"kiln:specifying\" },\n   308→        issue: { number: 42, labels: [{ name: \"kiln:blocked\" }] },\n   309→      });\n   310→      expect(await checkBlocked(octokit, ctx, makeConfig())).toBe(true);\n   311→    });\n   312→\n   313→    it(\"blocks review (pull_request.opened)\", async () => {\n   314→      const octokit = makeOctokit();\n   315→      const ctx = makeContext(\"pull_request\", {\n   316→        action: \"opened\",\n   317→        pull_request: {\n   318→          number: 43,\n   319→          labels: [{ name: \"kiln:implementation\" }, { name: \"kiln:blocked\" }],\n   320→          body: \"\",\n   321→        },\n   322→      });\n   323→      expect(await checkBlocked(octokit, ctx, makeConfig())).toBe(true);\n   324→    });\n   325→\n   326→    it(\"blocks fix (pull_request_review.submitted changes_requested)\", async () => {\n   327→      const octokit = makeOctokit();\n   328→      const ctx = makeContext(\"pull_request_review\", {\n   329→        action: \"submitted\",\n   330→        review: { state: \"changes_requested\" },\n   331→        pull_request: {\n   332→          number: 44,\n   333→          labels: [{ name: \"kiln:blocked\" }],\n   334→          body: \"\",\n   335→        },\n   336→      });\n   337→      expect(await checkBlocked(octokit, ctx, makeConfig())).toBe(true);\n   338→    });\n   339→\n   340→    it(\"blocks release (pull_request_review.submitted approved)\", async ()