{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JuFPu55fd2Diia2FV9yMW6","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import * as fs from \"fs\";\n     3→import * as yaml from \"js-yaml\";\n     4→import { KilnConfig } from \"./types\";\n     5→\n     6→const DEFAULTS: KilnConfig = {\n     7→  protected_paths: [\".github/\", \".env\", \"CLAUDE.md\", \".kiln/\"],\n     8→  human_review: {\n     9→    spec: \"required\",\n    10→    implementation: \"auto\",\n    11→  },\n    12→  auto_merge: true,\n    13→  timeout_minutes: 30,\n    14→  labels: {\n    15→    prefix: \"kiln\",\n    16→  },\n    17→  agents: {\n    18→    triage: { enabled: true },\n    19→    spec: { enabled: true },\n    20→    implement: { enabled: true, run_tests: true, run_lint: true },\n    21→    review: { enabled: true, auto_approve: false },\n    22→    fix: { enabled: true, max_iterations: 3 },\n    23→  },\n    24→};\n    25→\n    26→export async function loadConfig(configPath: string): Promise<KilnConfig> {\n    27→  if (!fs.existsSync(configPath)) {\n    28→    core.info(`No config found at ${configPath}, using defaults.`);\n    29→    return DEFAULTS;\n    30→  }\n    31→\n    32→  try {\n    33→    const raw = fs.readFileSync(configPath, \"utf-8\");\n    34→    const userConfig = (yaml.load(raw) || {}) as Record<string, unknown>;\n    35→    return deepMerge(\n    36→      DEFAULTS as unknown as Record<string, unknown>,\n    37→      userConfig,\n    38→    ) as unknown as KilnConfig;\n    39→  } catch (error) {\n    40→    const message = error instanceof Error ? error.message : String(error);\n    41→    core.warning(`Failed to parse config at ${configPath}: ${message}`);\n    42→    return DEFAULTS;\n    43→  }\n    44→}\n    45→\n    46→function deepMerge(\n    47→  target: Record<string, unknown>,\n    48→  source: Record<string, unknown>,\n    49→): Record<string, unknown> {\n    50→  const result = { ...target };\n    51→  for (const key of Object.keys(source)) {\n    52→    if (\n    53→      source[key] &&\n    54→      typeof source[key] === \"object\" &&\n    55→      !Array.isArray(source[key]) &&\n    56→      target[key] &&\n    57→      typeof target[key] === \"object\" &&\n    58→      !Array.isArray(target[key])\n    59→    ) {\n    60→      result[key] = deepMerge(\n    61→        target[key] as Record<string, unknown>,\n    62→        source[key] as Record<string, unknown>,\n    63→      );\n    64→    } else {\n    65→      result[key] = source[key];\n    66→    }\n    67→  }\n    68→  return result;\n    69→}\n    70→"}]},"parent_tool_use_id":null,"session_id":"cab57a4f-e8df-4648-9c51-7e23a35b2ad7","uuid":"61434dd9-d8db-40e6-9067-e21da666a7bb","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/config.ts","content":"import * as core from \"@actions/core\";\nimport * as fs from \"fs\";\nimport * as yaml from \"js-yaml\";\nimport { KilnConfig } from \"./types\";\n\nconst DEFAULTS: KilnConfig = {\n  protected_paths: [\".github/\", \".env\", \"CLAUDE.md\", \".kiln/\"],\n  human_review: {\n    spec: \"required\",\n    implementation: \"auto\",\n  },\n  auto_merge: true,\n  timeout_minutes: 30,\n  labels: {\n    prefix: \"kiln\",\n  },\n  agents: {\n    triage: { enabled: true },\n    spec: { enabled: true },\n    implement: { enabled: true, run_tests: true, run_lint: true },\n    review: { enabled: true, auto_approve: false },\n    fix: { enabled: true, max_iterations: 3 },\n  },\n};\n\nexport async function loadConfig(configPath: string): Promise<KilnConfig> {\n  if (!fs.existsSync(configPath)) {\n    core.info(`No config found at ${configPath}, using defaults.`);\n    return DEFAULTS;\n  }\n\n  try {\n    const raw = fs.readFileSync(configPath, \"utf-8\");\n    const userConfig = (yaml.load(raw) || {}) as Record<string, unknown>;\n    return deepMerge(\n      DEFAULTS as unknown as Record<string, unknown>,\n      userConfig,\n    ) as unknown as KilnConfig;\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.warning(`Failed to parse config at ${configPath}: ${message}`);\n    return DEFAULTS;\n  }\n}\n\nfunction deepMerge(\n  target: Record<string, unknown>,\n  source: Record<string, unknown>,\n): Record<string, unknown> {\n  const result = { ...target };\n  for (const key of Object.keys(source)) {\n    if (\n      source[key] &&\n      typeof source[key] === \"object\" &&\n      !Array.isArray(source[key]) &&\n      target[key] &&\n      typeof target[key] === \"object\" &&\n      !Array.isArray(target[key])\n    ) {\n      result[key] = deepMerge(\n        target[key] as Record<string, unknown>,\n        source[key] as Record<string, unknown>,\n      );\n    } else {\n      result[key] = source[key];\n    }\n  }\n  return result;\n}\n","numLines":70,"startLine":1,"totalLines":70}}}
