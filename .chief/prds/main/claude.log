{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Wr1uzq1XCJE3zYZkAMJ3bc","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import * as github from \"@actions/github\";\n     3→import { checkBlocked } from \"./blocked\";\n     4→import { loadConfig } from \"./config\";\n     5→import { ensureLabels } from \"./labels\";\n     6→import { detectStage } from \"./router\";\n     7→import { KilnContext, StageResult } from \"./types\";\n     8→\n     9→import triage from \"./stages/triage\";\n    10→import specify from \"./stages/specify\";\n    11→import approveSpec from \"./stages/approve-spec\";\n    12→import implement from \"./stages/implement\";\n    13→import review from \"./stages/review\";\n    14→import fix from \"./stages/fix\";\n    15→import ship from \"./stages/ship\";\n    16→\n    17→type StageHandler = (ctx: KilnContext) => Promise<StageResult>;\n    18→\n    19→const STAGES: Record<string, StageHandler> = {\n    20→  triage,\n    21→  \"re-triage\": triage,\n    22→  specify,\n    23→  \"approve-spec\": approveSpec,\n    24→  implement,\n    25→  review,\n    26→  fix,\n    27→  release: ship,\n    28→};\n    29→\n    30→async function run(): Promise<void> {\n    31→  try {\n    32→    const token = core.getInput(\"github_token\");\n    33→    const anthropicKey = core.getInput(\"anthropic_api_key\");\n    34→    const configPath = core.getInput(\"config_path\");\n    35→    const forceStage = core.getInput(\"stage\");\n    36→    const timeoutMinutes = parseInt(core.getInput(\"timeout_minutes\"), 10);\n    37→\n    38→    const octokit = github.getOctokit(token);\n    39→    const context = github.context;\n    40→\n    41→    const config = await loadConfig(configPath);\n    42→\n    43→    await ensureLabels(octokit, context, config);\n    44→\n    45→    if (await checkBlocked(octokit, context, config)) {\n    46→      core.info(\"🛑 Kiln is blocked on this issue. Skipping.\");\n    47→      core.setOutput(\"stage\", \"none\");\n    48→      core.setOutput(\"result\", \"blocked\");\n    49→      return;\n    50→    }\n    51→\n    52→    let stage: string | null;\n    53→\n    54→    if (forceStage !== \"auto\") {\n    55→      stage = forceStage;\n    56→    } else {\n    57→      const route = detectStage(context);\n    58→      stage = route?.stage ?? null;\n    59→    }\n    60→\n    61→    if (!stage) {\n    62→      core.setOutput(\"stage\", \"none\");\n    63→      core.setOutput(\"result\", \"skipped\");\n    64→      return;\n    65→    }\n    66→\n    67→    core.info(`🔥 Kiln — Running stage: ${stage}`);\n    68→\n    69→    const handler = STAGES[stage];\n    70→    if (!handler) {\n    71→      core.setFailed(`Unknown stage: ${stage}`);\n    72→      return;\n    73→    }\n    74→\n    75→    const ctx: KilnContext = {\n    76→      octokit,\n    77→      context,\n    78→      config,\n    79→      anthropicKey,\n    80→      timeoutMinutes,\n    81→      token,\n    82→    };\n    83→\n    84→    const result = await handler(ctx);\n    85→\n    86→    core.setOutput(\"stage\", stage);\n    87→    core.setOutput(\"result\", result?.status || \"success\");\n    88→    if (result?.prNumber) {\n    89→      core.setOutput(\"pr_number\", result.prNumber.toString());\n    90→    }\n    91→\n    92→    core.info(`🔥 Kiln — Stage \"${stage}\" completed.`);\n    93→  } catch (error) {\n    94→    const message = error instanceof Error ? error.message : String(error);\n    95→    core.setFailed(`🔥 Kiln failed: ${message}`);\n    96→  }\n    97→}\n    98→\n    99→run();\n   100→"}]},"parent_tool_use_id":null,"session_id":"f20d6a69-1eae-4f47-9a8a-63b220fe9642","uuid":"ee1b5f39-ebc2-453a-80b3-9893068e923e","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/index.ts","content":"import * as core from \"@actions/core\";\nimport * as github from \"@actions/github\";\nimport { checkBlocked } from \"./blocked\";\nimport { loadConfig } from \"./config\";\nimport { ensureLabels } from \"./labels\";\nimport { detectStage } from \"./router\";\nimport { KilnContext, StageResult } from \"./types\";\n\nimport triage from \"./stages/triage\";\nimport specify from \"./stages/specify\";\nimport approveSpec from \"./stages/approve-spec\";\nimport implement from \"./stages/implement\";\nimport review from \"./stages/review\";\nimport fix from \"./stages/fix\";\nimport ship from \"./stages/ship\";\n\ntype StageHandler = (ctx: KilnContext) => Promise<StageResult>;\n\nconst STAGES: Record<string, StageHandler> = {\n  triage,\n  \"re-triage\": triage,\n  specify,\n  \"approve-spec\": approveSpec,\n  implement,\n  review,\n  fix,\n  release: ship,\n};\n\nasync function run(): Promise<void> {\n  try {\n    const token = core.getInput(\"github_token\");\n    const anthropicKey = core.getInput(\"anthropic_api_key\");\n    const configPath = core.getInput(\"config_path\");\n    const forceStage = core.getInput(\"stage\");\n    const timeoutMinutes = parseInt(core.getInput(\"timeout_minutes\"), 10);\n\n    const octokit = github.getOctokit(token);\n    const context = github.context;\n\n    const config = await loadConfig(configPath);\n\n    await ensureLabels(octokit, context, config);\n\n    if (await checkBlocked(octokit, context, config)) {\n      core.info(\"🛑 Kiln is blocked on this issue. Skipping.\");\n      core.setOutput(\"stage\", \"none\");\n      core.setOutput(\"result\", \"blocked\");\n      return;\n    }\n\n    let stage: string | null;\n\n    if (forceStage !== \"auto\") {\n      stage = forceStage;\n    } else {\n      const route = detectStage(context);\n      stage = route?.stage ?? null;\n    }\n\n    if (!stage) {\n      core.setOutput(\"stage\", \"none\");\n      core.setOutput(\"result\", \"skipped\");\n      return;\n    }\n\n    core.info(`🔥 Kiln — Running stage: ${stage}`);\n\n    const handler = STAGES[stage];\n    if (!handler) {\n      core.setFailed(`Unknown stage: ${stage}`);\n      return;\n    }\n\n    const ctx: KilnContext = {\n      octokit,\n      context,\n      config,\n      anthropicKey,\n      timeoutMinutes,\n      token,\n    };\n\n    const result = await handler(ctx);\n\n    core.setOutput(\"stage\", stage);\n    core.setOutput(\"result\", result?.status || \"success\");\n    if (result?.prNumber) {\n      core.setOutput(\"pr_number\", result.prNumber.toString());\n    }\n\n    core.info(`🔥 Kiln — Stage \"${stage}\" completed.`);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.setFailed(`🔥 Kiln failed: ${message}`);\n  }\n}\n\nrun();\n","numLines":100,"startLine":1,"totalLines":100}}}
