{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PuzQQxiE4DHZmiGhgRCW8G","type":"tool_result","content":"     1→import { KilnContext } from \"./types\";\n     2→\n     3→const BLOCKED_COMMENT =\n     4→  \"🔥 **Kiln** — Automation is blocked on this item. Remove kiln:blocked to resume.\";\n     5→\n     6→export async function checkBlocked(\n     7→  octokit: KilnContext[\"octokit\"],\n     8→  context: KilnContext[\"context\"],\n     9→  config: KilnContext[\"config\"],\n    10→): Promise<boolean> {\n    11→  const prefix = config.labels?.prefix || \"kiln\";\n    12→  const blockedLabel = `${prefix}:blocked`;\n    13→\n    14→  const hasLabel = (\n    15→    labels: Array<string | { name?: string }> | undefined,\n    16→  ): boolean =>\n    17→    !!labels?.some(\n    18→      (l) => (typeof l === \"string\" ? l : l.name) === blockedLabel,\n    19→    );\n    20→\n    21→  // For PR events, check both PR labels and linked issue labels\n    22→  if (context.payload.pull_request) {\n    23→    const prLabels = context.payload.pull_request.labels as\n    24→      | Array<{ name?: string }>\n    25→      | undefined;\n    26→    const prNumber = context.payload.pull_request.number as number;\n    27→\n    28→    if (hasLabel(prLabels)) {\n    29→      await postBlockedComment(octokit, context, prNumber);\n    30→      return true;\n    31→    }\n    32→\n    33→    // Also check the linked issue\n    34→    const match = (\n    35→      context.payload.pull_request.body as string | undefined\n    36→    )?.match(/Closes #(\\d+)/i);\n    37→    if (match) {\n    38→      const issueNumber = parseInt(match[1], 10);\n    39→      try {\n    40→        const { data: issue } = await octokit.rest.issues.get({\n    41→          ...context.repo,\n    42→          issue_number: issueNumber,\n    43→        });\n    44→        if (hasLabel(issue.labels)) {\n    45→          await postBlockedComment(octokit, context, prNumber);\n    46→          return true;\n    47→        }\n    48→      } catch {\n    49→        // Issue not found or inaccessible — not blocked\n    50→      }\n    51→    }\n    52→\n    53→    return false;\n    54→  }\n    55→\n    56→  // For issue events, check the issue labels\n    57→  const issueNumber = context.payload.issue?.number as number | undefined;\n    58→  if (!issueNumber) return false;\n    59→\n    60→  const issueLabels = context.payload.issue?.labels as\n    61→    | Array<{ name?: string }>\n    62→    | undefined;\n    63→\n    64→  if (hasLabel(issueLabels)) {\n    65→    await postBlockedComment(octokit, context, issueNumber);\n    66→    return true;\n    67→  }\n    68→\n    69→  return false;\n    70→}\n    71→\n    72→async function postBlockedComment(\n    73→  octokit: KilnContext[\"octokit\"],\n    74→  context: KilnContext[\"context\"],\n    75→  issueOrPrNumber: number,\n    76→): Promise<void> {\n    77→  try {\n    78→    await octokit.rest.issues.createComment({\n    79→      ...context.repo,\n    80→      issue_number: issueOrPrNumber,\n    81→      body: BLOCKED_COMMENT,\n    82→    });\n    83→  } catch {\n    84→    // Best-effort comment; don't fail the guard if comment posting fails\n    85→  }\n    86→}\n    87→"}]},"parent_tool_use_id":null,"session_id":"f20d6a69-1eae-4f47-9a8a-63b220fe9642","uuid":"bf251a74-ad9b-45e8-bb59-186a75d59956","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/blocked.ts","content":"import { KilnContext } from \"./types\";\n\nconst BLOCKED_COMMENT =\n  \"🔥 **Kiln** — Automation is blocked on this item. Remove kiln:blocked to resume.\";\n\nexport async function checkBlocked(\n  octokit: KilnContext[\"octokit\"],\n  context: KilnContext[\"context\"],\n  config: KilnContext[\"config\"],\n): Promise<boolean> {\n  const prefix = config.labels?.prefix || \"kiln\";\n  const blockedLabel = `${prefix}:blocked`;\n\n  const hasLabel = (\n    labels: Array<string | { name?: string }> | undefined,\n  ): boolean =>\n    !!labels?.some(\n      (l) => (typeof l === \"string\" ? l : l.name) === blockedLabel,\n    );\n\n  // For PR events, check both PR labels and linked issue labels\n  if (context.payload.pull_request) {\n    const prLabels = context.payload.pull_request.labels as\n      | Array<{ name?: string }>\n      | undefined;\n    const prNumber = context.payload.pull_request.number as number;\n\n    if (hasLabel(prLabels)) {\n      await postBlockedComment(octokit, context, prNumber);\n      return true;\n    }\n\n    // Also check the linked issue\n    const match = (\n      context.payload.pull_request.body as string | undefined\n    )?.match(/Closes #(\\d+)/i);\n    if (match) {\n      const issueNumber = parseInt(match[1], 10);\n      try {\n        const { data: issue } = await octokit.rest.issues.get({\n          ...context.repo,\n          issue_number: issueNumber,\n        });\n        if (hasLabel(issue.labels)) {\n          await postBlockedComment(octokit, context, prNumber);\n          return true;\n        }\n      } catch {\n        // Issue not found or inaccessible — not blocked\n      }\n    }\n\n    return false;\n  }\n\n  // For issue events, check the issue labels\n  const issueNumber = context.payload.issue?.number as number | undefined;\n  if (!issueNumber) return false;\n\n  const issueLabels = context.payload.issue?.labels as\n    | Array<{ name?: string }>\n    | undefined;\n\n  if (hasLabel(issueLabels)) {\n    await postBlockedComment(octokit, context, issueNumber);\n    return true;\n  }\n\n  return false;\n}\n\nasync function postBlockedComment(\n  octokit: KilnContext[\"octokit\"],\n  context: KilnContext[\"context\"],\n  issueOrPrNumber: number,\n): Promise<void> {\n  try {\n    await octokit.rest.issues.createComment({\n      ...context.repo,\n      issue_number: issueOrPrNumber,\n      body: BLOCKED_COMMENT,\n    });\n  } catch {\n    // Best-effort comment; don't fail the guard if comment posting fails\n  }\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
