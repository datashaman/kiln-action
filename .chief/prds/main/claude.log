{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UDfKnQJ9hSkJzANgDLggX9","type":"tool_result","content":"     1→import { execSync } from \"child_process\";\n     2→import * as core from \"@actions/core\";\n     3→import { Octokit } from \"./types\";\n     4→import { Context } from \"@actions/github/lib/context\";\n     5→\n     6→export interface ClaudeConfig {\n     7→  /** Anthropic API key (required) */\n     8→  anthropicKey: string;\n     9→  /** Timeout in minutes (default: 30, matching claude-code-action v1) */\n    10→  timeoutMinutes?: number;\n    11→  /** Whether Claude can edit files (default: false = read-only / --print mode) */\n    12→  allowEdits?: boolean;\n    13→  /** Octokit instance for posting error comments (optional) */\n    14→  octokit?: Octokit;\n    15→  /** GitHub Actions context for resolving issue/PR numbers (optional) */\n    16→  context?: Context;\n    17→}\n    18→\n    19→export interface ClaudeResult {\n    20→  /** The raw text output from Claude */\n    21→  output: string;\n    22→  /** Whether the invocation succeeded */\n    23→  success: boolean;\n    24→  /** Error message if the invocation failed */\n    25→  error?: string;\n    26→}\n    27→\n    28→const DEFAULT_TIMEOUT_MINUTES = 30;\n    29→const MAX_BUFFER_BYTES = 10 * 1024 * 1024; // 10MB\n    30→\n    31→/**\n    32→ * Shared utility to invoke Claude Code via the CLI.\n    33→ *\n    34→ * This is Kiln's integration layer for AI stages. All stages use this\n    35→ * function to interact with Claude, ensuring a consistent pattern for\n    36→ * prompt delivery, output capture, timeout handling, error surfacing,\n    37→ * and API-key security.\n    38→ *\n    39→ * Mirrors the interface of anthropics/claude-code-action@v1:\n    40→ * - Accepts a prompt string (equivalent to direct_prompt)\n    41→ * - Passes the API key via environment variable (never logged)\n    42→ * - Hard-coded 30-minute default timeout (matching v1)\n    43→ */\n    44→export async function invokeClaude(\n    45→  prompt: string,\n    46→  config: ClaudeConfig,\n    47→): Promise<ClaudeResult> {\n    48→  const {\n    49→    anthropicKey,\n    50→    timeoutMinutes = DEFAULT_TIMEOUT_MINUTES,\n    51→    allowEdits = false,\n    52→    octokit,\n    53→    context,\n    54→  } = config;\n    55→\n    56→  const timeoutMs = timeoutMinutes * 60 * 1000;\n    57→  const escapedPrompt = escapeShell(prompt);\n    58→\n    59→  // --print mode = read-only (no file edits); omit for edit mode\n    60→  const command = allowEdits\n    61→    ? `claude \"${escapedPrompt}\"`\n    62→    : `claude --print \"${escapedPrompt}\"`;\n    63→\n    64→  try {\n    65→    const output = execSync(command, {\n    66→      env: {\n    67→        ...process.env,\n    68→        ANTHROPIC_API_KEY: anthropicKey,\n    69→      },\n    70→      timeout: timeoutMs,\n    71→      maxBuffer: MAX_BUFFER_BYTES,\n    72→      encoding: \"utf-8\",\n    73→    });\n    74→\n    75→    return { output: output.trim(), success: true };\n    76→  } catch (error) {\n    77→    const isTimeout =\n    78→      error instanceof Error && \"killed\" in error && (error as NodeJS.ErrnoException & { killed?: boolean }).killed;\n    79→    const errorMessage = isTimeout\n    80→      ? `Claude Code timed out after ${timeoutMinutes} minutes`\n    81→      : error instanceof Error\n    82→        ? error.message\n    83→        : String(error);\n    84→\n    85→    core.error(`Claude Code invocation failed: ${errorMessage}`);\n    86→\n    87→    // Surface the error as a comment on the relevant issue/PR when possible\n    88→    await postErrorComment(errorMessage, octokit, context);\n    89→\n    90→    return { output: \"\", success: false, error: errorMessage };\n    91→  }\n    92→}\n    93→\n    94→/**\n    95→ * Convenience wrapper: invoke Claude in read-only mode (--print).\n    96→ * Used by triage and review stages.\n    97→ */\n    98→export function runClaude(\n    99→  prompt: string,\n   100→  options: { anthropicKey: string; timeoutMinutes?: number },\n   101→): string {\n   102→  const { anthropicKey, timeoutMinutes = DEFAULT_TIMEOUT_MINUTES } = options;\n   103→  const timeoutMs = timeoutMinutes * 60 * 1000;\n   104→\n   105→  try {\n   106→    const output = execSync(`claude --print \"${escapeShell(prompt)}\"`, {\n   107→      env: { ...process.env, ANTHROPIC_API_KEY: anthropicKey },\n   108→      timeout: timeoutMs,\n   109→      maxBuffer: MAX_BUFFER_BYTES,\n   110→      encoding: \"utf-8\",\n   111→    });\n   112→    return output.trim();\n   113→  } catch (error) {\n   114→    const message = error instanceof Error ? error.message : String(error);\n   115→    core.error(`Claude CLI failed: ${message}`);\n   116→    throw error;\n   117→  }\n   118→}\n   119→\n   120→/**\n   121→ * Convenience wrapper: invoke Claude in edit mode (can modify files).\n   122→ * Used by specify, implement, and fix stages.\n   123→ */\n   124→export function runClaudeEdit(\n   125→  prompt: string,\n   126→  options: { anthropicKey: string; timeoutMinutes?: number },\n   127→): string {\n   128→  const { anthropicKey, timeoutMinutes = DEFAULT_TIMEOUT_MINUTES } = options;\n   129→  const timeoutMs = timeoutMinutes * 60 * 1000;\n   130→\n   131→  try {\n   132→    const output = execSync(`claude \"${escapeShell(prompt)}\"`, {\n   133→      env: { ...process.env, ANTHROPIC_API_KEY: anthropicKey },\n   134→      timeout: timeoutMs,\n   135→      maxBuffer: MAX_BUFFER_BYTES,\n   136→      encoding: \"utf-8\",\n   137→    });\n   138→    return output.trim();\n   139→  } catch (error) {\n   140→    const message = error instanceof Error ? error.message : String(error);\n   141→    core.error(`Claude CLI (edit) failed: ${message}`);\n   142→    throw error;\n   143→  }\n   144→}\n   145→\n   146→/**\n   147→ * Post an error comment on the relevant issue or PR.\n   148→ * Best-effort — failures are logged but not thrown.\n   149→ */\n   150→async function postErrorComment(\n   151→  errorMessage: string,\n   152→  octokit?: Octokit,\n   153→  context?: Context,\n   154→): Promise<void> {\n   155→  if (!octokit || !context) return;\n   156→\n   157→  const issueNumber = resolveCommentTarget(context);\n   158→  if (!issueNumber) return;\n   159→\n   160→  // Sanitize: strip the API key from the error message if it leaked\n   161→  const sanitized = sanitizeOutput(\n   162→    errorMessage,\n   163→    process.env.ANTHROPIC_API_KEY,\n   164→  );\n   165→\n   166→  try {\n   167→    await octokit.rest.issues.createComment({\n   168→      ...context.repo,\n   169→      issue_number: issueNumber,\n   170→      body: `🔥 **Kiln** — Claude Code error: ${sanitized}`,\n   171→    });\n   172→  } catch (commentError) {\n   173→    const msg =\n   174→      commentError instanceof Error\n   175→        ? commentError.message\n   176→        : String(commentError);\n   177→    core.warning(`Failed to post error comment: ${msg}`);\n   178→  }\n   179→}\n   180→\n   181→/**\n   182→ * Determine the issue or PR number to post comments on.\n   183→ */\n   184→function resolveCommentTarget(context: Context): number | undefined {\n   185→  const payload = context.payload;\n   186→\n   187→  if (payload.issue) {\n   188→    return (payload.issue as { number: number }).number;\n   189→  }\n   190→  if (payload.pull_request) {\n   191→    return (payload.pull_request as { number: number }).number;\n   192→  }\n   193→  return undefined;\n   194→}\n   195→\n   196→/**\n   197→ * Remove any occurrence of the API key from output strings.\n   198→ */\n   199→function sanitizeOutput(text: string, apiKey?: string): string {\n   200→  if (!apiKey) return text;\n   201→  return text.replace(new RegExp(escapeRegExp(apiKey), \"g\"), \"[REDACTED]\");\n   202→}\n   203→\n   204→function escapeShell(str: string): string {\n   205→  return str.replace(/\"/g, '\\\\\"').replace(/\\$/g, \"\\\\$\").replace(/`/g, \"\\\\`\");\n   206→}\n   207→\n   208→function escapeRegExp(str: string): string {\n   209→  return str.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$&\");\n   210→}\n   211→"}]},"parent_tool_use_id":null,"session_id":"9f060dfe-dd73-41ed-8761-620bfcb4f31f","uuid":"51742b8e-6555-4cac-aee7-88965c93b057","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/claude.ts","content":"import { execSync } from \"child_process\";\nimport * as core from \"@actions/core\";\nimport { Octokit } from \"./types\";\nimport { Context } from \"@actions/github/lib/context\";\n\nexport interface ClaudeConfig {\n  /** Anthropic API key (required) */\n  anthropicKey: string;\n  /** Timeout in minutes (default: 30, matching claude-code-action v1) */\n  timeoutMinutes?: number;\n  /** Whether Claude can edit files (default: false = read-only / --print mode) */\n  allowEdits?: boolean;\n  /** Octokit instance for posting error comments (optional) */\n  octokit?: Octokit;\n  /** GitHub Actions context for resolving issue/PR numbers (optional) */\n  context?: Context;\n}\n\nexport interface ClaudeResult {\n  /** The raw text output from Claude */\n  output: string;\n  /** Whether the invocation succeeded */\n  success: boolean;\n  /** Error message if the invocation failed */\n  error?: string;\n}\n\nconst DEFAULT_TIMEOUT_MINUTES = 30;\nconst MAX_BUFFER_BYTES = 10 * 1024 * 1024; // 10MB\n\n/**\n * Shared utility to invoke Claude Code via the CLI.\n *\n * This is Kiln's integration layer for AI stages. All stages use this\n * function to interact with Claude, ensuring a consistent pattern for\n * prompt delivery, output capture, timeout handling, error surfacing,\n * and API-key security.\n *\n * Mirrors the interface of anthropics/claude-code-action@v1:\n * - Accepts a prompt string (equivalent to direct_prompt)\n * - Passes the API key via environment variable (never logged)\n * - Hard-coded 30-minute default timeout (matching v1)\n */\nexport async function invokeClaude(\n  prompt: string,\n  config: ClaudeConfig,\n): Promise<ClaudeResult> {\n  const {\n    anthropicKey,\n    timeoutMinutes = DEFAULT_TIMEOUT_MINUTES,\n    allowEdits = false,\n    octokit,\n    context,\n  } = config;\n\n  const timeoutMs = timeoutMinutes * 60 * 1000;\n  const escapedPrompt = escapeShell(prompt);\n\n  // --print mode = read-only (no file edits); omit for edit mode\n  const command = allowEdits\n    ? `claude \"${escapedPrompt}\"`\n    : `claude --print \"${escapedPrompt}\"`;\n\n  try {\n    const output = execSync(command, {\n      env: {\n        ...process.env,\n        ANTHROPIC_API_KEY: anthropicKey,\n      },\n      timeout: timeoutMs,\n      maxBuffer: MAX_BUFFER_BYTES,\n      encoding: \"utf-8\",\n    });\n\n    return { output: output.trim(), success: true };\n  } catch (error) {\n    const isTimeout =\n      error instanceof Error && \"killed\" in error && (error as NodeJS.ErrnoException & { killed?: boolean }).killed;\n    const errorMessage = isTimeout\n      ? `Claude Code timed out after ${timeoutMinutes} minutes`\n      : error instanceof Error\n        ? error.message\n        : String(error);\n\n    core.error(`Claude Code invocation failed: ${errorMessage}`);\n\n    // Surface the error as a comment on the relevant issue/PR when possible\n    await postErrorComment(errorMessage, octokit, context);\n\n    return { output: \"\", success: false, error: errorMessage };\n  }\n}\n\n/**\n * Convenience wrapper: invoke Claude in read-only mode (--print).\n * Used by triage and review stages.\n */\nexport function runClaude(\n  prompt: string,\n  options: { anthropicKey: string; timeoutMinutes?: number },\n): string {\n  const { anthropicKey, timeoutMinutes = DEFAULT_TIMEOUT_MINUTES } = options;\n  const timeoutMs = timeoutMinutes * 60 * 1000;\n\n  try {\n    const output = execSync(`claude --print \"${escapeShell(prompt)}\"`, {\n      env: { ...process.env, ANTHROPIC_API_KEY: anthropicKey },\n      timeout: timeoutMs,\n      maxBuffer: MAX_BUFFER_BYTES,\n      encoding: \"utf-8\",\n    });\n    return output.trim();\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.error(`Claude CLI failed: ${message}`);\n    throw error;\n  }\n}\n\n/**\n * Convenience wrapper: invoke Claude in edit mode (can modify files).\n * Used by specify, implement, and fix stages.\n */\nexport function runClaudeEdit(\n  prompt: string,\n  options: { anthropicKey: string; timeoutMinutes?: number },\n): string {\n  const { anthropicKey, timeoutMinutes = DEFAULT_TIMEOUT_MINUTES } = options;\n  const timeoutMs = timeoutMinutes * 60 * 1000;\n\n  try {\n    const output = execSync(`claude \"${escapeShell(prompt)}\"`, {\n      env: { ...process.env, ANTHROPIC_API_KEY: anthropicKey },\n      timeout: timeoutMs,\n      maxBuffer: MAX_BUFFER_BYTES,\n      encoding: \"utf-8\",\n    });\n    return output.trim();\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.error(`Claude CLI (edit) failed: ${message}`);\n    throw error;\n  }\n}\n\n/**\n * Post an error comment on the relevant issue or PR.\n * Best-effort — failures are logged but not thrown.\n */\nasync function postErrorComment(\n  errorMessage: string,\n  octokit?: Octokit,\n  context?: Context,\n): Promise<void> {\n  if (!octokit || !context) return;\n\n  const issueNumber = resolveCommentTarget(context);\n  if (!issueNumber) return;\n\n  // Sanitize: strip the API key from the error message if it leaked\n  const sanitized = sanitizeOutput(\n    errorMessage,\n    process.env.ANTHROPIC_API_KEY,\n  );\n\n  try {\n    await octokit.rest.issues.createComment({\n      ...context.repo,\n      issue_number: issueNumber,\n      body: `🔥 **Kiln** — Claude Code error: ${sanitized}`,\n    });\n  } catch (commentError) {\n    const msg =\n      commentError instanceof Error\n        ? commentError.message\n        : String(commentError);\n    core.warning(`Failed to post error comment: ${msg}`);\n  }\n}\n\n/**\n * Determine the issue or PR number to post comments on.\n */\nfunction resolveCommentTarget(context: Context): number | undefined {\n  const payload = context.payload;\n\n  if (payload.issue) {\n    return (payload.issue as { number: number }).number;\n  }\n  if (payload.pull_request) {\n    return (payload.pull_request as { number: number }).number;\n  }\n  return undefined;\n}\n\n/**\n * Remove any occurrence of the API key from output strings.\n */\nfunction sanitizeOutput(text: string, apiKey?: string): string {\n  if (!apiKey) return text;\n  return text.replace(new RegExp(escapeRegExp(apiKey), \"g\"), \"[REDACTED]\");\n}\n\nfunction escapeShell(str: string): string {\n  return str.replace(/\"/g, '\\\\\"').replace(/\\$/g, \"\\\\$\").replace(/`/g, \"\\\\`\");\n}\n\nfunction escapeRegExp(str: string): string {\n  return str.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$&\");\n}\n","numLines":211,"startLine":1,"totalLines":211}}}
