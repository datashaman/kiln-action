{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CPUbGeUWe3bjXijDWBtEvQ","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import * as github from \"@actions/github\";\n     3→import { loadConfig } from \"./config\";\n     4→import { ensureLabels } from \"./labels\";\n     5→import { detectStage } from \"./router\";\n     6→import { KilnContext, StageResult } from \"./types\";\n     7→\n     8→import triage from \"./stages/triage\";\n     9→import specify from \"./stages/specify\";\n    10→import approveSpec from \"./stages/approve-spec\";\n    11→import implement from \"./stages/implement\";\n    12→import review from \"./stages/review\";\n    13→import fix from \"./stages/fix\";\n    14→import ship from \"./stages/ship\";\n    15→\n    16→type StageHandler = (ctx: KilnContext) => Promise<StageResult>;\n    17→\n    18→const STAGES: Record<string, StageHandler> = {\n    19→  triage,\n    20→  \"re-triage\": triage,\n    21→  specify,\n    22→  \"approve-spec\": approveSpec,\n    23→  implement,\n    24→  review,\n    25→  fix,\n    26→  release: ship,\n    27→};\n    28→\n    29→async function isBlocked(\n    30→  octokit: KilnContext[\"octokit\"],\n    31→  context: KilnContext[\"context\"],\n    32→  config: KilnContext[\"config\"],\n    33→): Promise<boolean> {\n    34→  const prefix = config.labels?.prefix || \"kiln\";\n    35→  const blockedLabel = `${prefix}:blocked`;\n    36→\n    37→  let issueNumber = context.payload.issue?.number as number | undefined;\n    38→  if (!issueNumber && context.payload.pull_request) {\n    39→    const match = (\n    40→      context.payload.pull_request.body as string | undefined\n    41→    )?.match(/Closes #(\\d+)/);\n    42→    if (match) issueNumber = parseInt(match[1], 10);\n    43→  }\n    44→\n    45→  if (!issueNumber) return false;\n    46→\n    47→  try {\n    48→    const { data: issue } = await octokit.rest.issues.get({\n    49→      ...context.repo,\n    50→      issue_number: issueNumber,\n    51→    });\n    52→    return issue.labels.some(\n    53→      (l) => (typeof l === \"string\" ? l : l.name) === blockedLabel,\n    54→    );\n    55→  } catch {\n    56→    return false;\n    57→  }\n    58→}\n    59→\n    60→async function run(): Promise<void> {\n    61→  try {\n    62→    const token = core.getInput(\"github_token\");\n    63→    const anthropicKey = core.getInput(\"anthropic_api_key\");\n    64→    const configPath = core.getInput(\"config_path\");\n    65→    const forceStage = core.getInput(\"stage\");\n    66→    const timeoutMinutes = parseInt(core.getInput(\"timeout_minutes\"), 10);\n    67→\n    68→    const octokit = github.getOctokit(token);\n    69→    const context = github.context;\n    70→\n    71→    const config = await loadConfig(configPath);\n    72→\n    73→    await ensureLabels(octokit, context, config);\n    74→\n    75→    if (await isBlocked(octokit, context, config)) {\n    76→      core.info(\"🛑 Kiln is blocked on this issue. Skipping.\");\n    77→      core.setOutput(\"stage\", \"none\");\n    78→      core.setOutput(\"result\", \"blocked\");\n    79→      return;\n    80→    }\n    81→\n    82→    let stage: string | null;\n    83→\n    84→    if (forceStage !== \"auto\") {\n    85→      stage = forceStage;\n    86→    } else {\n    87→      const route = detectStage(context);\n    88→      stage = route?.stage ?? null;\n    89→    }\n    90→\n    91→    if (!stage) {\n    92→      core.setOutput(\"stage\", \"none\");\n    93→      core.setOutput(\"result\", \"skipped\");\n    94→      return;\n    95→    }\n    96→\n    97→    core.info(`🔥 Kiln — Running stage: ${stage}`);\n    98→\n    99→    const handler = STAGES[stage];\n   100→    if (!handler) {\n   101→      core.setFailed(`Unknown stage: ${stage}`);\n   102→      return;\n   103→    }\n   104→\n   105→    const ctx: KilnContext = {\n   106→      octokit,\n   107→      context,\n   108→      config,\n   109→      anthropicKey,\n   110→      timeoutMinutes,\n   111→      token,\n   112→    };\n   113→\n   114→    const result = await handler(ctx);\n   115→\n   116→    core.setOutput(\"stage\", stage);\n   117→    core.setOutput(\"result\", result?.status || \"success\");\n   118→    if (result?.prNumber) {\n   119→      core.setOutput(\"pr_number\", result.prNumber.toString());\n   120→    }\n   121→\n   122→    core.info(`🔥 Kiln — Stage \"${stage}\" completed.`);\n   123→  } catch (error) {\n   124→    const message = error instanceof Error ? error.message : String(error);\n   125→    core.setFailed(`🔥 Kiln failed: ${message}`);\n   126→  }\n   127→}\n   128→\n   129→run();\n   130→"}]},"parent_tool_use_id":null,"session_id":"8981eff5-58b5-4df5-8b71-0aaa41565c79","uuid":"eb5eb4f3-a66b-4706-8828-dc134e85dc2e","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/index.ts","content":"import * as core from \"@actions/core\";\nimport * as github from \"@actions/github\";\nimport { loadConfig } from \"./config\";\nimport { ensureLabels } from \"./labels\";\nimport { detectStage } from \"./router\";\nimport { KilnContext, StageResult } from \"./types\";\n\nimport triage from \"./stages/triage\";\nimport specify from \"./stages/specify\";\nimport approveSpec from \"./stages/approve-spec\";\nimport implement from \"./stages/implement\";\nimport review from \"./stages/review\";\nimport fix from \"./stages/fix\";\nimport ship from \"./stages/ship\";\n\ntype StageHandler = (ctx: KilnContext) => Promise<StageResult>;\n\nconst STAGES: Record<string, StageHandler> = {\n  triage,\n  \"re-triage\": triage,\n  specify,\n  \"approve-spec\": approveSpec,\n  implement,\n  review,\n  fix,\n  release: ship,\n};\n\nasync function isBlocked(\n  octokit: KilnContext[\"octokit\"],\n  context: KilnContext[\"context\"],\n  config: KilnContext[\"config\"],\n): Promise<boolean> {\n  const prefix = config.labels?.prefix || \"kiln\";\n  const blockedLabel = `${prefix}:blocked`;\n\n  let issueNumber = context.payload.issue?.number as number | undefined;\n  if (!issueNumber && context.payload.pull_request) {\n    const match = (\n      context.payload.pull_request.body as string | undefined\n    )?.match(/Closes #(\\d+)/);\n    if (match) issueNumber = parseInt(match[1], 10);\n  }\n\n  if (!issueNumber) return false;\n\n  try {\n    const { data: issue } = await octokit.rest.issues.get({\n      ...context.repo,\n      issue_number: issueNumber,\n    });\n    return issue.labels.some(\n      (l) => (typeof l === \"string\" ? l : l.name) === blockedLabel,\n    );\n  } catch {\n    return false;\n  }\n}\n\nasync function run(): Promise<void> {\n  try {\n    const token = core.getInput(\"github_token\");\n    const anthropicKey = core.getInput(\"anthropic_api_key\");\n    const configPath = core.getInput(\"config_path\");\n    const forceStage = core.getInput(\"stage\");\n    const timeoutMinutes = parseInt(core.getInput(\"timeout_minutes\"), 10);\n\n    const octokit = github.getOctokit(token);\n    const context = github.context;\n\n    const config = await loadConfig(configPath);\n\n    await ensureLabels(octokit, context, config);\n\n    if (await isBlocked(octokit, context, config)) {\n      core.info(\"🛑 Kiln is blocked on this issue. Skipping.\");\n      core.setOutput(\"stage\", \"none\");\n      core.setOutput(\"result\", \"blocked\");\n      return;\n    }\n\n    let stage: string | null;\n\n    if (forceStage !== \"auto\") {\n      stage = forceStage;\n    } else {\n      const route = detectStage(context);\n      stage = route?.stage ?? null;\n    }\n\n    if (!stage) {\n      core.setOutput(\"stage\", \"none\");\n      core.setOutput(\"result\", \"skipped\");\n      return;\n    }\n\n    core.info(`🔥 Kiln — Running stage: ${stage}`);\n\n    const handler = STAGES[stage];\n    if (!handler) {\n      core.setFailed(`Unknown stage: ${stage}`);\n      return;\n    }\n\n    const ctx: KilnContext = {\n      octokit,\n      context,\n      config,\n      anthropicKey,\n      timeoutMinutes,\n      token,\n    };\n\n    const result = await handler(ctx);\n\n    core.setOutput(\"stage\", stage);\n    core.setOutput(\"result\", result?.status || \"success\");\n    if (result?.prNumber) {\n      core.setOutput(\"pr_number\", result.prNumber.toString());\n    }\n\n    core.info(`🔥 Kiln — Stage \"${stage}\" completed.`);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.setFailed(`🔥 Kiln failed: ${message}`);\n  }\n}\n\nrun();\n","numLines":130,"startLine":1,"totalLines":130}}}
