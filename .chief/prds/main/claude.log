90→          `🔥 Kiln Router — Matched stage: re-triage (issue_comment.created on issue with intake/needs-info label)`,\n    91→        );\n    92→        return result;\n    93→      }\n    94→    }\n    95→  }\n    96→\n    97→  // ── Pull Request Events ───────────────────────────────\n    98→  if (eventName === \"pull_request\") {\n    99→    const prNumber = payload.pull_request?.number as number | undefined;\n   100→    const prLabels = extractLabels(payload.pull_request?.labels);\n   101→\n   102→    // Impl PR opened or updated → review\n   103→    if (\n   104→      (payload.action === \"opened\" || payload.action === \"synchronize\") &&\n   105→      prLabels.some((l) => l.endsWith(\":implementation\"))\n   106→    ) {\n   107→      const result: RouteResult = {\n   108→        stage: \"review\",\n   109→        prNumber,\n   110→        labels: prLabels,\n   111→        payload: payload as unknown as Record<string, unknown>,\n   112→      };\n   113→      core.info(\n   114→        `🔥 Kiln Router — Matched stage: review (pull_request.${payload.action} with implementation label)`,\n   115→      );\n   116→      return result;\n   117→    }\n   118→  }\n   119→\n   120→  // ── PR Review Events ──────────────────────────────────\n   121→  if (eventName === \"pull_request_review\") {\n   122→    const prNumber = payload.pull_request?.number as number | undefined;\n   123→    const prLabels = extractLabels(payload.pull_request?.labels);\n   124→    const state = payload.review?.state as string | undefined;\n   125→\n   126→    // Spec PR approved → approve-spec (triggers implementation)\n   127→    if (state === \"approved\" && prLabels.some((l) => l.endsWith(\":spec\"))) {\n   128→      const result: RouteResult = {\n   129→        stage: \"approve-spec\",\n   130→        prNumber,\n   131→        labels: prLabels,\n   132→        payload: payload as unknown as Record<string, unknown>,\n   133→      };\n   134→      core.info(\n   135→        `🔥 Kiln Router — Matched stage: approve-spec (pull_request_review.submitted approved on spec PR)`,\n   136→      );\n   137→      return result;\n   138→    }\n   139→\n   140→    // Impl PR: changes requested → fix\n   141→    if (\n   142→      state === \"changes_requested\" &&\n   143→      prLabels.some((l) => l.endsWith(\":implementation\"))\n   144→    ) {\n   145→      const result: RouteResult = {\n   146→        stage: \"fix\",\n   147→        prNumber,\n   148→        labels: prLabels,\n   149→        payload: payload as unknown as Record<string, unknown>,\n   150→      };\n   151→      core.info(\n   152→        `🔥 Kiln Router — Matched stage: fix (pull_request_review.submitted changes_requested on implementation PR)`,\n   153→      );\n   154→      return result;\n   155→    }\n   156→\n   157→    // Impl PR: approved → release\n   158→    if (\n   159→      state === \"approved\" &&\n   160→      prLabels.some((l) => l.endsWith(\":implementation\"))\n   161→    ) {\n   162→      const result: RouteResult = {\n   163→        stage: \"release\",\n   164→        prNumber,\n   165→        labels: prLabels,\n   166→        payload: payload as unknown as Record<string, unknown>,\n   167→      };\n   168→      core.info(\n   169→        `🔥 Kiln Router — Matched stage: release (pull_request_review.submitted approved on implementation PR)`,\n   170→      );\n   171→      return result;\n   172→    }\n   173→  }\n   174→\n   175→  // ── Check Suite (CI) Events ───────────────────────────\n   176→  if (eventName === \"check_suite\" && payload.action === \"completed\") {\n   177→    const prs =\n   178→      (payload.check_suite?.pull_requests as Array<unknown>) || [];\n   179→    if (prs.length > 0) {\n   180→      const result: RouteResult = {\n   181→        stage: \"release\",\n   182→        labels: [],\n   183→        payload: payload as unknown as Record<string, unknown>,\n   184→      };\n   185→      core.info(\n   186→        `🔥 Kiln Router — Matched stage: release (check_suite.completed with associated PRs)`,\n   187→      );\n   188→      return result;\n   189→    }\n   190→  }\n   191→\n   192→  core.info(\n   193→    `🔥 Kiln Router — No matching stage for event: ${eventName}.${payload.action || \"\"}`,\n   194→  );\n   195→  return null;\n   196→}\n   197→\n   198→function extractLabels(\n   199→  labels: unknown,\n   200→): string[] {\n   201→  if (!Array.isArray(labels)) return [];\n   202→  return labels.map((l: { name: string }) => l.name);\n   203→}\n   204→"}]},"parent_tool_use_id":null,"session_id":"c724d35f-7b14-4623-85ef-5de838552fab","uuid":"27636629-1471-4ded-82ca-b29237768a9b","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/router.ts","content":"import * as core from \"@actions/core\";\nimport { Context } from \"@actions/github/lib/context\";\nimport { RouteResult } from \"./types\";\n\n/**\n * Detects which Kiln stage to run based on the GitHub event.\n *\n * Event → Stage mapping:\n *\n *   issues.opened                                        → triage\n *   issue_comment.created (kiln:intake or kiln:needs-info) → re-triage\n *   issues.labeled  (kiln:specifying)                    → specify\n *   pull_request_review.submitted (approved + spec PR)   → approve-spec\n *   issues.labeled  (kiln:implementing)                  → implement\n *   pull_request.opened / synchronize (impl PR)          → review\n *   pull_request_review.submitted (changes_requested + impl PR) → fix\n *   pull_request_review.submitted (approved + impl PR)   → release\n *   check_suite.completed (impl PR)                      → release\n */\nexport function detectStage(context: Context): RouteResult | null {\n  const { eventName, payload } = context;\n\n  // ── Issue Events ──────────────────────────────────────\n  if (eventName === \"issues\") {\n    const issueNumber = payload.issue?.number as number | undefined;\n    const issueLabels = extractLabels(payload.issue?.labels);\n\n    // New issue opened → triage\n    if (payload.action === \"opened\") {\n      const result: RouteResult = {\n        stage: \"triage\",\n        issueNumber,\n        labels: issueLabels,\n        payload: payload as unknown as Record<string, unknown>,\n      };\n      core.info(`🔥 Kiln Router — Matched stage: triage (issues.opened)`);\n      return result;\n    }\n\n    // Labeled events — check which label was just added\n    if (payload.action === \"labeled\") {\n      const added = payload.label?.name as string | undefined;\n\n      if (added?.endsWith(\":specifying\")) {\n        const result: RouteResult = {\n          stage: \"specify\",\n          issueNumber,\n          labels: issueLabels,\n          payload: payload as unknown as Record<string, unknown>,\n        };\n        core.info(\n          `🔥 Kiln Router — Matched stage: specify (issues.labeled with ${added})`,\n        );\n        return result;\n      }\n\n      if (added?.endsWith(\":implementing\")) {\n        const result: RouteResult = {\n          stage: \"implement\",\n          issueNumber,\n          labels: issueLabels,\n          payload: payload as unknown as Record<string, unknown>,\n        };\n        core.info(\n          `🔥 Kiln Router — Matched stage: implement (issues.labeled with ${added})`,\n        );\n        return result;\n      }\n    }\n  }\n\n  // ── Issue Comment Events ──────────────────────────────\n  if (eventName === \"issue_comment\") {\n    if (payload.action === \"created\") {\n      const issueNumber = payload.issue?.number as number | undefined;\n      const issueLabels = extractLabels(payload.issue?.labels);\n\n      if (\n        issueLabels.some(\n          (n) => n.endsWith(\":intake\") || n.endsWith(\":needs-info\"),\n        )\n      ) {\n        const result: RouteResult = {\n          stage: \"re-triage\",\n          issueNumber,\n          labels: issueLabels,\n          payload: payload as unknown as Record<string, unknown>,\n        };\n        core.info(\n          `🔥 Kiln Router — Matched stage: re-triage (issue_comment.created on issue with intake/needs-info label)`,\n        );\n        return result;\n      }\n    }\n  }\n\n  // ── Pull Request Events ───────────────────────────────\n  if (eventName === \"pull_request\") {\n    const prNumber = payload.pull_request?.number as number | undefined;\n    const prLabels = extractLabels(payload.pull_request?.labels);\n\n    // Impl PR opened or updated → review\n    if (\n      (payload.action === \"opened\" || payload.action === \"synchronize\") &&\n      prLabels.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      const result: RouteResult = {\n        stage: \"review\",\n        prNumber,\n        labels: prLabels,\n        payload: payload as unknown as Record<string, unknown>,\n      };\n      core.info(\n        `🔥 Kiln Router — Matched stage: review (pull_request.${payload.action} with implementation label)`,\n      );\n      return result;\n    }\n  }\n\n  // ── PR Review Events ──────────────────────────────────\n  if (eventName === \"pull_request_review\") {\n    const prNumber = payload.pull_request?.number as number | undefined;\n    const prLabels = extractLabels(payload.pull_request?.labels);\n    const state = payload.review?.state as string | undefined;\n\n    // Spec PR approved → approve-spec (triggers implementation)\n    if (state === \"approved\" && prLabels.some((l) => l.endsWith(\":spec\"))) {\n      const result: RouteResult = {\n        stage: \"approve-spec\",\n        prNumber,\n        labels: prLabels,\n        payload: payload as unknown as Record<string, unknown>,\n      };\n      core.info(\n        `🔥 Kiln Router — Matched stage: approve-spec (pull_request_review.submitted approved on spec PR)`,\n      );\n      return result;\n    }\n\n    // Impl PR: changes requested → fix\n    if (\n      state === \"changes_requested\" &&\n      prLabels.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      const result: RouteResult = {\n        stage: \"fix\",\n        prNumber,\n        labels: prLabels,\n        payload: payload as unknown as Record<string, unknown>,\n      };\n      core.info(\n        `🔥 Kiln Router — Matched stage: fix (pull_request_review.submitted changes_requested on implementation PR)`,\n      );\n      return result;\n    }\n\n    // Impl PR: approved → release\n    if (\n      state === \"approved\" &&\n      prLabels.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      const result: RouteResult = {\n        stage: \"release\",\n        prNumber,\n        labels: prLabels,\n        payload: payload as unknown as Record<string, unknown>,\n      };\n      core.info(\n        `🔥 Kiln Router — Matched stage: release (pull_request_review.submitted approved on implementation PR)`,\n      );\n      return result;\n    }\n  }\n\n  // ── Check Suite (CI) Events ───────────────────────────\n  if (eventName === \"check_suite\" && payload.action === \"completed\") {\n    const prs =\n      (payload.check_suite?.pull_requests as Array<unknown>) || [];\n    if (prs.length > 0) {\n      const result: RouteResult = {\n        stage: \"release\",\n        labels: [],\n        payload: payload as unknown as Record<string, unknown>,\n      };\n      core.info(\n        `🔥 Kiln Router — Matched stage: release (check_suite.completed with associated PRs)`,\n      );\n      return result;\n    }\n  }\n\n  core.info(\n    `🔥 Kiln Router — No matching stage for event: ${eventName}.${payload.action || \"\"}`,\n  );\n  return null;\n}\n\nfunction extractLabels(\n  labels: unknown,\n): string[] {\n  if (!Array.isArray(labels)) return [];\n  return labels.map((l: { name: string }) => l.name);\n}\n","numLines":204,"startLine":1,"totalLines":204}}}
