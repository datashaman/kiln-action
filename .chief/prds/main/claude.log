{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Gae9fb3GQ1qxnQYEy1LWs","type":"tool_result","content":"     1→const core = require(\"@actions/core\");\n     2→const { runClaude } = require(\"../claude\");\n     3→\n     4→module.exports = async function review(ctx) {\n     5→  const { octokit, context, config, anthropicKey, timeoutMinutes } = ctx;\n     6→  const pr = context.payload.pull_request;\n     7→\n     8→  core.info(`🔥 Review — PR #${pr.number}: ${pr.title}`);\n     9→\n    10→  // Get the diff\n    11→  const { data: diff } = await octokit.rest.pulls.get({\n    12→    ...context.repo,\n    13→    pull_number: pr.number,\n    14→    mediaType: { format: \"diff\" },\n    15→  });\n    16→\n    17→  // Get the list of changed files\n    18→  const { data: files } = await octokit.rest.pulls.listFiles({\n    19→    ...context.repo,\n    20→    pull_number: pr.number,\n    21→    per_page: 100,\n    22→  });\n    23→\n    24→  const fileList = files.map((f) => `${f.status}: ${f.filename} (+${f.additions} -${f.deletions})`).join(\"\\n\");\n    25→\n    26→  // Extract issue number from PR body\n    27→  const issueMatch = pr.body?.match(/Closes #(\\d+)/);\n    28→  const specRef = issueMatch ? `specs/issue-${issueMatch[1]}.md` : null;\n    29→\n    30→  const prompt = `You are the Kiln review agent — a senior code reviewer.\n    31→\n    32→**PR #${pr.number}:** ${pr.title}\n    33→${specRef ? `**Spec:** ${specRef}` : \"\"}\n    34→\n    35→**Changed files:**\n    36→${fileList}\n    37→\n    38→**Diff:**\n    39→${diff.substring(0, 50000)}\n    40→\n    41→${specRef ? `First, read the spec at ${specRef} and verify the implementation meets all acceptance criteria.` : \"\"}\n    42→\n    43→Review for:\n    44→1. **Correctness** — Does it do what the spec says?\n    45→2. **Completeness** — Are all acceptance criteria met? All tests written?\n    46→3. **Security** — Any vulnerabilities? Input validation? Auth checks?\n    47→4. **Performance** — Any N+1 queries, unnecessary loops, memory leaks?\n    48→5. **Error handling** — Are errors caught and handled gracefully?\n    49→6. **Code style** — Does it match existing project conventions?\n    50→7. **Scope** — Are there any changes OUTSIDE the spec's scope?\n    51→\n    52→Respond with a JSON block:\n    53→\\`\\`\\`json\n    54→{\n    55→  \"verdict\": \"approve\" | \"request_changes\",\n    56→  \"summary\": \"Overall assessment in 2-3 sentences\",\n    57→  \"issues\": [\n    58→    {\n    59→      \"file\": \"path/to/file.ts\",\n    60→      \"line\": 42,\n    61→      \"severity\": \"critical\" | \"major\" | \"minor\" | \"nit\",\n    62→      \"comment\": \"Description of the issue and how to fix it\"\n    63→    }\n    64→  ]\n    65→}\n    66→\\`\\`\\`\n    67→\n    68→Be thorough but fair. Only request changes for real issues, not style preferences.`;\n    69→\n    70→  const output = await runClaude(prompt, { anthropicKey, timeoutMinutes });\n    71→\n    72→  // Parse the review\n    73→  let reviewResult;\n    74→  try {\n    75→    const jsonMatch = output.match(/```json\\s*([\\s\\S]*?)\\s*```/) || output.match(/\\{[\\s\\S]*\\}/);\n    76→    const jsonStr = jsonMatch ? (jsonMatch[1] || jsonMatch[0]) : output;\n    77→    reviewResult = JSON.parse(jsonStr);\n    78→  } catch (error) {\n    79→    core.warning(`Failed to parse review response. Posting raw review.`);\n    80→    await octokit.rest.pulls.createReview({\n    81→      ...context.repo,\n    82→      pull_number: pr.number,\n    83→      body: `🔥 **Kiln Review**\\n\\n${output}`,\n    84→      event: \"COMMENT\",\n    85→    });\n    86→    return { status: \"success\" };\n    87→  }\n    88→\n    89→  // Build review comments\n    90→  const comments = (reviewResult.issues || [])\n    91→    .filter((i) => i.file && i.line)\n    92→    .map((i) => ({\n    93→      path: i.file,\n    94→      line: i.line,\n    95→      body: `**${i.severity}:** ${i.comment}`,\n    96→    }));\n    97→\n    98→  // Submit the review\n    99→  const event = reviewResult.verdict === \"approve\" ? \"APPROVE\" : \"REQUEST_CHANGES\";\n   100→\n   101→  const reviewBody = [\n   102→    `🔥 **Kiln Review**`,\n   103→    \"\",\n   104→    reviewResult.summary,\n   105→    \"\",\n   106→    reviewResult.issues?.length\n   107→      ? `Found **${reviewResult.issues.length}** issue(s): ${reviewResult.issues.filter((i) => i.severity === \"critical\").length} critical, ${reviewResult.issues.filter((i) => i.severity === \"major\").length} major, ${reviewResult.issues.filter((i) => i.severity === \"minor\").length} minor`\n   108→      : \"No issues found. ✅\",\n   109→  ].join(\"\\n\");\n   110→\n   111→  try {\n   112→    await octokit.rest.pulls.createReview({\n   113→      ...context.repo,\n   114→      pull_number: pr.number,\n   115→      body: reviewBody,\n   116→      event,\n   117→      comments: comments.length > 0 ? comments : undefined,\n   118→    });\n   119→  } catch (error) {\n   120→    // If inline comments fail (e.g., line not in diff), post as regular review\n   121→    core.warning(`Inline comments failed, posting summary review: ${error.message}`);\n   122→    await octokit.rest.pulls.createReview({\n   123→      ...context.repo,\n   124→      pull_number: pr.number,\n   125→      body: reviewBody + \"\\n\\n\" + (reviewResult.issues || []).map((i) => `- **${i.severity}** \\`${i.file}:${i.line}\\`: ${i.comment}`).join(\"\\n\"),\n   126→      event,\n   127→    });\n   128→  }\n   129→\n   130→  return { status: \"success\", verdict: reviewResult.verdict };\n   131→};\n   132→"}]},"parent_tool_use_id":null,"session_id":"2a8b2ce2-e0c8-48b6-8ab6-0a0f1560652c","uuid":"61c96fe0-92f4-4321-9ad4-7bdf85dc8ee6","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/review.js","content":"const core = require(\"@actions/core\");\nconst { runClaude } = require(\"../claude\");\n\nmodule.exports = async function review(ctx) {\n  const { octokit, context, config, anthropicKey, timeoutMinutes } = ctx;\n  const pr = context.payload.pull_request;\n\n  core.info(`🔥 Review — PR #${pr.number}: ${pr.title}`);\n\n  // Get the diff\n  const { data: diff } = await octokit.rest.pulls.get({\n    ...context.repo,\n    pull_number: pr.number,\n    mediaType: { format: \"diff\" },\n  });\n\n  // Get the list of changed files\n  const { data: files } = await octokit.rest.pulls.listFiles({\n    ...context.repo,\n    pull_number: pr.number,\n    per_page: 100,\n  });\n\n  const fileList = files.map((f) => `${f.status}: ${f.filename} (+${f.additions} -${f.deletions})`).join(\"\\n\");\n\n  // Extract issue number from PR body\n  const issueMatch = pr.body?.match(/Closes #(\\d+)/);\n  const specRef = issueMatch ? `specs/issue-${issueMatch[1]}.md` : null;\n\n  const prompt = `You are the Kiln review agent — a senior code reviewer.\n\n**PR #${pr.number}:** ${pr.title}\n${specRef ? `**Spec:** ${specRef}` : \"\"}\n\n**Changed files:**\n${fileList}\n\n**Diff:**\n${diff.substring(0, 50000)}\n\n${specRef ? `First, read the spec at ${specRef} and verify the implementation meets all acceptance criteria.` : \"\"}\n\nReview for:\n1. **Correctness** — Does it do what the spec says?\n2. **Completeness** — Are all acceptance criteria met? All tests written?\n3. **Security** — Any vulnerabilities? Input validation? Auth checks?\n4. **Performance** — Any N+1 queries, unnecessary loops, memory leaks?\n5. **Error handling** — Are errors caught and handled gracefully?\n6. **Code style** — Does it match existing project conventions?\n7. **Scope** — Are there any changes OUTSIDE the spec's scope?\n\nRespond with a JSON block:\n\\`\\`\\`json\n{\n  \"verdict\": \"approve\" | \"request_changes\",\n  \"summary\": \"Overall assessment in 2-3 sentences\",\n  \"issues\": [\n    {\n      \"file\": \"path/to/file.ts\",\n      \"line\": 42,\n      \"severity\": \"critical\" | \"major\" | \"minor\" | \"nit\",\n      \"comment\": \"Description of the issue and how to fix it\"\n    }\n  ]\n}\n\\`\\`\\`\n\nBe thorough but fair. Only request changes for real issues, not style preferences.`;\n\n  const output = await runClaude(prompt, { anthropicKey, timeoutMinutes });\n\n  // Parse the review\n  let reviewResult;\n  try {\n    const jsonMatch = output.match(/```json\\s*([\\s\\S]*?)\\s*```/) || output.match(/\\{[\\s\\S]*\\}/);\n    const jsonStr = jsonMatch ? (jsonMatch[1] || jsonMatch[0]) : output;\n    reviewResult = JSON.parse(jsonStr);\n  } catch (error) {\n    core.warning(`Failed to parse review response. Posting raw review.`);\n    await octokit.rest.pulls.createReview({\n      ...context.repo,\n      pull_number: pr.number,\n      body: `🔥 **Kiln Review**\\n\\n${output}`,\n      event: \"COMMENT\",\n    });\n    return { status: \"success\" };\n  }\n\n  // Build review comments\n  const comments = (reviewResult.issues || [])\n    .filter((i) => i.file && i.line)\n    .map((i) => ({\n      path: i.file,\n      line: i.line,\n      body: `**${i.severity}:** ${i.comment}`,\n    }));\n\n  // Submit the review\n  const event = reviewResult.verdict === \"approve\" ? \"APPROVE\" : \"REQUEST_CHANGES\";\n\n  const reviewBody = [\n    `🔥 **Kiln Review**`,\n    \"\",\n    reviewResult.summary,\n    \"\",\n    reviewResult.issues?.length\n      ? `Found **${reviewResult.issues.length}** issue(s): ${reviewResult.issues.filter((i) => i.severity === \"critical\").length} critical, ${reviewResult.issues.filter((i) => i.severity === \"major\").length} major, ${reviewResult.issues.filter((i) => i.severity === \"minor\").length} minor`\n      : \"No issues found. ✅\",\n  ].join(\"\\n\");\n\n  try {\n    await octokit.rest.pulls.createReview({\n      ...context.repo,\n      pull_number: pr.number,\n      body: reviewBody,\n      event,\n      comments: comments.length > 0 ? comments : undefined,\n    });\n  } catch (error) {\n    // If inline comments fail (e.g., line not in diff), post as regular review\n    core.warning(`Inline comments failed, posting summary review: ${error.message}`);\n    await octokit.rest.pulls.createReview({\n      ...context.repo,\n      pull_number: pr.number,\n      body: reviewBody + \"\\n\\n\" + (reviewResult.issues || []).map((i) => `- **${i.severity}** \\`${i.file}:${i.line}\\`: ${i.comment}`).join(\"\\n\"),\n      event,\n    });\n  }\n\n  return { status: \"success\", verdict: reviewResult.verdict };\n};\n","numLines":132,"startLine":1,"totalLines":132}}}
