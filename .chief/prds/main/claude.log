akeConfig({ spec_template: \"custom-template.md\" }),\n   251→      });\n   252→      await specify(ctx);\n   253→\n   254→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   255→      expect(prompt).toContain(\"# Custom Template\");\n   256→      expect(prompt).toContain(\"## My Section\");\n   257→    });\n   258→\n   259→    it(\"uses custom spec template from config.agents.spec.template\", async () => {\n   260→      mockedExistsSync.mockImplementation((path: string) => {\n   261→        if (path === \"agent-template.md\") return true;\n   262→        if (path === \"specs/issue-5.md\") return true;\n   263→        return false;\n   264→      });\n   265→      mockedReadFileSync.mockReturnValue(\"# Agent Template\");\n   266→\n   267→      const ctx = makeCtx({\n   268→        config: makeConfig({\n   269→          agents: {\n   270→            spec: { enabled: true, template: \"agent-template.md\" },\n   271→          } as KilnConfig[\"agents\"],\n   272→        }),\n   273→      });\n   274→      await specify(ctx);\n   275→\n   276→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   277→      expect(prompt).toContain(\"# Agent Template\");\n   278→    });\n   279→\n   280→    it(\"falls back to default template when custom path does not exist\", async () => {\n   281→      mockedExistsSync.mockImplementation((path: string) => {\n   282→        if (path === \"nonexistent.md\") return false;\n   283→        if (path === \"specs/issue-5.md\") return true;\n   284→        return false;\n   285→      });\n   286→\n   287→      const ctx = makeCtx({\n   288→        config: makeConfig({ spec_template: \"nonexistent.md\" }),\n   289→      });\n   290→      await specify(ctx);\n   291→\n   292→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   293→      // Default template includes these sections\n   294→      expect(prompt).toContain(\"Overview\");\n   295→      expect(prompt).toContain(\"Requirements\");