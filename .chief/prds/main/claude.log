?: string;\n  iteration?: number;\n}\n","structuredPatch":[{"oldStart":33,"oldLines":6,"newStart":33,"newLines":14,"lines":["   token: string;"," }"," ","+export interface RouteResult {","+  stage: string;","+  issueNumber?: number;","+  prNumber?: number;","+  labels: string[];","+  payload: Record<string, unknown>;","+}","+"," export interface StageResult {","   status: string;","   nextStage?: string;"]}],"userModified":false,"replaceAll":false}}
