{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013g6EnYMXPJSjijn711ZRzg","type":"tool_result","content":"     1→/**\n     2→ * Detects which Kiln stage to run based on the GitHub event.\n     3→ *\n     4→ * Event → Stage mapping:\n     5→ *\n     6→ *   issues.opened                                        → triage\n     7→ *   issues.labeled  (kiln:specifying)                    → specify\n     8→ *   pull_request_review.submitted (approved + spec PR)   → approve-spec\n     9→ *   issues.labeled  (kiln:implementing)                  → implement\n    10→ *   pull_request.opened (impl PR)                        → review\n    11→ *   pull_request_review.submitted (changes_requested)    → fix\n    12→ *   pull_request_review.submitted (approved + impl PR)   → ship\n    13→ *   check_suite.completed (impl PR, all green)           → ship\n    14→ */\n    15→function detectStage(context) {\n    16→  const { eventName, payload } = context;\n    17→\n    18→  // ── Issue Events ──────────────────────────────────────\n    19→  if (eventName === \"issues\") {\n    20→    const labels = payload.issue.labels.map((l) => l.name);\n    21→\n    22→    // New issue opened → triage\n    23→    if (payload.action === \"opened\") {\n    24→      return \"triage\";\n    25→    }\n    26→\n    27→    // Labeled events — check which label was just added\n    28→    if (payload.action === \"labeled\") {\n    29→      const added = payload.label.name;\n    30→\n    31→      if (added.endsWith(\":specifying\")) return \"specify\";\n    32→      if (added.endsWith(\":implementing\")) return \"implement\";\n    33→    }\n    34→  }\n    35→\n    36→  // ── Pull Request Events ───────────────────────────────\n    37→  if (eventName === \"pull_request\") {\n    38→    const labels = payload.pull_request.labels.map((l) => l.name);\n    39→\n    40→    // Impl PR opened or updated → review\n    41→    if (\n    42→      (payload.action === \"opened\" || payload.action === \"synchronize\") &&\n    43→      labels.some((l) => l.endsWith(\":implementation\"))\n    44→    ) {\n    45→      return \"review\";\n    46→    }\n    47→  }\n    48→\n    49→  // ── PR Review Events ──────────────────────────────────\n    50→  if (eventName === \"pull_request_review\") {\n    51→    const labels = payload.pull_request.labels.map((l) => l.name);\n    52→    const state = payload.review.state;\n    53→\n    54→    // Spec PR approved → approve-spec (triggers implementation)\n    55→    if (state === \"approved\" && labels.some((l) => l.endsWith(\":spec\"))) {\n    56→      return \"approve-spec\";\n    57→    }\n    58→\n    59→    // Impl PR: changes requested → fix\n    60→    if (\n    61→      state === \"changes_requested\" &&\n    62→      labels.some((l) => l.endsWith(\":implementation\"))\n    63→    ) {\n    64→      return \"fix\";\n    65→    }\n    66→\n    67→    // Impl PR: approved → ship\n    68→    if (\n    69→      state === \"approved\" &&\n    70→      labels.some((l) => l.endsWith(\":implementation\"))\n    71→    ) {\n    72→      return \"ship\";\n    73→    }\n    74→  }\n    75→\n    76→  // ── Check Suite (CI) Events ───────────────────────────\n    77→  if (eventName === \"check_suite\" && payload.action === \"completed\") {\n    78→    // If associated with an impl PR that's already approved, ship it\n    79→    // (The ship stage will double-check conditions)\n    80→    const prs = payload.check_suite.pull_requests || [];\n    81→    if (prs.length > 0) {\n    82→      return \"ship\";\n    83→    }\n    84→  }\n    85→\n    86→  return null;\n    87→}\n    88→\n    89→module.exports = { detectStage };\n    90→"}]},"parent_tool_use_id":null,"session_id":"2a8b2ce2-e0c8-48b6-8ab6-0a0f1560652c","uuid":"22c859da-15c9-43f1-bbca-c2cfc0806098","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/router.js","content":"/**\n * Detects which Kiln stage to run based on the GitHub event.\n *\n * Event → Stage mapping:\n *\n *   issues.opened                                        → triage\n *   issues.labeled  (kiln:specifying)                    → specify\n *   pull_request_review.submitted (approved + spec PR)   → approve-spec\n *   issues.labeled  (kiln:implementing)                  → implement\n *   pull_request.opened (impl PR)                        → review\n *   pull_request_review.submitted (changes_requested)    → fix\n *   pull_request_review.submitted (approved + impl PR)   → ship\n *   check_suite.completed (impl PR, all green)           → ship\n */\nfunction detectStage(context) {\n  const { eventName, payload } = context;\n\n  // ── Issue Events ──────────────────────────────────────\n  if (eventName === \"issues\") {\n    const labels = payload.issue.labels.map((l) => l.name);\n\n    // New issue opened → triage\n    if (payload.action === \"opened\") {\n      return \"triage\";\n    }\n\n    // Labeled events — check which label was just added\n    if (payload.action === \"labeled\") {\n      const added = payload.label.name;\n\n      if (added.endsWith(\":specifying\")) return \"specify\";\n      if (added.endsWith(\":implementing\")) return \"implement\";\n    }\n  }\n\n  // ── Pull Request Events ───────────────────────────────\n  if (eventName === \"pull_request\") {\n    const labels = payload.pull_request.labels.map((l) => l.name);\n\n    // Impl PR opened or updated → review\n    if (\n      (payload.action === \"opened\" || payload.action === \"synchronize\") &&\n      labels.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      return \"review\";\n    }\n  }\n\n  // ── PR Review Events ──────────────────────────────────\n  if (eventName === \"pull_request_review\") {\n    const labels = payload.pull_request.labels.map((l) => l.name);\n    const state = payload.review.state;\n\n    // Spec PR approved → approve-spec (triggers implementation)\n    if (state === \"approved\" && labels.some((l) => l.endsWith(\":spec\"))) {\n      return \"approve-spec\";\n    }\n\n    // Impl PR: changes requested → fix\n    if (\n      state === \"changes_requested\" &&\n      labels.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      return \"fix\";\n    }\n\n    // Impl PR: approved → ship\n    if (\n      state === \"approved\" &&\n      labels.some((l) => l.endsWith(\":implementation\"))\n    ) {\n      return \"ship\";\n    }\n  }\n\n  // ── Check Suite (CI) Events ───────────────────────────\n  if (eventName === \"check_suite\" && payload.action === \"completed\") {\n    // If associated with an impl PR that's already approved, ship it\n    // (The ship stage will double-check conditions)\n    const prs = payload.check_suite.pull_requests || [];\n    if (prs.length > 0) {\n      return \"ship\";\n    }\n  }\n\n  return null;\n}\n\nmodule.exports = { detectStage };\n","numLines":90,"startLine":1,"totalLines":90}}}
