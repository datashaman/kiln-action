{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011C8iVLHdfGnkx4JR1qjpuZ","type":"tool_result","content":"     1→const core = require(\"@actions/core\");\n     2→const { transitionLabel } = require(\"../labels\");\n     3→\n     4→module.exports = async function approveSpec(ctx) {\n     5→  const { octokit, context, config } = ctx;\n     6→  const pr = context.payload.pull_request;\n     7→  const prefix = config.labels?.prefix || \"kiln\";\n     8→\n     9→  core.info(`🔥 Approve Spec — PR #${pr.number}: ${pr.title}`);\n    10→\n    11→  // Merge the spec PR\n    12→  try {\n    13→    await octokit.rest.pulls.merge({\n    14→      ...context.repo,\n    15→      pull_number: pr.number,\n    16→      merge_method: \"squash\",\n    17→      commit_title: `${pr.title} (#${pr.number})`,\n    18→    });\n    19→    core.info(`Spec PR #${pr.number} merged.`);\n    20→  } catch (error) {\n    21→    core.setFailed(`Failed to merge spec PR: ${error.message}`);\n    22→    return { status: \"error\" };\n    23→  }\n    24→\n    25→  // Extract issue number from PR body\n    26→  const issueMatch = pr.body?.match(/Tracking issue: #(\\d+)/);\n    27→  if (!issueMatch) {\n    28→    core.warning(\"Could not find linked issue number in spec PR body.\");\n    29→    return { status: \"success\" };\n    30→  }\n    31→\n    32→  const issueNumber = parseInt(issueMatch[1]);\n    33→\n    34→  // Transition issue to implementing\n    35→  await transitionLabel(octokit, context, issueNumber, \"spec-review\", \"implementing\", prefix);\n    36→\n    37→  // Comment on issue\n    38→  await octokit.rest.issues.createComment({\n    39→    ...context.repo,\n    40→    issue_number: issueNumber,\n    41→    body: `🔨 **Kiln** — Spec approved and merged. Starting implementation.`,\n    42→  });\n    43→\n    44→  return { status: \"success\", nextStage: \"implement\" };\n    45→};\n    46→"}]},"parent_tool_use_id":null,"session_id":"2a8b2ce2-e0c8-48b6-8ab6-0a0f1560652c","uuid":"23c4ee3e-d0ff-41e9-a35a-da8c2b86a884","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/approve-spec.js","content":"const core = require(\"@actions/core\");\nconst { transitionLabel } = require(\"../labels\");\n\nmodule.exports = async function approveSpec(ctx) {\n  const { octokit, context, config } = ctx;\n  const pr = context.payload.pull_request;\n  const prefix = config.labels?.prefix || \"kiln\";\n\n  core.info(`🔥 Approve Spec — PR #${pr.number}: ${pr.title}`);\n\n  // Merge the spec PR\n  try {\n    await octokit.rest.pulls.merge({\n      ...context.repo,\n      pull_number: pr.number,\n      merge_method: \"squash\",\n      commit_title: `${pr.title} (#${pr.number})`,\n    });\n    core.info(`Spec PR #${pr.number} merged.`);\n  } catch (error) {\n    core.setFailed(`Failed to merge spec PR: ${error.message}`);\n    return { status: \"error\" };\n  }\n\n  // Extract issue number from PR body\n  const issueMatch = pr.body?.match(/Tracking issue: #(\\d+)/);\n  if (!issueMatch) {\n    core.warning(\"Could not find linked issue number in spec PR body.\");\n    return { status: \"success\" };\n  }\n\n  const issueNumber = parseInt(issueMatch[1]);\n\n  // Transition issue to implementing\n  await transitionLabel(octokit, context, issueNumber, \"spec-review\", \"implementing\", prefix);\n\n  // Comment on issue\n  await octokit.rest.issues.createComment({\n    ...context.repo,\n    issue_number: issueNumber,\n    body: `🔨 **Kiln** — Spec approved and merged. Starting implementation.`,\n  });\n\n  return { status: \"success\", nextStage: \"implement\" };\n};\n","numLines":46,"startLine":1,"totalLines":46}}}
