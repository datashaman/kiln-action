{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JWv7BCjQKf31MFMoqmmfiQ","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import { runClaude } from \"../claude\";\n     3→import { transitionLabel } from \"../labels\";\n     4→import { KilnContext, StageResult } from \"../types\";\n     5→\n     6→export interface TriageResult {\n     7→  type: string;\n     8→  complexity: string;\n     9→  clear_enough: boolean;\n    10→  comment: string;\n    11→  labels: string[];\n    12→}\n    13→\n    14→export default async function triage(ctx: KilnContext): Promise<StageResult> {\n    15→  const { octokit, context, config, anthropicKey, timeoutMinutes } = ctx;\n    16→  const issue = context.payload.issue!;\n    17→  const prefix = config.labels?.prefix || \"kiln\";\n    18→\n    19→  core.info(`🔥 Triage — Issue #${issue.number}: ${issue.title}`);\n    20→\n    21→  const prompt = `You are the Kiln triage agent. Analyze this issue and respond with ONLY a JSON block.\n    22→\n    23→**Issue #${issue.number}**\n    24→**Title:** ${issue.title}\n    25→**Body:** ${issue.body || \"(empty)\"}\n    26→\n    27→Classify and assess:\n    28→1. Type: feature, bug, improvement, or chore\n    29→2. Complexity: xs, s, m, l, xl\n    30→3. Is there enough information to write a technical spec? (clear_enough: true/false)\n    31→4. Write a brief comment for the issue author.\n    32→5. Suggest any additional labels (beyond type and size) that should be applied.\n    33→\n    34→If NOT clear enough, your comment should politely ask for the specific missing information.\n    35→If clear enough, your comment should confirm your understanding of what needs to be done.\n    36→\n    37→Respond with ONLY this JSON:\n    38→\\`\\`\\`json\n    39→{\n    40→  \"type\": \"feature\",\n    41→  \"complexity\": \"m\",\n    42→  \"clear_enough\": true,\n    43→  \"comment\": \"Your comment here\",\n    44→  \"labels\": []\n    45→}\n    46→\\`\\`\\``;\n    47→\n    48→  const output = runClaude(prompt, { anthropicKey, timeoutMinutes });\n    49→\n    50→  let result: TriageResult;\n    51→  try {\n    52→    const jsonMatch =\n    53→      output.match(/```json\\s*([\\s\\S]*?)\\s*```/) ||\n    54→      output.match(/\\{[\\s\\S]*\\}/);\n    55→    const jsonStr = jsonMatch ? jsonMatch[1] || jsonMatch[0] : output;\n    56→    result = JSON.parse(jsonStr);\n    57→  } catch (error) {\n    58→    const message = error instanceof Error ? error.message : String(error);\n    59→    core.warning(`Failed to parse triage response: ${message}`);\n    60→    core.warning(`Raw output: ${output}`);\n    61→    result = {\n    62→      type: \"feature\",\n    63→      complexity: \"m\",\n    64→      clear_enough: true,\n    65→      comment: \"🔥 **Kiln** — Triaged. Moving to specification.\",\n    66→      labels: [],\n    67→    };\n    68→  }\n    69→\n    70→  // Post branded triage comment\n    71→  await octokit.rest.issues.createComment({\n    72→    ...context.repo,\n    73→    issue_number: issue.number,\n    74→    body: `🔥 **Kiln Triage**\\n\\n${result.comment}\\n\\n---\\n*Type: \\`${result.type}\\` · Size: \\`${result.complexity}\\`*`,\n    75→  });\n    76→\n    77→  // Apply type and size labels, plus any additional labels from Claude\n    78→  const labels = [\n    79→    `type:${result.type}`,\n    80→    `size:${result.complexity}`,\n    81→    ...(result.labels || []),\n    82→  ];\n    83→  await octokit.rest.issues.addLabels({\n    84→    ...context.repo,\n    85→    issue_number: issue.number,\n    86→    labels,\n    87→  });\n    88→\n    89→  if (result.clear_enough) {\n    90→    // Clear enough → move to specifying\n    91→    await transitionLabel(\n    92→      octokit,\n    93→      context,\n    94→      issue.number,\n    95→      null,\n    96→      \"specifying\",\n    97→      prefix,\n    98→    );\n    99→    return { status: \"success\", nextStage: \"specify\" };\n   100→  }\n   101→\n   102→  // Not clear enough → apply needs-info label with proper prefix\n   103→  await octokit.rest.issues.addLabels({\n   104→    ...context.repo,\n   105→    issue_number: issue.number,\n   106→    labels: [`${prefix}:needs-info`],\n   107→  });\n   108→\n   109→  return { status: \"success\", nextStage: \"waiting-for-info\" };\n   110→}\n   111→"}]},"parent_tool_use_id":null,"session_id":"33191b76-3531-4700-8f9d-e8e8e80fe25e","uuid":"cb8a0153-28a0-4e92-a031-45ea1499db62","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/triage.ts","content":"import * as core from \"@actions/core\";\nimport { runClaude } from \"../claude\";\nimport { transitionLabel } from \"../labels\";\nimport { KilnContext, StageResult } from \"../types\";\n\nexport interface TriageResult {\n  type: string;\n  complexity: string;\n  clear_enough: boolean;\n  comment: string;\n  labels: string[];\n}\n\nexport default async function triage(ctx: KilnContext): Promise<StageResult> {\n  const { octokit, context, config, anthropicKey, timeoutMinutes } = ctx;\n  const issue = context.payload.issue!;\n  const prefix = config.labels?.prefix || \"kiln\";\n\n  core.info(`🔥 Triage — Issue #${issue.number}: ${issue.title}`);\n\n  const prompt = `You are the Kiln triage agent. Analyze this issue and respond with ONLY a JSON block.\n\n**Issue #${issue.number}**\n**Title:** ${issue.title}\n**Body:** ${issue.body || \"(empty)\"}\n\nClassify and assess:\n1. Type: feature, bug, improvement, or chore\n2. Complexity: xs, s, m, l, xl\n3. Is there enough information to write a technical spec? (clear_enough: true/false)\n4. Write a brief comment for the issue author.\n5. Suggest any additional labels (beyond type and size) that should be applied.\n\nIf NOT clear enough, your comment should politely ask for the specific missing information.\nIf clear enough, your comment should confirm your understanding of what needs to be done.\n\nRespond with ONLY this JSON:\n\\`\\`\\`json\n{\n  \"type\": \"feature\",\n  \"complexity\": \"m\",\n  \"clear_enough\": true,\n  \"comment\": \"Your comment here\",\n  \"labels\": []\n}\n\\`\\`\\``;\n\n  const output = runClaude(prompt, { anthropicKey, timeoutMinutes });\n\n  let result: TriageResult;\n  try {\n    const jsonMatch =\n      output.match(/```json\\s*([\\s\\S]*?)\\s*```/) ||\n      output.match(/\\{[\\s\\S]*\\}/);\n    const jsonStr = jsonMatch ? jsonMatch[1] || jsonMatch[0] : output;\n    result = JSON.parse(jsonStr);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.warning(`Failed to parse triage response: ${message}`);\n    core.warning(`Raw output: ${output}`);\n    result = {\n      type: \"feature\",\n      complexity: \"m\",\n      clear_enough: true,\n      comment: \"🔥 **Kiln** — Triaged. Moving to specification.\",\n      labels: [],\n    };\n  }\n\n  // Post branded triage comment\n  await octokit.rest.issues.createComment({\n    ...context.repo,\n    issue_number: issue.number,\n    body: `🔥 **Kiln Triage**\\n\\n${result.comment}\\n\\n---\\n*Type: \\`${result.type}\\` · Size: \\`${result.complexity}\\`*`,\n  });\n\n  // Apply type and size labels, plus any additional labels from Claude\n  const labels = [\n    `type:${result.type}`,\n    `size:${result.complexity}`,\n    ...(result.labels || []),\n  ];\n  await octokit.rest.issues.addLabels({\n    ...context.repo,\n    issue_number: issue.number,\n    labels,\n  });\n\n  if (result.clear_enough) {\n    // Clear enough → move to specifying\n    await transitionLabel(\n      octokit,\n      context,\n      issue.number,\n      null,\n      \"specifying\",\n      prefix,\n    );\n    return { status: \"success\", nextStage: \"specify\" };\n  }\n\n  // Not clear enough → apply needs-info label with proper prefix\n  await octokit.rest.issues.addLabels({\n    ...context.repo,\n    issue_number: issue.number,\n    labels: [`${prefix}:needs-info`],\n  });\n\n  return { status: \"success\", nextStage: \"waiting-for-info\" };\n}\n","numLines":111,"startLine":1,"totalLines":111}}}
