{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CbbZQkLtX5StZr2bQFjcdc","type":"tool_result","content":"     1→import * as core from \"@actions/core\";\n     2→import { transitionLabel } from \"../labels\";\n     3→import { KilnContext, StageResult } from \"../types\";\n     4→\n     5→export default async function approveSpec(\n     6→  ctx: KilnContext,\n     7→): Promise<StageResult> {\n     8→  const { octokit, context, config } = ctx;\n     9→  const pr = context.payload.pull_request!;\n    10→  const prefix = config.labels?.prefix || \"kiln\";\n    11→\n    12→  core.info(`🔥 Approve Spec — PR #${pr.number}: ${pr.title}`);\n    13→\n    14→  try {\n    15→    await octokit.rest.pulls.merge({\n    16→      ...context.repo,\n    17→      pull_number: pr.number,\n    18→      merge_method: \"squash\",\n    19→      commit_title: `${pr.title} (#${pr.number})`,\n    20→    });\n    21→    core.info(`Spec PR #${pr.number} merged.`);\n    22→  } catch (error) {\n    23→    const message = error instanceof Error ? error.message : String(error);\n    24→    core.setFailed(`Failed to merge spec PR: ${message}`);\n    25→    return { status: \"error\" };\n    26→  }\n    27→\n    28→  // Extract issue number from branch name (kiln/spec/issue-{number})\n    29→  const branchName = pr.head?.ref as string | undefined;\n    30→  const branchMatch = branchName?.match(/^kiln\\/spec\\/issue-(\\d+)$/);\n    31→\n    32→  // Fallback to PR body if branch name doesn't match\n    33→  const bodyMatch = !branchMatch\n    34→    ? (pr.body as string | undefined)?.match(/Tracking issue: #(\\d+)/)\n    35→    : null;\n    36→\n    37→  const issueMatch = branchMatch || bodyMatch;\n    38→  if (!issueMatch) {\n    39→    core.warning(\"Could not find linked issue number in branch name or PR body.\");\n    40→    return { status: \"success\" };\n    41→  }\n    42→\n    43→  const issueNumber = parseInt(issueMatch[1], 10);\n    44→\n    45→  await transitionLabel(\n    46→    octokit,\n    47→    context,\n    48→    issueNumber,\n    49→    \"spec-review\",\n    50→    \"implementing\",\n    51→    prefix,\n    52→  );\n    53→\n    54→  await octokit.rest.issues.createComment({\n    55→    ...context.repo,\n    56→    issue_number: issueNumber,\n    57→    body: `🔨 **Kiln** — Spec approved and merged. Starting implementation.`,\n    58→  });\n    59→\n    60→  return { status: \"success\", nextStage: \"implement\" };\n    61→}\n    62→"}]},"parent_tool_use_id":null,"session_id":"c724d35f-7b14-4623-85ef-5de838552fab","uuid":"d837e954-b32a-4cec-943c-968b3f9edeef","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/stages/approve-spec.ts","content":"import * as core from \"@actions/core\";\nimport { transitionLabel } from \"../labels\";\nimport { KilnContext, StageResult } from \"../types\";\n\nexport default async function approveSpec(\n  ctx: KilnContext,\n): Promise<StageResult> {\n  const { octokit, context, config } = ctx;\n  const pr = context.payload.pull_request!;\n  const prefix = config.labels?.prefix || \"kiln\";\n\n  core.info(`🔥 Approve Spec — PR #${pr.number}: ${pr.title}`);\n\n  try {\n    await octokit.rest.pulls.merge({\n      ...context.repo,\n      pull_number: pr.number,\n      merge_method: \"squash\",\n      commit_title: `${pr.title} (#${pr.number})`,\n    });\n    core.info(`Spec PR #${pr.number} merged.`);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    core.setFailed(`Failed to merge spec PR: ${message}`);\n    return { status: \"error\" };\n  }\n\n  // Extract issue number from branch name (kiln/spec/issue-{number})\n  const branchName = pr.head?.ref as string | undefined;\n  const branchMatch = branchName?.match(/^kiln\\/spec\\/issue-(\\d+)$/);\n\n  // Fallback to PR body if branch name doesn't match\n  const bodyMatch = !branchMatch\n    ? (pr.body as string | undefined)?.match(/Tracking issue: #(\\d+)/)\n    : null;\n\n  const issueMatch = branchMatch || bodyMatch;\n  if (!issueMatch) {\n    core.warning(\"Could not find linked issue number in branch name or PR body.\");\n    return { status: \"success\" };\n  }\n\n  const issueNumber = parseInt(issueMatch[1], 10);\n\n  await transitionLabel(\n    octokit,\n    context,\n    issueNumber,\n    \"spec-review\",\n    \"implementing\",\n    prefix,\n  );\n\n  await octokit.rest.issues.createComment({\n    ...context.repo,\n    issue_number: issueNumber,\n    body: `🔨 **Kiln** — Spec approved and merged. Starting implementation.`,\n  });\n\n  return { status: \"success\", nextStage: \"implement\" };\n}\n","numLines":62,"startLine":1,"totalLines":62}}}
