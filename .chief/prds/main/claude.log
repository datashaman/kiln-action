{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GA8i46TtEepQx9CLdwPWSg","type":"tool_result","content":"     1→import { GitHub } from \"@actions/github/lib/utils\";\n     2→import { Context } from \"@actions/github/lib/context\";\n     3→\n     4→export type Octokit = InstanceType<typeof GitHub>;\n     5→\n     6→export interface KilnConfig {\n     7→  protected_paths: string[];\n     8→  human_review: {\n     9→    spec: string;\n    10→    implementation: string;\n    11→  };\n    12→  auto_merge: boolean;\n    13→  timeout_minutes: number;\n    14→  labels: {\n    15→    prefix: string;\n    16→  };\n    17→  agents: {\n    18→    triage: { enabled: boolean };\n    19→    spec: { enabled: boolean; template?: string };\n    20→    implement: { enabled: boolean; run_tests: boolean; run_lint: boolean };\n    21→    review: { enabled: boolean; auto_approve: boolean };\n    22→    fix: { enabled: boolean; max_iterations: number };\n    23→  };\n    24→  spec_template?: string;\n    25→}\n    26→\n    27→export interface KilnContext {\n    28→  octokit: Octokit;\n    29→  context: Context;\n    30→  config: KilnConfig;\n    31→  anthropicKey: string;\n    32→  timeoutMinutes: number;\n    33→  token: string;\n    34→}\n    35→\n    36→export interface RouteResult {\n    37→  stage: string;\n    38→  issueNumber?: number;\n    39→  prNumber?: number;\n    40→  labels: string[];\n    41→  payload: Record<string, unknown>;\n    42→}\n    43→\n    44→export interface StageResult {\n    45→  status: string;\n    46→  nextStage?: string;\n    47→  prNumber?: number;\n    48→  reason?: string;\n    49→  verdict?: string;\n    50→  iteration?: number;\n    51→}\n    52→"}]},"parent_tool_use_id":null,"session_id":"33191b76-3531-4700-8f9d-e8e8e80fe25e","uuid":"8238d8ce-7ce2-4ff7-80a6-30a8bd02db9c","tool_use_result":{"type":"text","file":{"filePath":"/Users/marlinf/Projects/datashaman/kiln-action/src/types.ts","content":"import { GitHub } from \"@actions/github/lib/utils\";\nimport { Context } from \"@actions/github/lib/context\";\n\nexport type Octokit = InstanceType<typeof GitHub>;\n\nexport interface KilnConfig {\n  protected_paths: string[];\n  human_review: {\n    spec: string;\n    implementation: string;\n  };\n  auto_merge: boolean;\n  timeout_minutes: number;\n  labels: {\n    prefix: string;\n  };\n  agents: {\n    triage: { enabled: boolean };\n    spec: { enabled: boolean; template?: string };\n    implement: { enabled: boolean; run_tests: boolean; run_lint: boolean };\n    review: { enabled: boolean; auto_approve: boolean };\n    fix: { enabled: boolean; max_iterations: number };\n  };\n  spec_template?: string;\n}\n\nexport interface KilnContext {\n  octokit: Octokit;\n  context: Context;\n  config: KilnConfig;\n  anthropicKey: string;\n  timeoutMinutes: number;\n  token: string;\n}\n\nexport interface RouteResult {\n  stage: string;\n  issueNumber?: number;\n  prNumber?: number;\n  labels: string[];\n  payload: Record<string, unknown>;\n}\n\nexport interface StageResult {\n  status: string;\n  nextStage?: string;\n  prNumber?: number;\n  reason?: string;\n  verdict?: string;\n  iteration?: number;\n}\n","numLines":52,"startLine":1,"totalLines":52}}}
