{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F1XzcfZEY3h1j3n4ATJtf5","type":"tool_result","content":"     1→import specify from \"./specify\";\n     2→import { KilnContext, KilnConfig, Octokit } from \"../types\";\n     3→import { Context } from \"@actions/github/lib/context\";\n     4→\n     5→jest.mock(\"@actions/core\");\n     6→jest.mock(\"../claude\");\n     7→jest.mock(\"../labels\");\n     8→jest.mock(\"child_process\", () => ({\n     9→  execSync: jest.fn().mockReturnValue(\"\"),\n    10→}));\n    11→\n    12→// Partial mock of fs: preserve promises (needed by @actions/core) but mock sync methods\n    13→jest.mock(\"fs\", () => {\n    14→  const actual = jest.requireActual(\"fs\");\n    15→  return {\n    16→    ...actual,\n    17→    existsSync: jest.fn(),\n    18→    mkdirSync: jest.fn(),\n    19→    readFileSync: jest.fn(),\n    20→  };\n    21→});\n    22→\n    23→import * as core from \"@actions/core\";\n    24→import { runClaudeEdit } from \"../claude\";\n    25→import { transitionLabel } from \"../labels\";\n    26→import { execSync } from \"child_process\";\n    27→import * as fs from \"fs\";\n    28→\n    29→const mockedRunClaudeEdit = runClaudeEdit as unknown as jest.Mock;\n    30→const mockedTransitionLabel = transitionLabel as unknown as jest.Mock;\n    31→const mockedExecSync = execSync as unknown as jest.Mock;\n    32→const mockedExistsSync = fs.existsSync as unknown as jest.Mock;\n    33→const mockedMkdirSync = fs.mkdirSync as unknown as jest.Mock;\n    34→const mockedReadFileSync = fs.readFileSync as unknown as jest.Mock;\n    35→\n    36→function makeOctokit(): Octokit {\n    37→  return {\n    38→    rest: {\n    39→      pulls: {\n    40→        create: jest.fn().mockResolvedValue({\n    41→          data: { number: 10 },\n    42→        }),\n    43→      },\n    44→      issues: {\n    45→        createComment: jest.fn().mockResolvedValue({}),\n    46→        addLabels: jest.fn().mockResolvedValue({}),\n    47→      },\n    48→    },\n    49→  } as unknown as Octokit;\n    50→}\n    51→\n    52→function makeConfig(\n    53→  overrides: Partial<KilnConfig> = {},\n    54→  prefix = \"kiln\",\n    55→): KilnConfig {\n    56→  return {\n    57→    labels: { prefix },\n    58→    ...overrides,\n    59→  } as unknown as KilnConfig;\n    60→}\n    61→\n    62→function makeContext(issuePayload: Record<string, unknown> = {}): Context {\n    63→  return {\n    64→    eventName: \"issues\",\n    65→    payload: {\n    66→      action: \"labeled\",\n    67→      issue: {\n    68→        number: 5,\n    69→        title: \"Add user authentication\",\n    70→        body: \"We need OAuth2 login support.\",\n    71→        labels: [{ name: \"kiln:specifying\" }],\n    72→        ...issuePayload,\n    73→      },\n    74→    },\n    75→    repo: { owner: \"test-owner\", repo: \"test-repo\" },\n    76→  } as unknown as Context;\n    77→}\n    78→\n    79→function makeCtx(overrides: Partial<KilnContext> = {}): KilnContext {\n    80→  return {\n    81→    octokit: makeOctokit(),\n    82→    context: makeContext(),\n    83→    config: makeConfig(),\n    84→    anthropicKey: \"sk-ant-test-key\",\n    85→    timeoutMinutes: 30,\n    86→    token: \"ghp-test-token\",\n    87→    ...overrides,\n    88→  };\n    89→}\n    90→\n    91→beforeEach(() => {\n    92→  jest.clearAllMocks();\n    93→  mockedTransitionLabel.mockResolvedValue(undefined);\n    94→  mockedRunClaudeEdit.mockReturnValue(\"Spec created successfully\");\n    95→  mockedExecSync.mockReturnValue(\"\");\n    96→  mockedMkdirSync.mockReturnValue(undefined);\n    97→\n    98→  // By default, spec file exists after Claude creates it\n    99→  mockedExistsSync.mockImplementation((path: string) => {\n   100→    if (path === \"specs/issue-5.md\") return true;\n   101→    return false;\n   102→  });\n   103→});\n   104→\n   105→describe(\"specify\", () => {\n   106→  // ── AC: Triggers when issue receives kiln:specifying label ──\n   107→  describe(\"triggers on kiln:specifying label\", () => {\n   108→    it(\"processes an issue with kiln:specifying label\", async () => {\n   109→      const ctx = makeCtx();\n   110→      const result = await specify(ctx);\n   111→      expect(result.status).toBe(\"success\");\n   112→    });\n   113→\n   114→    it(\"logs the issue number and title\", async () => {\n   115→      const ctx = makeCtx();\n   116→      await specify(ctx);\n   117→      expect(core.info).toHaveBeenCalledWith(\n   118→        expect.stringContaining(\"Issue #5: Add user authentication\"),\n   119→      );\n   120→    });\n   121→  });\n   122→\n   123→  // ── AC: Checks out the repo and sends issue context to Claude ──\n   124→  describe(\"checks out repo and invokes Claude\", () => {\n   125→    it(\"creates a spec branch kiln/spec/issue-{number}\", async () => {\n   126→      const ctx = makeCtx();\n   127→      await specify(ctx);\n   128→\n   129→      expect(mockedExecSync).toHaveBeenCalledWith(\n   130→        \"git checkout -b kiln/spec/issue-5\",\n   131→      );\n   132→    });\n   133→\n   134→    it(\"configures git user before branching\", async () => {\n   135→      const ctx = makeCtx();\n   136→      await specify(ctx);\n   137→\n   138→      const calls = mockedExecSync.mock.calls.map(\n   139→        (c: unknown[]) => c[0] as string,\n   140→      );\n   141→      const configNameIdx = calls.findIndex((c: string) =>\n   142→        c.includes(\"git config user.name\"),\n   143→      );\n   144→      const configEmailIdx = calls.findIndex((c: string) =>\n   145→        c.includes(\"git config user.email\"),\n   146→      );\n   147→      const checkoutIdx = calls.findIndex((c: string) =>\n   148→        c.includes(\"git checkout\"),\n   149→      );\n   150→\n   151→      expect(configNameIdx).toBeLessThan(checkoutIdx);\n   152→      expect(configEmailIdx).toBeLessThan(checkoutIdx);\n   153→    });\n   154→\n   155→    it(\"creates specs directory\", async () => {\n   156→      const ctx = makeCtx();\n   157→      await specify(ctx);\n   158→\n   159→      expect(mockedMkdirSync).toHaveBeenCalledWith(\"specs\", {\n   160→        recursive: true,\n   161→      });\n   162→    });\n   163→\n   164→    it(\"sends issue title and body to Claude via runClaudeEdit\", async () => {\n   165→      const ctx = makeCtx();\n   166→      await specify(ctx);\n   167→\n   168→      expect(mockedRunClaudeEdit).toHaveBeenCalledWith(\n   169→        expect.stringContaining(\"Add user authentication\"),\n   170→        expect.objectContaining({\n   171→          anthropicKey: \"sk-ant-test-key\",\n   172→          timeoutMinutes: 30,\n   173→        }),\n   174→      );\n   175→\n   176→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   177→      expect(prompt).toContain(\"We need OAuth2 login support.\");\n   178→    });\n   179→\n   180→    it(\"includes issue number in the prompt\", async () => {\n   181→      const ctx = makeCtx();\n   182→      await specify(ctx);\n   183→\n   184→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   185→      expect(prompt).toContain(\"Issue #5\");\n   186→    });\n   187→\n   188→    it(\"handles empty issue body\", async () => {\n   189→      mockedExistsSync.mockImplementation((path: string) => {\n   190→        if (path === \"specs/issue-7.md\") return true;\n   191→        return false;\n   192→      });\n   193→      const ctx = makeCtx({\n   194→        context: makeContext({ number: 7, title: \"Bug\", body: null }),\n   195→      });\n   196→      await specify(ctx);\n   197→\n   198→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   199→      expect(prompt).toContain(\"(empty)\");\n   200→    });\n   201→\n   202→    it(\"invokes Claude in edit mode (not read-only)\", async () => {\n   203→      const ctx = makeCtx();\n   204→      await specify(ctx);\n   205→\n   206→      expect(mockedRunClaudeEdit).toHaveBeenCalled();\n   207→    });\n   208→  });\n   209→\n   210→  // ── AC: Claude creates spec file with required sections ──\n   211→  describe(\"spec file creation\", () => {\n   212→    it(\"instructs Claude to create spec at specs/issue-{number}.md\", async () => {\n   213→      const ctx = makeCtx();\n   214→      await specify(ctx);\n   215→\n   216→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   217→      expect(prompt).toContain(\"specs/issue-5.md\");\n   218→    });\n   219→\n   220→    it(\"includes spec template with all required sections in prompt\", async () => {\n   221→      const ctx = makeCtx();\n   222→      await specify(ctx);\n   223→\n   224→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   225→      expect(prompt).toContain(\"Overview\");\n   226→      expect(prompt).toContain(\"Requirements\");\n   227→      expect(prompt).toContain(\"Technical Design\");\n   228→      expect(prompt).toContain(\"Test Plan\");\n   229→      expect(prompt).toContain(\"Out of Scope\");\n   230→      expect(prompt).toContain(\"Implementation Notes\");\n   231→    });\n   232→\n   233→    it(\"verifies spec file was created after Claude runs\", async () => {\n   234→      const ctx = makeCtx();\n   235→      await specify(ctx);\n   236→\n   237→      expect(mockedExistsSync).toHaveBeenCalledWith(\"specs/issue-5.md\");\n   238→    });\n   239→\n   240→    it(\"fails if spec file was not created\", async () => {\n   241→      mockedExistsSync.mockReturnValue(false);\n   242→      const ctx = makeCtx();\n   243→      const result = await specify(ctx);\n   244→\n   245→      expect(result.status).toBe(\"error\");\n   246→      expect(core.setFailed).toHaveBeenCalledWith(\n   247→        \"Spec agent did not create specs/issue-5.md\",\n   248→      );\n   249→    });\n   250→  });\n   251→\n   252→  // ── AC: Custom spec template ──\n   253→  describe(\"custom spec template\", () => {\n   254→    it(\"uses custom spec template from config.spec_template\", async () => {\n   255→      mockedExistsSync.mockImplementation((path: string) => {\n   256→        if (path === \"custom-template.md\") return true;\n   257→        if (path === \"specs/issue-5.md\") return true;\n   258→        return false;\n   259→      });\n   260→      mockedReadFileSync.mockReturnValue(\"# Custom Template\\n## My Section\");\n   261→\n   262→      const ctx = makeCtx({\n   263→        config: makeConfig({ spec_template: \"custom-template.md\" }),\n   264→      });\n   265→      await specify(ctx);\n   266→\n   267→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   268→      expect(prompt).toContain(\"# Custom Template\");\n   269→      expect(prompt).toContain(\"## My Section\");\n   270→    });\n   271→\n   272→    it(\"uses custom spec template from config.agents.spec.template\", async () => {\n   273→      mockedExistsSync.mockImplementation((path: string) => {\n   274→        if (path === \"agent-template.md\") return true;\n   275→        if (path === \"specs/issue-5.md\") return true;\n   276→        return false;\n   277→      });\n   278→      mockedReadFileSync.mockReturnValue(\"# Agent Template\");\n   279→\n   280→      const ctx = makeCtx({\n   281→        config: makeConfig({\n   282→          agents: {\n   283→            spec: { enabled: true, template: \"agent-template.md\" },\n   284→          } as KilnConfig[\"agents\"],\n   285→        }),\n   286→      });\n   287→      await specify(ctx);\n   288→\n   289→      const prompt = mockedRunClaudeEdit.mock.calls[0][0] as string;\n   290→      expect(prompt).toContain(\"# Agent Template\");\n   291→    });\n   292→\n   293→    it(\"falls back to default template when custom path does not exist\", async () => {\n   294→      mockedExistsSync.mockImplementation((path: string) => {\n   295→        if (path === \"nonexistent.md\") return false;\n   296→        if (path === \"specs/issue-5.md\") return true;\n   297→        return false;\n   298→      });\n   2